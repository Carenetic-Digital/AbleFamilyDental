---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    title: "Fillings",
    href: "/services/restorative/fillings",
    description: "Tooth-coloured composite resin fillings repair cavities and minor cracks while blending naturally with your tooth.",
    icon: `<path d="M12 2C9 2 7 4 7 7c0 1.5.5 2.5 1 3.5.5 1 1 2 1 3.5 0 2 .5 4 3 4 1 0 1.5-1 2-1.5.5.5 1 1.5 2 1.5 2.5 0 3-2 3-4 0-1.5.5-2.5 1-3.5.5-1 1-2 1-3.5 0-3-2-5-5-5z"/>`,
  },
  {
    title: "Bridges",
    href: "/services/restorative/bridges",
    description: "A fixed prosthetic that spans a gap left by one or more missing teeth, anchored to adjacent teeth or implants.",
    icon: `<path d="M3 9h18"/><path d="M3 15h18"/><path d="M8 9v6"/><path d="M16 9v6"/><rect x="3" y="6" width="18" height="12" rx="2" ry="2" fill="none"/>`,
  },
  {
    title: "Crowns",
    href: "/services/restorative/crowns",
    description: "A cap placed over a damaged or weakened tooth to restore its shape, strength, and appearance for long-term function.",
    icon: `<path d="M2 4l3 12h14l3-12-6 7-4-7-4 7-6-7z"/>`,
  },
  {
    title: "Dentures",
    href: "/services/restorative/dentures",
    description: "Custom-fitted removable or implant-supported prosthetics that restore a full arch — or partial set — of missing teeth.",
    icon: `<path d="M12 2C8 2 5 5 5 9c0 2.5 1.5 5 3 6.5V18h8v-2.5c1.5-1.5 3-4 3-6.5 0-4-3-7-7-7z"/><path d="M9 18v3"/><path d="M15 18v3"/>`,
  },
  {
    title: "Implants",
    href: "/services/restorative/implants",
    description: "A titanium post placed in the jawbone as a tooth root replacement, topped with a natural-looking crown.",
    icon: `<line x1="12" y1="2" x2="12" y2="12"/><circle cx="12" cy="16" r="4"/><path d="M9 9l3-7 3 7"/>`,
  },
  {
    title: "Root Canal Treatment",
    href: "/services/restorative/root-canal",
    description: "A procedure to remove infected or inflamed pulp from inside a tooth, relieving pain and saving the tooth from extraction.",
    icon: `<path d="M12 2v8"/><path d="M9 5l3-3 3 3"/><path d="M8 10c0 4 1.5 8 4 10 2.5-2 4-6 4-10"/><path d="M6 10h12"/>`,
  },
];
---

<BaseLayout
  title="Restorative Dentistry | Wildwood Dental Clinic Saskatoon"
  description="Repair, rebuild, and replace damaged or missing teeth with restorative dentistry at Wildwood Dental Clinic in Saskatoon. Fillings, crowns, bridges, dentures, implants, and root canal treatment."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-16 lg:py-20">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Restorative</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Restorative Dentistry</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Repair, Rebuild, and Replace
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        When a tooth is damaged, decayed, or missing, restorative dentistry brings it back to full function. Our team at Wildwood Dental takes a conservative approach — preserving as much natural tooth structure as possible.
      </p>
    </div>
  </section>

  <!-- ============================================================
       INTRO + SERVICE CARDS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <div class="max-w-2xl mb-12">
        <p class="text-[var(--color-text)] text-lg leading-relaxed">
          Restorative dental care addresses a wide range of concerns — from a small cavity to a missing tooth. Whether you need a straightforward filling or a more involved treatment like an implant or denture, our team works with you to choose the approach that fits your oral health needs and long-term goals.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(svc => (
          <div class="bg-white rounded-2xl p-7 shadow-md border border-[var(--color-border-soft)] flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-5 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon} />
            </div>
            <h3 class="font-display font-semibold text-[length:var(--text-xl)] text-[var(--color-brand-primary)] leading-snug">
              {svc.title}
            </h3>
            <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">
              {svc.description}
            </p>
            <a href={svc.href} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
              Learn More
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to restore your smile?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> or book online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/patients/book" class="btn btn-primary btn-lg">Book an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
