---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "Exams & Cleanings", href: "/services/childrens/exams-cleanings" },
  { name: "Infant Oral Care", href: "/services/childrens/infant-oral-care" },
  { name: "Fluoride", href: "/services/childrens/fluoride" },
  { name: "Sealants", href: "/services/childrens/sealants" },
  { name: "X-Rays", href: "/services/childrens/x-rays" },
  { name: "Frenectomies", href: "/services/childrens/frenectomies", current: true },
  { name: "Space Maintainers", href: "/services/childrens/space-maintainers" },
  { name: "Comfort & Anxiety", href: "/services/childrens/comfort" },
];
---

<BaseLayout
  title="Frenectomies | Tongue-Tie & Lip-Tie | Wildwood Dental Clinic Saskatoon"
  description="Frenectomy procedures for tongue-tie and lip-tie at Wildwood Dental Clinic in Saskatoon. What they are, who needs one, and what to expect."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/childrens-smile.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/childrens" class="hover:text-white transition-colors">Children's Dentistry</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Frenectomies</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Children's Dentistry</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Frenectomies (Tongue-Tie &amp; Lip-Tie)
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        A frenectomy is a simple procedure to release a tight frenum, the small fold of tissue that can restrict tongue or lip movement in some children.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Specialty disclaimer -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Dental services for children at Wildwood Dental Clinic are provided by our general dentist team. Our dentists are not licensed specialists in pediatric dentistry.
              </p>
            </div>
          </div>

          <!-- What a frenum is -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What is a frenum?
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                A frenum (or frenulum) is a small fold of soft tissue that connects one structure to another in the mouth. Everyone has several frenula, notably, the lingual frenum, which connects the underside of the tongue to the floor of the mouth, and the labial frenum, which connects the upper lip to the gum above the front teeth.
              </p>
              <p>
                In most people, these frenula are positioned and sized in a way that causes no problems. In some children, however, the frenum may be shorter, thicker, or positioned in a way that limits movement, which is where the terms "tongue-tie" and "lip-tie" come in.
              </p>
            </div>
          </div>

          <!-- Image break -->
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/images/services/content-dental-chair.jpg"
              alt="Dental treatment chair in a comfortable clinical setting"
              width="800"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full h-56 sm:h-72 object-cover"
            />
          </div>


          <!-- Tongue-tie -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Tongue-tie (ankyloglossia)
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Tongue-tie occurs when the lingual frenum is tight enough to restrict the tongue's range of motion. In infants, a restricted tongue can make it difficult to latch effectively during breastfeeding, which may affect feeding comfort and milk transfer. In older children, tongue-tie has been associated in some cases with speech articulation difficulties and challenges with oral hygiene.
              </p>
              <p>
                It is worth noting that not all tongue-ties cause functional problems, and not all cases require treatment. The degree of restriction and whether it is causing identifiable difficulties, rather than simply the appearance of the frenum, guides the decision about whether intervention makes sense.
              </p>
            </div>
          </div>

          <!-- Lip-tie -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Lip-tie
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                A lip-tie involves the upper labial frenum, the tissue connecting the upper lip to the gum. When this frenum is particularly short or thick, it may limit the upper lip's ability to flange outward during breastfeeding, affecting latch in some infants. In older children and adults, a prominent upper labial frenum can contribute to a gap between the upper front teeth or, in some cases, gum recession near the upper front teeth.
              </p>
              <p>
                As with tongue-tie, the presence of a lip-tie alone does not necessarily mean treatment is required, the impact on function is the key consideration.
              </p>
            </div>
          </div>

          <!-- When a frenectomy is recommended -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-4">
              When a frenectomy may be recommended
            </h2>
            <div class="space-y-3 text-[var(--color-text)] leading-relaxed">
              <p>
                A frenectomy may be considered when a frenum is causing functional difficulties, such as breastfeeding challenges in an infant, speech concerns in a child, or other dental or hygiene issues. The decision is typically made after assessment by the dental team, and often with input from other providers as well.
              </p>
              <p>
                For infants with suspected tongue-tie affecting breastfeeding, involving a lactation consultant and, where relevant, a speech-language pathologist in the evaluation is common practice. A frenectomy in this context is often an interdisciplinary decision.
              </p>
            </div>
          </div>

          <!-- The procedure -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              The procedure
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                A frenectomy is a simple procedure involving the release of the frenum tissue. Local anesthetic is used to keep the area comfortable. The procedure itself is typically brief, and recovery is usually short.
              </p>
              <p>
                For very young infants, topical or local anesthetic may be used depending on the approach. For older children and adults, local anesthetic injection is standard.
              </p>
            </div>
          </div>

          <!-- Post-procedure care -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Post-procedure care
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                After a frenectomy, gentle stretching exercises are often recommended in the days and weeks following the procedure. These exercises help prevent the frenum from reattaching as healing occurs. Detailed instructions are provided at the appointment and our team is available to answer questions during recovery.
              </p>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or book online, new patients welcome.</p>
            <a href="/book" class="mt-4 btn btn-primary w-full block text-center">Request Appointment</a>
            <a href="tel:+13063747272" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">306.374.7272</a>
          </div>

          <!-- Sibling services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Children's Dentistry</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Questions about your child's dental care?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> or book online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
