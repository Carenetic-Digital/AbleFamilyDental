---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceCategories = [
  { title: "Emergency Services", href: "/services/emergency", icon: "/images/icons/Oral Surgery Sedation Dentistry.svg", description: "Prompt care when you need it most — same-day appointments available.", items: ["Toothache Relief", "Broken/Chipped Tooth Repair", "Knocked-Out Tooth Treatment", "Same-Day Appointments"] },
  { title: "Preventive Dentistry", href: "/services/preventive", icon: "/images/icons/Preventative Dental Care.svg", description: "Routine care that keeps small issues from becoming big ones.", items: ["Routine Cleanings & Exams", "Fluoride Treatments", "Dental Sealants", "Night Guards & Sport Guards"] },
  { title: "Diagnostic Services", href: "/services/diagnostic", icon: "/images/icons/Diagnostic Imaging and X Rays.svg", description: "Advanced imaging technology for accurate, early diagnosis.", items: ["X-Rays & 3D Imaging", "CBCT Scans (Cone Beam CT)", "Intraoral Cameras", "Oral Cancer Screenings"] },
  { title: "Children's Dentistry", href: "/services/childrens", icon: "/images/icons/Pediatric Dentistry.svg", description: "Gentle, kid-friendly care starting from their very first tooth.", items: ["Children's Exams & Cleanings", "Infant Oral Care (First Visit by Age 1)", "Frenectomies (Tongue-Ties)", "Space Maintainers"] },
  { title: "Orthodontics", href: "/services/orthodontics", icon: "/images/icons/Cosmetic Dentistry.svg", description: "Straighten your smile discreetly with clear aligner therapy.", items: ["Invisalign & Clear Aligners"] },
  { title: "Restorative", href: "/services/restorative", icon: "/images/icons/Restorative Dentistry.svg", description: "Rebuild function and confidence with durable, natural-looking restorations.", items: ["Tooth-Colored Fillings", "Crowns & Bridges", "Inlays & Onlays"] },
  { title: "Oral Surgery", href: "/services/oral-surgery", icon: "/images/icons/Oral Surgery Sedation Dentistry.svg", description: "Expert surgical care — from simple extractions to dental implants.", items: ["Extractions", "Wisdom Tooth Extraction", "Dental Implants"] },
  { title: "Periodontal Care", href: "/services/periodontal", icon: "/images/icons/Oral Hygine Cleanings.svg", description: "Protecting your gum health to support a lifetime of strong teeth.", items: ["Scaling & Root Planing", "Gum Disease Treatment", "Gum Contouring"] },
  { title: "Endodontics", href: "/services/endodontics", icon: "/images/icons/Dental Fillings and Repairs.svg", description: "Saving teeth that are damaged or infected from the inside out.", items: ["Root Canal Treatment", "Cracked Tooth Treatment", "Traumatic Dental Injuries"] },
  { title: "Cosmetic Dentistry", href: "/services/cosmetic", icon: "/images/icons/Cosmetic Dentistry.svg", description: "Refine your smile's appearance while keeping it healthy.", items: ["Teeth Whitening", "Porcelain Veneers", "Smile Makeovers", "Dental Bonding"] },
  { title: "TMJ/TMD Therapy", href: "/services/tmj", icon: "/images/icons/Dental Exams and Check Ups.svg", description: "Relief from jaw pain, headaches, and bite problems.", items: ["TMJ Diagnosis", "Botulinum Toxin Therapy for Jaw Pain", "Custom Night Guards", "Bite Correction"] },
];
---

<BaseLayout
  title="Wildwood Dental Clinic | Family Dentistry on 8th Street East, Saskatoon"
  description="A family-friendly general dentistry clinic on 8th Street East in Saskatoon. Saskatchewan-trained dentists offering preventive, restorative, cosmetic, and surgical care for over 35 years."
>

  <!-- ============================================================
       SECTION 1: Hero
       ============================================================ -->
  <section class="relative overflow-hidden bg-white min-h-[520px] lg:min-h-[600px]">

    <!-- Hero image: right half, absolute, fades left into white -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[52%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/hero/smiling-person-hero.jpg"
        alt=""
        width="832"
        height="1040"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="w-full h-full object-cover object-center"
      />
      <!-- Gradient fade from white into image -->
      <div
        class="absolute inset-y-0 left-0 w-48 pointer-events-none"
        style="background: linear-gradient(to right, #ffffff, transparent);"
      ></div>
    </div>

    <div class="container-wide relative pt-14 pb-20 md:pt-20 md:pb-28 lg:grid lg:grid-cols-12">

      <!-- LEFT: col-span-6 -->
      <div class="lg:col-span-6">
        <p class="eyebrow">Saskatoon · 8th Street East · Since 1989</p>
        <h1 class="mt-4 font-display font-semibold text-[var(--color-brand-primary)] text-[length:var(--text-6xl)] leading-[1.05] tracking-tight">
          Your <em class="not-italic relative inline-block">
            family's
            <svg class="absolute left-0 right-0 -bottom-1 w-full" viewBox="0 0 220 12" fill="none" preserveAspectRatio="none" aria-hidden="true">
              <path d="M2 8 C 60 2, 160 2, 218 8" stroke="#d59639" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </em> dentist
          <br class="hidden sm:block" />
          on 8th Street East.
        </h1>
        <p class="mt-6 max-w-xl text-lg text-[var(--color-text)] leading-relaxed">
          Wildwood Dental Clinic has cared for Saskatoon families for over 35 years.
          Six Saskatchewan-trained dentists providing comprehensive care — all in one comfortable clinic.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href="/book" class="btn btn-primary btn-lg">
            Book Appointment
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="tel:+13063747272" class="btn btn-outline btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            306.374.7272
          </a>
        </div>

        <a
          href="https://share.google/tBUCH3KsjPqnNPytZ"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-5 inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent-hover)]"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          See what patients are saying on Google
        </a>
      </div>

    </div>
  </section>

  <!-- ============================================================
       SECTION 2: CDCP Banner
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-5">
    <div class="container-wide flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div class="flex items-center gap-4 text-white">
        <!-- Shield checkmark -->
        <svg class="shrink-0 w-14 h-14" viewBox="0 0 56 56" fill="none" stroke="white" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M28 6 L10 13 L10 27 C10 38 18 47 28 50 C38 47 46 38 46 27 L46 13 Z" stroke-width="2.5" fill="none"/>
          <polyline points="20,28 25,33 36,22" stroke-width="3"/>
        </svg>
        <div>
          <p class="font-medium text-white">
            We accept the <span class="font-semibold">Canadian Dental Care Plan (CDCP)</span>
          </p>
        </div>
      </div>
      <a
        href="/new-patients/insurance-payment"
        class="shrink-0 btn bg-white text-[var(--color-brand-primary)] hover:bg-[var(--color-surface-alt)] font-semibold"
      >
        Learn More →
      </a>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3: Trusted Care / Generations
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <!-- Skyline behind top 2-col only -->
      <div class="relative overflow-hidden rounded-xl">
        <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1200 500" preserveAspectRatio="xMidYMax slice" fill="var(--color-brand-primary)" aria-hidden="true" style="opacity: 0.04;">
          <rect x="0" y="320" width="1200" height="180"/>
          <rect x="20" y="260" width="70" height="240"/>
          <rect x="45" y="225" width="16" height="35"/>
          <rect x="120" y="285" width="55" height="215"/>
          <rect x="210" y="200" width="90" height="300"/>
          <rect x="228" y="165" width="18" height="35"/>
          <rect x="340" y="240" width="65" height="260"/>
          <rect x="440" y="210" width="100" height="290"/>
          <rect x="458" y="175" width="16" height="35"/>
          <rect x="580" y="230" width="75" height="270"/>
          <rect x="596" y="190" width="14" height="40"/>
          <rect x="690" y="255" width="85" height="245"/>
          <rect x="706" y="218" width="18" height="37"/>
          <rect x="810" y="225" width="70" height="275"/>
          <rect x="826" y="188" width="12" height="37"/>
          <rect x="920" y="270" width="80" height="230"/>
          <rect x="1040" y="205" width="75" height="295"/>
          <rect x="1056" y="170" width="14" height="35"/>
          <rect x="1150" y="250" width="50" height="250"/>
        </svg>

        <div class="grid lg:grid-cols-2 gap-12 items-start relative p-1">

        <!-- LEFT column -->
        <div class="lg:pt-4">
          <!-- Eyebrow with map-pin icon -->
          <p class="inline-flex items-center gap-2 text-[var(--color-brand-accent)] text-xs font-semibold uppercase tracking-[0.12em]">
            <svg class="shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Serving Saskatoon for over 35 years
          </p>

          <h2 class="mt-4 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-[var(--color-brand-primary)]">
            Trusted Care In Saskatoon, For<br />
            <em class="italic relative inline-block">
              Generations.
              <svg class="absolute left-0 right-0 -bottom-1 w-full" viewBox="0 0 260 12" fill="none" preserveAspectRatio="none" aria-hidden="true">
                <path d="M2 8 C 65 2, 195 2, 258 8" stroke="#d59639" stroke-width="3" stroke-linecap="round"/>
              </svg>
            </em>
          </h2>

          <p class="mt-6 text-lg text-[var(--color-text)] leading-relaxed max-w-lg">
            Experience dentistry that puts comfort and care first. Our practice combines advanced
            technology with genuine compassion to deliver thorough, attentive care.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=105+-+1526+8th+Street+East,+Saskatoon,+SK+S7H+0T3"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Find Us on Maps
            </a>
            <a href="#our-office" class="btn btn-outline">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Hours of Operation
            </a>
          </div>
        </div>

        <!-- RIGHT column: single city image with badge -->
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3] lg:aspect-auto lg:h-full min-h-[280px]">
          <img
            src="/images/hero/saskatoon-city.png"
            alt="Aerial view of Saskatoon"
            width="800"
            height="600"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover"
          />
          <!-- Navy badge overlay -->
          <div class="absolute bottom-4 left-4 inline-flex items-center gap-2.5 bg-[var(--color-brand-primary)] text-white rounded-xl px-5 py-3.5 shadow-lg">
            <svg class="shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span class="text-base font-semibold leading-tight">Proudly located in the Wildwood community</span>
          </div>
        </div>

        </div><!-- /grid -->
      </div><!-- /skyline wrapper -->

      <!-- Bottom row: image mosaic (left) + 3 cards (right) -->
      <div class="mt-12 grid lg:grid-cols-2 gap-8 items-start">

        <!-- Image mosaic -->
        <div class="grid grid-cols-2 gap-3" style="grid-template-rows: auto auto;">
          <div>
            <img
              src="/images/hero/wildwood-hero.jpg"
              alt="Wildwood Dental Clinic interior"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full object-cover rounded-xl aspect-[4/3]"
            />
          </div>
          <div class="row-span-2">
            <img
              src="/images/hero/wildwood-seating.png"
              alt="Comfortable seating area at Wildwood Dental Clinic"
              width="600"
              height="900"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover rounded-xl"
            />
          </div>
          <div>
            <img
              src="/images/hero/wildwood-exterior.png"
              alt="Wildwood Dental Clinic exterior"
              width="600"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full object-cover rounded-xl aspect-[4/3]"
            />
          </div>
        </div>

        <!-- Three stacked cards -->
        <div class="flex flex-col gap-5">

          <div class="bg-white rounded-xl p-4 shadow-xl flex flex-row gap-4 items-start">
            <div class="w-14 h-14 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </div>
            <div class="flex flex-col flex-1">
              <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">About Our Clinic</h3>
              <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">
                Personalized dental care focused on your comfort and long-term health.
              </p>
              <a href="/about/our-clinic" class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)]">
                Learn More →
              </a>
            </div>
          </div>

          <div class="bg-white rounded-xl p-4 shadow-xl flex flex-row gap-4 items-start">
            <div class="w-14 h-14 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="flex flex-col flex-1">
              <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Meet Our Doctors</h3>
              <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">
                A team dedicated to delivering high-quality care with a patient-first approach.
              </p>
              <a href="/about/our-team" class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)]">
                Meet the Team →
              </a>
            </div>
          </div>

          <div class="bg-white rounded-xl p-4 shadow-xl flex flex-row gap-4 items-start">
            <div class="w-14 h-14 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 2C7 2 5 3.5 5 6C5 7.5 5.5 8.5 6 10C6.5 11.5 7 13 7 15C7 17 7.5 20 10 20C11 20 11.5 19 12 18.5C12.5 19 13 20 14 20C16.5 20 17 17 17 15C17 13 17.5 11.5 18 10C18.5 8.5 19 7.5 19 6C19 3.5 17 2 15 2C14 2 13 2.5 12 3C11 2.5 10 2 9 2Z"/></svg>
            </div>
            <div class="flex flex-col flex-1">
              <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Oral Health Resources</h3>
              <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">
                Learn more about your dental health, treatments, and how to maintain a healthy smile.
              </p>
              <a href="/blog" class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)]">
                Read Our Blog →
              </a>
            </div>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4: Services Carousel
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]" style="padding-bottom: 2.5rem;">
    <div class="container-wide">
      <div class="text-center">
        <p class="eyebrow">Comprehensive care for the whole family</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-[var(--color-brand-primary)]">
          Explore Our Dental Services
        </h2>
        <p class="mt-3 text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl mx-auto">
          From preventive visits to urgent dental care, Wildwood Dental Clinic offers care for every stage of your smile.
        </p>
      </div>
    </div>

    <!-- Carousel: full viewport width, 4 cards, arrows at edges -->
    <div class="mt-10 flex items-center gap-4 px-6">

        <button
          id="svc-prev"
          aria-label="Previous services"
          class="shrink-0 w-11 h-11 rounded-full border border-[var(--color-border)] bg-white flex items-center justify-center text-[var(--color-brand-primary)] hover:border-[var(--color-brand-primary)] hover:bg-[var(--color-brand-primary)] hover:text-white transition-all duration-150 shadow-sm disabled:opacity-40 disabled:cursor-not-allowed"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <!-- Clip viewport — cards slide behind this window -->
        <div id="svc-viewport" class="overflow-hidden flex-1 min-w-0 py-6 px-3">
          <div id="svc-track" class="svc-track">
            {serviceCategories.map((svc, i) => (
              <a
                href={svc.href}
                data-svc-card
                class="svc-card card group flex flex-col bg-white hover:border-[var(--color-brand-accent)]/30"
                aria-label={svc.title}
              >
                <div class="flex items-center gap-3">
                  <img
                    src={svc.icon}
                    alt=""
                    width="56"
                    height="56"
                    loading={i < 4 ? "eager" : "lazy"}
                    decoding="async"
                    class="w-14 h-14 rounded-lg shrink-0"
                  />
                  <h3 class="font-display text-lg font-semibold text-[var(--color-brand-primary)] leading-snug">
                    {svc.title}
                  </h3>
                </div>
                <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-snug line-clamp-2">
                  {svc.description}
                </p>
                <div class="mt-3 h-px w-full bg-[var(--color-brand-secondary)]"></div>
                <ul class="mt-3 space-y-1 flex-1">
                  {svc.items.slice(0, 3).map(item => (
                    <li class="flex items-start gap-2 text-sm text-[var(--color-text-muted)]">
                      <svg class="mt-0.5 shrink-0 text-[var(--color-brand-accent)]" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                      {item}
                    </li>
                  ))}
                </ul>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-brand-accent)] group-hover:text-[var(--color-brand-accent-hover)]">
                  Learn More
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>

        <button
          id="svc-next"
          aria-label="Next services"
          class="shrink-0 w-11 h-11 rounded-full border border-[var(--color-border)] bg-white flex items-center justify-center text-[var(--color-brand-primary)] hover:border-[var(--color-brand-primary)] hover:bg-[var(--color-brand-primary)] hover:text-white transition-all duration-150 shadow-sm disabled:opacity-40 disabled:cursor-not-allowed"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

      </div>

    <!-- Dots -->
    <div id="svc-dots" class="flex justify-center gap-2 mt-5" role="tablist" aria-label="Service card navigation"></div>
  </section>

  <!-- ============================================================
       SECTION 5: Invisalign Band
       ============================================================ -->
  <section class="bg-[var(--color-surface-cool)] section-y">
    <div class="container-wide grid lg:grid-cols-2 gap-12 items-center">

