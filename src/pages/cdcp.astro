---
import BaseLayout from '../layouts/BaseLayout.astro';

const qualifyCards = [
  { title: "No Dental Insurance", body: "You do not have access to private dental insurance." },
  { title: "Family Income Under $90,000", body: "Your adjusted family net income is under $90,000 per year." },
  { title: "Canadian Resident", body: "You are a Canadian resident for tax purposes." },
  { title: "Filed Taxes", body: "You filed your tax return in the previous year." },
];

const coverageItems = [
  "Dental exams and X-rays",
  "Root canals",
  "Cleanings and preventive care",
  "Periodontal treatment",
  "Fillings and restorative care",
  "Some oral surgery services",
];

const importantNotes = [
  "The CDCP may not cover the full cost of treatment",
  "Some procedures require pre-approval",
  "Patients must renew their CDCP coverage each year after filing their annual income tax return",
  "Additional charges may apply depending on the treatment and coverage limits",
];

const careFeats = [
  { label: "Modern Dental\nTechnology",     icon: `<path d="M12 5.5c-1.5-1.3-3.2-2-5-2C4 3.5 2 5.7 2 9c0 2.4.9 4.6 1.7 7 .6 1.8 1 4 2.3 4 1.2 0 1.3-2 1.8-3.6.4-1.3.8-2.4 2.2-2.4s1.8 1.1 2.2 2.4c.5 1.6.6 3.6 1.8 3.6 1.3 0 1.7-2.2 2.3-4 .8-2.4 1.7-4.6 1.7-7 0-3.3-2-5.5-5-5.5-1.8 0-3.5.7-5 2Z"/>` },
  { label: "Comprehensive\nDental Care",    icon: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>` },
  { label: "Experienced\nDental Team",      icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>` },
  { label: "Convenient\nScheduling",        icon: `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/>` },
  { label: "Comfortable\nEnvironment",      icon: `<path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>` },
];

const knowItems = [
  { icon: `<circle cx="12" cy="12" r="10"/><path d="M12 6v12"/><path d="M15 9.5a2.5 2.5 0 0 0-2.5-1.5h-1a2 2 0 0 0 0 4h1a2 2 0 0 1 0 4h-1A2.5 2.5 0 0 1 9 14.5"/>`, text: "The CDCP may not cover the full cost of treatment." },
  { icon: `<path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="m9 14 2 2 4-4"/>`, text: "Some procedures require pre-approval." },
  { icon: `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/>`, text: "Patients must renew their CDCP coverage each year after filing their annual income tax return." },
  { icon: `<path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>`, text: "Additional charges may apply depending on the treatment and coverage limits." },
];

const faqs = [
  { q: "Does the CDCP cover all dental treatment?", a: "No. The CDCP may cover only a portion of eligible dental treatment costs. Coverage amounts depend on household income and the specific service being provided." },
  { q: "Will I have any out-of-pocket costs?", a: "Possibly. Some treatments may not be fully covered, and additional charges may apply depending on your treatment needs and CDCP coverage limits." },
  { q: "Do I need to renew my coverage?", a: "Yes. Patients must renew their CDCP coverage each year after filing their annual income tax return." },
  { q: "Can Wildwood Dental Clinic help me understand my coverage?", a: "Yes. Our team can help explain your CDCP benefits and discuss any costs before treatment is provided." },
  { q: "Can I use my CDCP benefits at Wildwood Dental Clinic?", a: "Wildwood Dental Clinic welcomes patients who qualify for the Canadian Dental Care Plan." },
  { q: "Do some services require pre-authorization?", a: "Yes. Certain treatments may require pre-authorization before coverage is approved under the CDCP." },
  { q: "How do I apply for the CDCP?", a: "Applications are completed directly through the Government of Canada using your My Service Canada Account (MSCA)." },
  { q: "What if I am unsure whether I qualify?", a: "Eligibility requirements are determined by the Government of Canada. Please review the official eligibility requirements for the most current information." },
];

---

<BaseLayout
  title="Canadian Dental Care Plan (CDCP) | Wildwood Dental Clinic Saskatoon"
  description="Wildwood Dental Clinic supports patients who qualify for the Canadian Dental Care Plan (CDCP). Learn what the CDCP covers, who qualifies, and how to apply."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[46%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/clinic-patient.jpg"
        alt=""
        width="900"
        height="700"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-28 lg:max-w-[60%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Canadian Dental Care Plan</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Government Program</p>
      <h1 class="mt-3 font-display font-semibold leading-tight text-white" style="font-size: var(--text-6xl);">
        Canadian<br />Dental Care Plan<br />(CDCP)
      </h1>
      <div class="mt-6 w-16 h-0.5 bg-[var(--color-brand-accent)]"></div>
      <p class="mt-6 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-lg">
        Wildwood Dental Clinic is pleased to support patients who qualify for the CDCP.
      </p>
    </div>
  </section>

  <!-- ============================================================
       WHAT IS THE CDCP
       ============================================================ -->
  <section class="pt-16 pb-0">
    <div class="container-wide">
      <div class="relative overflow-hidden rounded-2xl" style="background: linear-gradient(180deg,#eef3f8,#f6f8fb); min-height: 300px;">
        <!-- Left: Canadian flag -->
        <div class="absolute inset-y-0 left-0 w-[24%] hidden md:block" style="-webkit-mask-image: linear-gradient(to right, black 60%, transparent 100%); mask-image: linear-gradient(to right, black 60%, transparent 100%);">
          <img src="/images/Canadian Flag.png" alt="Canadian flag" class="w-full h-full object-cover" />
        </div>
        <!-- Right: Parliament building -->
        <div class="absolute inset-y-0 right-0 w-[32%] hidden md:block">
          <img src="/images/Clock Tower.png" alt="Parliament Hill Peace Tower, Ottawa" class="w-full h-full object-cover" />
        </div>
        <div class="relative z-10 max-w-xl mx-auto text-center px-8 py-14">
          <div class="flex items-center justify-center gap-4 mb-4">
            <span class="block h-px w-16 bg-[var(--color-brand-accent)]"></span>
            <div class="w-16 h-16 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center text-white shrink-0" style="box-shadow: 0 8px 20px rgba(10,44,82,.25);">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 21h18"/><path d="M5 21V10l7-5 7 5v11"/><path d="M9 21v-6h6v6"/><path d="M12 5V2"/>
              </svg>
            </div>
            <span class="block h-px w-16 bg-[var(--color-brand-accent)]"></span>
          </div>
          <h2 class="font-display font-semibold text-[var(--color-brand-primary)]" style="font-size: var(--text-4xl);">What is the CDCP?</h2>
          <p class="mt-5 text-[var(--color-text-muted)] leading-[1.75]" style="font-size: 16.5px;">
            The Canadian Dental Care Plan (CDCP) is a federal government program designed to make dental care more affordable for eligible Canadian residents who do not have dental insurance. The program helps cover a portion of the cost of many dental services.
          </p>
          <div class="mt-6 h-px max-w-[300px] mx-auto" style="background: rgba(20,54,95,.14);"></div>
          <a
            class="mt-5 inline-flex items-center gap-2 font-semibold text-[var(--color-brand-primary)] text-base hover:text-[var(--color-brand-accent-hover)] transition-colors"
            href="https://www.canada.ca/en/services/benefits/dental/dental-care-plan.html"
            target="_blank"
            rel="noopener noreferrer"
          >
            Learn more on the Government of Canada website
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       DO YOU QUALIFY
       ============================================================ -->
  <section class="section-y">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="font-display font-semibold text-[var(--color-brand-primary)]" style="font-size: var(--text-4xl);">Do You Qualify for the CDCP?</h2>
        <div class="mt-4 mx-auto w-16 h-0.5 bg-[var(--color-brand-accent)]"></div>
        <p class="mt-6 text-[var(--color-text-muted)] text-lg leading-relaxed">You may qualify if you meet all of the following criteria:</p>
      </div>
      <div class="mt-14 grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {qualifyCards.map(card => (
          <div class="bg-white border border-[var(--color-border-soft)] rounded-xl p-9 text-center flex flex-col justify-center" style="box-shadow: 0 8px 26px rgba(20,54,95,.05);">
            <h3 class="font-display font-semibold text-[var(--color-brand-primary)] leading-snug" style="font-size: var(--text-xl);">{card.title}</h3>
            <p class="mt-4 text-sm text-[var(--color-text-muted)] leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 flex items-center justify-center gap-3">
        <div class="w-9 h-9 rounded-full border-2 border-[var(--color-brand-accent)] text-[var(--color-brand-accent-hover)] flex items-center justify-center font-display font-bold text-lg shrink-0" aria-hidden="true">?</div>
        <a
          href="https://www.canada.ca/en/services/benefits/dental/dental-care-plan/qualify.html"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-semibold text-[var(--color-brand-primary)] text-lg hover:text-[var(--color-brand-accent-hover)] transition-colors"
        >
          Check Eligibility Details
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <p class="mt-4 text-center text-sm text-[var(--color-text-muted)]">
        Learn more about <span class="text-[var(--color-brand-accent-hover)] font-semibold">eligibility requirements</span> directly from the Government of Canada.
      </p>
    </div>
  </section>

  <!-- ============================================================
       COVERAGE & NOTES PANELS
       ============================================================ -->
  <section class="pb-8">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-7">

        <!-- What's covered -->
        <div class="bg-[var(--color-surface-cool)] rounded-2xl p-10">
          <h3 class="font-display font-semibold text-[var(--color-brand-primary)]" style="font-size: var(--text-2xl);">What Services May Be Covered?</h3>
          <div class="mt-3.5 w-12 h-0.5 bg-[var(--color-brand-accent)]"></div>
          <p class="mt-5 text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">The CDCP may help cover a portion of the cost for many dental services such as:</p>
          <div class="grid grid-cols-2 gap-x-6 gap-y-3 mb-5">
            {coverageItems.map(item => (
              <div class="flex items-start gap-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
                <span class="w-2 h-2 rounded-full bg-[var(--color-brand-accent)] mt-1.5 shrink-0" aria-hidden="true"></span>
                {item}
              </div>
            ))}
          </div>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Some services may require pre-authorization before they are covered. Depending on your household income, the program may cover between 40% and 100% of eligible treatment costs.</p>
        </div>

        <!-- Important notes -->
        <div class="bg-[var(--color-surface-cool)] rounded-2xl p-10">
          <h3 class="font-display font-semibold text-[var(--color-brand-primary)]" style="font-size: var(--text-2xl);">Important Notes About CDCP</h3>
          <div class="mt-3.5 w-12 h-0.5 bg-[var(--color-brand-accent)]"></div>
          <div class="mt-5 space-y-3.5 mb-5">
            {importantNotes.map(item => (
              <div class="flex items-start gap-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
                <span class="w-2 h-2 rounded-full bg-[var(--color-brand-accent)] mt-1.5 shrink-0" aria-hidden="true"></span>
                {item}
              </div>
            ))}
          </div>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Our team will help explain your benefits and discuss any costs before your appointment.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       HOW TO APPLY
       ============================================================ -->
  <section class="section-y">
    <div class="container-wide">
      <div class="bg-[var(--color-surface-cool)] rounded-2xl px-10 py-14 text-center">
        <h2 class="font-display font-semibold text-[var(--color-brand-primary)]" style="font-size: var(--text-4xl);">How to Apply for the CDCP</h2>
        <div class="mt-4 mx-auto w-16 h-0.5 bg-[var(--color-brand-accent)]"></div>
        <p class="mt-6 text-[var(--color-text-muted)] text-lg leading-relaxed max-w-xl mx-auto">
          Patients apply directly through the Government of Canada.<br />
          You can apply online through your My Service Canada Account (MSCA).
        </p>
        <a
          href="https://www.canada.ca/en/services/benefits/dental/dental-care-plan/apply.html"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 btn btn-primary btn-lg"
        >
          Apply Through the Government of Canada
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
        </a>
        <div class="mt-10 flex flex-col sm:flex-row items-stretch justify-center">
          <a
            href="https://www.canada.ca/en/services/benefits/dental/dental-care-plan.html"
            target="_blank"
            rel="noopener noreferrer"
            class="apply-link flex items-center gap-4 px-10 py-4 text-left hover:bg-white/60 rounded-xl sm:rounded-r-none transition-colors no-underline"
          >
            <span class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-[var(--color-brand-primary)] shrink-0" style="box-shadow: inset 0 0 0 1px rgba(20,54,95,.08);">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z"/></svg>
            </span>
            <span class="text-left">
              <strong class="block font-display font-semibold text-[var(--color-brand-primary)]">CDCP Overview</strong>
              <span class="text-sm text-[var(--color-text-muted)]">Learn more about the plan.</span>
            </span>
            <span class="text-[var(--color-brand-accent-hover)] text-xl ml-1.5 apply-arr" aria-hidden="true">→</span>
          </a>
          <div class="hidden sm:block w-px self-stretch" style="background: rgba(20,54,95,.14);"></div>
          <a
            href="https://www.canada.ca/en/services/benefits/dental/dental-care-plan/qualify.html"
            target="_blank"
            rel="noopener noreferrer"
            class="apply-link flex items-center gap-4 px-10 py-4 text-left hover:bg-white/60 rounded-xl sm:rounded-l-none transition-colors no-underline"
          >
            <span class="w-12 h-12 rounded-full bg-white flex items-center justify-center text-[var(--color-brand-primary)] shrink-0" style="box-shadow: inset 0 0 0 1px rgba(20,54,95,.08);">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </span>
            <span class="text-left">
              <strong class="block font-display font-semibold text-[var(--color-brand-primary)]">Eligibility Details</strong>
              <span class="text-sm text-[var(--color-text-muted)]">See if you qualify.</span>
            </span>
            <span class="text-[var(--color-brand-accent-hover)] text-xl ml-1.5 apply-arr" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CDCP CARE AT WILDWOOD
       ============================================================ -->
  <section class="pb-20">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_1.06fr] gap-14 items-center">
        <div class="rounded-2xl overflow-hidden" style="box-shadow: 0 18px 44px rgba(20,54,95,.12);">
          <img
            src="/images/services/content-consultation.jpg"
            alt="Dentist consulting with a patient at Wildwood Dental Clinic"
            width="700"
            height="500"
            loading="lazy"
            decoding="async"
            class="w-full object-cover"
            style="height: 440px;"
          />
        </div>
        <div>
          <h2 class="font-display font-semibold text-[var(--color-brand-primary)] leading-tight" style="font-size: var(--text-4xl);">CDCP Care at<br />Wildwood Dental Clinic</h2>
          <div class="mt-4 w-16 h-0.5 bg-[var(--color-brand-accent)]"></div>
          <p class="mt-6 text-[var(--color-text-muted)] leading-relaxed max-w-lg">Wildwood Dental Clinic is pleased to support patients who qualify for the CDCP.</p>
          <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed max-w-lg">Our team will help explain your benefits and discuss any costs before your appointment.</p>
          <div class="mt-8 grid grid-cols-2 gap-x-7 gap-y-5">
            {careFeats.map(feat => (
              <div class="flex items-start gap-3.5">
                <span class="text-[var(--color-brand-accent-hover)] shrink-0 mt-0.5">
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={feat.icon}></svg>
                </span>
                <strong class="font-display font-semibold text-[var(--color-brand-primary)] leading-snug whitespace-pre-line" style="font-size: 16.5px;">{feat.label}</strong>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       IMPORTANT THINGS TO KNOW (navy band)
       ============================================================ -->
  <section class="pb-20">
    <div class="container-wide">
      <div class="rounded-2xl text-white" style="background: linear-gradient(160deg, var(--color-brand-primary), var(--color-brand-primary-deep)); padding: 50px 52px 54px;">
        <h2 class="font-display font-semibold text-white" style="font-size: var(--text-3xl);">Important Things to Know</h2>
        <div class="mt-3.5 w-12 h-0.5 bg-[var(--color-brand-accent)]"></div>
        <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-0">
          {knowItems.map((item, i) => (
            <div class={`relative ${i > 0 ? 'lg:border-l lg:border-white/16 lg:px-7' : 'lg:pr-7'} ${i > 1 ? 'mt-8 lg:mt-0' : ''} ${i === 1 ? 'mt-8 lg:mt-0' : ''}`}>
              <div class="w-12 h-12 rounded-full border-2 border-[var(--color-brand-accent)] text-[var(--color-brand-accent-soft)] flex items-center justify-center mb-5">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon}></svg>
              </div>
              <p class="text-[var(--color-text-on-dark-muted)] text-sm leading-relaxed">{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section class="pb-20">
    <div class="container-wide">
      <h2 class="font-display font-semibold text-[var(--color-brand-primary)]" style="font-size: var(--text-4xl);">Frequently Asked Questions</h2>
      <div class="mt-3.5 w-12 h-0.5 bg-[var(--color-brand-accent)]"></div>
      <div class="mt-10 space-y-3.5">
        {faqs.map(faq => (
          <details class="faq-item border border-[var(--color-border-soft)] rounded-xl bg-white overflow-hidden">
            <summary class="list-none cursor-pointer flex items-center justify-between gap-5 px-6 py-5 font-semibold text-[var(--color-brand-primary)]" style="font-size: 16.5px;">
              {faq.q}
              <svg class="faq-chev w-5 h-5 text-[var(--color-brand-accent-hover)] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </summary>
            <p class="px-6 pb-5 text-[var(--color-text-muted)] text-sm leading-relaxed max-w-4xl">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       HAVE QUESTIONS CTA
       ============================================================ -->
  <section class="pb-20">
    <div class="container-wide">
