---
import BaseLayout from '../../layouts/BaseLayout.astro';

const aboutNav = [
  { name: "Our Clinic", href: "/about/our-clinic", current: true },
  { name: "Our Team", href: "/about/our-team" },
  { name: "Careers", href: "/about/careers" },
];

const differentiators = [
  {
    title: "Family-Oriented Care",
    body: "We welcome patients of all ages, from young children to seniors, and work to create a comfortable and supportive environment.",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
  {
    title: "Comfortable Experience",
    body: "Comfortable seating, personal televisions, and sedation options including nitrous oxide and oral sedation help ease dental anxiety.",
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
  {
    title: "Direct Insurance Billing",
    body: "We bill most major insurance plans directly so you spend less time on paperwork and more time focused on your health.",
    icon: `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`,
  },
  {
    title: "Flexible Hours",
    body: "Later Tuesday and Thursday hours, and Saturday appointments by request, give working patients and families more flexibility.",
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    title: "Minimal Wait Times",
    body: "We respect your time. Our scheduling is designed to minimize wait times and get you in and out efficiently.",
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    title: "Accessible by Transit",
    body: "Our 5th Street South location is served by Lethbridge Transit routes nearby, making it easy to reach us without a car.",
    icon: `<circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"/>`,
  },
];

const aboutSections = [
  {
    title: "Our Team",
    href: "/about/our-team",
    body: "Meet our three dentists, all trained at the University of Alberta and licensed by the Alberta Dental Association and College, and learn about the clinical team that supports your care.",
    cta: "Meet Our Team",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    highlights: [
      "Six general dentists",
      "University of Alberta trained",
      "Dental hygienists, assistants & admin",
      "Patient-centred care approach",
    ],
  },
  {
    title: "Careers",
    href: "/about/careers",
    body: "We're always interested in hearing from qualified dental professionals. Learn about the types of roles at our clinic and how to reach us about current or future opportunities.",
    cta: "View Careers",
    icon: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
    highlights: [
      "Dentists & dental hygienists",
      "Dental assistants",
      "Administrative & reception",
      "Established Lethbridge practice",
    ],
  },
];
---

<BaseLayout
  title="About Able Family Dental | Lethbridge Family Dentistry"
  description="Learn about Able Family Dental in Lethbridge, including our history, patient care approach, facility, technology, and family dentistry team."
>

  <!-- ============================================================
       HERO BANNER
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/sourced/clinic-interior-dental-office.png"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">About</span>
      </nav>
      <p class="eyebrow text-white">An established Lethbridge family dental practice</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        About Able Family Dental
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        A family-oriented general dental practice on 5th Street South in Lethbridge, focused on preventive care, clear communication, and a welcoming environment for patients of every age.
      </p>
    </div>
  </section>

  <!-- ============================================================
       OUR STORY
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-accent)]">Our Story</p>
        <div class="mt-1 w-10 h-0.5 bg-[var(--color-brand-accent)]"></div>
        <h2 class="mt-4 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          A Lethbridge dental home for your whole family
        </h2>
        <div class="mt-5 space-y-4 text-[var(--color-text)] leading-relaxed">
          <p>
            Able Family Dental has been serving Lethbridge families from our 5th Street South location since we first opened our doors. Over the years, we've built lasting relationships with patients across the city, many of whom have been coming to us for a long time, and many who have brought their children along the way.
          </p>
          <p>
            Our team of six general dentists provides a comprehensive range of dental services under one roof: from routine checkups and cleanings to dental implants, Invisalign, sedation dentistry, and more. Whether you're a new patient or a familiar face, you'll find a professional, friendly environment designed around your comfort and your health.
          </p>
          <p>
            We're a proud part of the Lethbridge community, and we take that seriously, from the training our dentists received at the University of Alberta to the professional standards we uphold through the Alberta Dental Association and College.
          </p>
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/book/" class="btn btn-primary">Book Appointment</a>
          <a href="/refer/" class="btn btn-outline">Refer Patient</a>
          <a href="/contact/" class="btn btn-outline">Get in Touch</a>
        </div>
      </div>

      <div>
        <img
          src="/images/about/able-family-dental-exterior.png"
          alt="Able Family Dental exterior on 5th Street South, Lethbridge"
          width="1449"
          height="1086"
          loading="lazy"
          decoding="async"
          class="w-full rounded-2xl shadow-xl object-cover"
        />
      </div>

    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- Main content -->
        <div class="space-y-10">

          <!-- Our approach -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Our approach to care
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                We believe good dental care begins with clear communication. When we find something at your exam, we take the time to explain what it is, what it means, and what the options are, including what happens if you decide to wait. Our goal is to give you the information you need to make decisions that work for your life.
              </p>
              <p>
                Prevention is central to how we practice. Regular checkups and cleanings are the foundation of long-term oral health, and we focus on helping patients understand the habits and routines that support healthy teeth and gums between visits.
              </p>
              <p>
                We also understand that dental visits can feel stressful for some patients. We work to make every appointment as comfortable as possible, and we offer sedation options, including nitrous oxide and oral sedation, for patients who would benefit from additional support.
              </p>
            </div>
          </div>

          <!-- Clinic photos carousel -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
              Our space
            </h2>
            <div class="flex items-center gap-3" aria-roledescription="carousel" aria-label="Clinic photos">
              <button id="space-prev" aria-label="Previous" class="shrink-0 w-9 h-9 rounded-full border border-[var(--color-border-soft)] bg-white shadow-sm flex items-center justify-center text-[var(--color-brand-primary)] hover:bg-[var(--color-surface-cool)] transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <!-- 4-slot sliding track: s0(off-left) | s1(visible) | s2(visible) | s3(off-right) -->
              <div class="overflow-hidden flex-1" id="space-viewport" style="opacity:0">
                <div class="flex gap-4" id="space-track">
                  <img id="space-s0" src="/images/about/able-family-dental-exterior.png"       alt="" aria-hidden="true" width="800" height="600" loading="lazy" decoding="async" class="shrink-0 w-[calc(50%-8px)] rounded-xl shadow-xl object-cover aspect-[4/3]" />
                  <img id="space-s1" src="/images/about/able-family-dental-front-desk.png"     alt="Able Family Dental front desk"           width="800" height="600" loading="lazy" decoding="async" class="shrink-0 w-[calc(50%-8px)] rounded-xl shadow-xl object-cover aspect-[4/3]" />
                  <img id="space-s2" src="/images/about/able-family-dental-sterilization.png"  alt="Able Family Dental sterilization area"   width="800" height="600" loading="lazy" decoding="async" class="shrink-0 w-[calc(50%-8px)] rounded-xl shadow-xl object-cover aspect-[4/3]" />
                  <img id="space-s3" src="/images/about/able-family-dental-treatment-room.png" alt="" aria-hidden="true" width="800" height="600" loading="lazy" decoding="async" class="shrink-0 w-[calc(50%-8px)] rounded-xl shadow-xl object-cover aspect-[4/3]" />
                </div>
              </div>
              <button id="space-next" aria-label="Next" class="shrink-0 w-9 h-9 rounded-full border border-[var(--color-border-soft)] bg-white shadow-sm flex items-center justify-center text-[var(--color-brand-primary)] hover:bg-[var(--color-surface-cool)] transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>

          <script is:inline>
            (function () {
              var slides = [
                { src: '/images/about/able-family-dental-front-desk.png',     alt: 'Able Family Dental front desk' },
                { src: '/images/about/able-family-dental-sterilization.png',  alt: 'Able Family Dental sterilization area' },
                { src: '/images/about/able-family-dental-treatment-room.png', alt: 'Able Family Dental treatment room' },
                { src: '/images/about/able-family-dental-exterior.png',       alt: 'Able Family Dental exterior' },
              ];
              var N = slides.length;
              var current = 0;
              var busy = false;
              var track    = document.getElementById('space-track');
              var viewport = document.getElementById('space-viewport');
              var s = [
                document.getElementById('space-s0'),
                document.getElementById('space-s1'),
                document.getElementById('space-s2'),
                document.getElementById('space-s3'),
              ];

              function idx(n) { return ((n % N) + N) % N; }

              function assign(el, n, ghost) {
                var d = slides[idx(n)];
                el.src = d.src;
                el.alt = ghost ? '' : d.alt;
                ghost ? el.setAttribute('aria-hidden', 'true') : el.removeAttribute('aria-hidden');
              }

              function getStep() {
                var gap = parseFloat(window.getComputedStyle(track).columnGap) || 16;
                return s[1].offsetWidth + gap;
              }

              function snap() {
                track.style.transition = 'none';
                track.offsetHeight;
                track.style.transform = 'translateX(-' + getStep() + 'px)';
              }

              function go(dir) {
                if (busy) return;
                busy = true;
                assign(dir === 1 ? s[3] : s[0], current + (dir === 1 ? 2 : -1), true);
                var step = getStep();
                track.style.transition = 'transform 0.4s ease-in-out';
                track.style.transform = dir === 1
                  ? 'translateX(-' + (2 * step) + 'px)'
                  : 'translateX(0px)';
                track.addEventListener('transitionend', function h(e) {
                  if (e.propertyName !== 'transform') return;
                  track.removeEventListener('transitionend', h);
                  current = idx(current + dir);
                  assign(s[1], current,     false);
                  assign(s[2], current + 1, false);
                  assign(s[0], current - 1, true);
                  assign(s[3], current + 2, true);
                  snap();
                  busy = false;
                });
              }

              requestAnimationFrame(function () {
                snap();
                viewport.style.opacity = '1';
              });

              document.getElementById('space-prev').addEventListener('click', function () { go(-1); });
              document.getElementById('space-next').addEventListener('click', function () { go(1); });
            })();
          </script>

          <!-- Differentiators grid -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
              What patients can expect
            </h2>
            <div class="grid sm:grid-cols-2 gap-5">
              {differentiators.map(item => (
                <div class="bg-white rounded-xl p-5 border border-[var(--color-border-soft)] flex gap-4 items-start">
                  <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
                  </div>
                  <div>
                    <h3 class="font-display font-semibold text-sm text-[var(--color-brand-primary)]">{item.title}</h3>
                    <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">{item.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Our Technology -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Our Technology
            </h2>
            <p class="text-[var(--color-text)] leading-relaxed mb-6">
              Able Family Dental uses modern dental technology to support accurate diagnosis and patient-centred care. Our equipment includes in-house digital X-rays and 3D Cone Beam CT for clear, detailed imaging of your teeth and jaw.
            </p>
            <div class="max-w-lg">
              <div class="rounded-2xl overflow-hidden">
                <img
                  src="/images/bugherd/Xray.png"
                  alt="3D Cone Beam CT imaging of teeth and jaw"
                  width="800"
                  height="600"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-72 object-cover"
                />
                <div class="bg-white px-4 py-3 border border-t-0 border-[var(--color-border-soft)] rounded-b-2xl">
                  <p class="text-sm font-semibold text-[var(--color-brand-primary)]">3D Cone Beam CT (CBCT)</p>
                  <p class="text-xs text-[var(--color-text-muted)] mt-0.5">High-resolution 3D images of your teeth and jaw</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Location & access -->
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-4">
              Location &amp; accessibility
            </h2>
            <div class="space-y-3 text-[var(--color-text)] leading-relaxed">
              <p>
                We're located at <strong>511 5th Street South, Lethbridge, AB</strong>.
              </p>
              <ul class="space-y-2 mt-3">
                {[
                  "Accessible rear entrance — step-free, wheelchair-accessible entry at the rear of the clinic",
                  "Accessible washroom on site",
                  "Lethbridge Transit routes nearby",
                ].map(item => (
                  <li class="flex items-center gap-2.5 text-sm text-[var(--color-text-muted)]">
                    <svg class="shrink-0 text-[var(--color-brand-accent)]" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <div class="mt-4">
                <a
                  href="https://maps.app.goo.gl/pAJAeiNddySjEkKc8"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors"
                >
                  Get Directions
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">

          <!-- Booking card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or request an appointment online, new patients welcome.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="/refer/" class="mt-2 btn btn-outline w-full block text-center">Refer Patient</a>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <!-- About nav -->
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">About Able Family Dental</h3>
            <ul class="space-y-2">
              {aboutNav.map(item => (
                <li>
                  {item.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {item.name}
                    </span>
                  ) : (
                    <a href={item.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {item.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

          <!-- Contact card -->
          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)] mb-3">Get in Touch</h3>
            <div class="space-y-2 text-sm text-[var(--color-text-muted)]">
              <p><strong class="text-[var(--color-text)]">Able Family Dental</strong></p>
              <p>511 5th Street South<br/>Lethbridge, AB</p>
              <p>
                <a href="tel:+14033277202" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent)] transition-colors">403.327.7202</a>
              </p>
            </div>
            <a href="/contact/" class="mt-4 inline-block text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">Contact Us →</a>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROFESSIONAL STANDARDS & CREDENTIALS
       ============================================================ -->
  <section class="pt-[var(--spacing-section)] pb-0 bg-[var(--color-surface)] relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 30% 30%, rgba(74,118,210,0.08) 0%, transparent 58%);" aria-hidden="true"></div>

    <div class="container-wide relative grid lg:grid-cols-[40fr_60fr] gap-10 lg:gap-14 items-start pb-2">

      <!-- LEFT: Copy -->
      <div>
        <p class="eyebrow">Patient Care Standards</p>
        <div class="mt-3 w-12 h-[3px] bg-[var(--color-brand-accent)] rounded-sm"></div>
        <h2 class="mt-5 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Committed to Safe, Professional Dental Care
        </h2>
        <div class="mt-5 space-y-4 text-[var(--color-text-muted)] leading-[1.7]">
          <p>At Able Family Dental, we are committed to providing patient-centred dental care in a professional, respectful, and compliant environment.</p>
          <p>Our team follows the guidelines set by the Alberta Dental Association and College and references trusted national dental resources to support patient education.</p>
          <p>We uphold cleanliness, sterilization, and infection prevention standards aligned with provincial and national dental regulatory requirements.</p>
        </div>
      </div>

      <!-- RIGHT: Credential cards + skyline -->
      <div class="flex flex-col gap-0">

        <div class="grid grid-cols-3 max-[559px]:grid-cols-1 gap-4">

          <!-- CDSA -->
          <div class="rounded-[var(--radius-lg)] bg-white flex flex-col items-center shadow-md">
            <div class="w-full aspect-square bg-white rounded-[var(--radius-lg)] overflow-hidden flex items-center justify-center p-4">
              <img
                src="/images/logos/cdsa-college-dental-surgeons-alberta.png"
                alt="College of Dental Surgeons of Alberta"
                width="300"
                height="120"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-contain"
              />
            </div>
          </div>

          <!-- CDA -->
          <div class="rounded-[var(--radius-lg)] bg-white flex flex-col items-center shadow-md">
            <div class="w-full aspect-square bg-white rounded-[var(--radius-lg)] overflow-hidden flex items-center justify-center p-4">
              <img
                src="/images/brand/cda-logo.png"
                alt="Canadian Dental Association"
                width="301"
                height="168"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-contain"
              />
            </div>
          </div>

          <!-- Commitment to Clean -->
          <div class="rounded-[var(--radius-lg)] bg-white flex flex-col items-center shadow-md">
            <div class="w-full aspect-square bg-white rounded-[var(--radius-lg)] overflow-hidden flex items-center justify-center p-4">
              <img
                src="/images/logos/Commitment-to-Clean-shield.png"
                alt="Commitment to Clean"
                width="400"
                height="400"
                loading="lazy"
                decoding="async"
                class="w-[75%] h-[75%] object-contain"
              />
            </div>
          </div>

        </div>

        <!-- Skyline graphic -->
        <div class="w-full" style="aspect-ratio: 16/5;">
          <img
            src="/images/brand/lethbridge-landmarks-line-art.svg"
            alt=""
            aria-hidden="true"
            width="1957"
            height="804"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-contain object-bottom mix-blend-multiply"
            style="filter: sepia(1) brightness(2.2) saturate(0.35); opacity: 0.18;"
          />
        </div>

      </div>

    </div>
  </section>

  <!-- ============================================================
       VISIT INFORMATION
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="mb-8">
        <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)]">Visit Information</h2>
        <p class="mt-2 text-[var(--color-text-muted)]">Everything you need to know before your visit.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            label: "Accepting New Patients",
            note: "We welcome new patients and families.",
            icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>`,
          },
          {
            label: "Direct Billing Available",
            note: "We bill most major insurance carriers directly.",
            icon: `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`,
          },
          {
            label: "Accessible Rear Entrance",
            note: "Step-free, wheelchair-accessible entry is available at the rear of the clinic.",
            icon: `<circle cx="12" cy="5" r="1"/><path d="M9 20l1-5h4l1 5"/><path d="M8 15l1-5h6l1 5"/><path d="M6 20a5 5 0 0 1 5-5"/>`,
          },
          {
            label: "Accessible Washroom",
            note: "Our washroom is wheelchair accessible.",
            icon: `<path d="M12 22V12"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><circle cx="12" cy="5" r="3"/>`,
          },
        ].map(item => (
          <div class="bg-white rounded-2xl p-5 border border-[var(--color-border-soft)] flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-sm text-[var(--color-brand-primary)]">{item.label}</p>
              <p class="mt-0.5 text-xs text-[var(--color-text-muted)] leading-relaxed">{item.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       EXPLORE MORE
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow">Learn more</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          More About Able Family Dental
        </h2>
        <p class="mt-3 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Meet the team behind your care or find out about joining us.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
        {aboutSections.map(section => (
          <div class="bg-white rounded-2xl shadow-xl border border-[var(--color-border-soft)] flex flex-col overflow-hidden">
            <div class="bg-[var(--color-brand-primary)] px-6 pt-6 pb-5 flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={section.icon} />
              </div>
              <h3 class="font-display font-semibold text-xl text-white">{section.title}</h3>
            </div>
            <div class="p-6 flex flex-col flex-1">
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{section.body}</p>
              <ul class="mt-4 space-y-1.5">
                {section.highlights.map(item => (
                  <li class="flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
                    <svg class="shrink-0 text-[var(--color-brand-accent)]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a href={section.href} class="mt-6 btn btn-outline w-full text-center text-sm">{section.cta} →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to make Able Family Dental your dental home?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
