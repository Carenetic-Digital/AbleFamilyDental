---
// Pre-footer: Our Office section with hours, address, and contact info
---

<section id="our-office" class="section-y bg-[var(--color-surface-cool)]">
  <div class="container-wide">

    <!-- Centered title row -->
    <div class="flex items-center justify-center gap-4 mb-12">
      <div class="flex-1 h-px bg-[var(--color-brand-accent)]/50"></div>
      <div class="flex items-center gap-3 shrink-0">
        <svg class="text-[var(--color-brand-accent)] w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-[var(--color-brand-primary)]">Our Office</h2>
      </div>
      <div class="flex-1 h-px bg-[var(--color-brand-accent)]/50"></div>
    </div>

    <div class="grid lg:grid-cols-2 gap-8">

      <!-- Office Hours card -->
      <div class="bg-white border border-[var(--color-border-soft)] rounded-2xl p-8 shadow-xl">
        <div class="flex items-center gap-3 mb-6">
          <svg class="text-[var(--color-brand-primary)] shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)]">Office Hours</h3>
        </div>
        <dl class="space-y-3">
          <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] pb-3">
            <dt class="text-[var(--color-text)] font-medium">Monday</dt>
            <dd class="tabular-nums text-[var(--color-text-muted)]">8:00 am – 5:00 pm</dd>
          </div>
          <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] pb-3">
            <dt class="text-[var(--color-text)] font-medium">Tuesday</dt>
            <dd class="tabular-nums text-[var(--color-text-muted)]">8:00 am – 6:00 pm</dd>
          </div>
          <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] pb-3">
            <dt class="text-[var(--color-text)] font-medium">Wednesday</dt>
            <dd class="tabular-nums text-[var(--color-text-muted)]">7:00 am – 5:00 pm</dd>
          </div>
          <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] pb-3">
            <dt class="text-[var(--color-text)] font-medium">Thursday</dt>
            <dd class="tabular-nums text-[var(--color-text-muted)]">8:00 am – 6:00 pm</dd>
          </div>
          <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] pb-3">
            <dt class="text-[var(--color-text)] font-medium">Friday</dt>
            <dd class="tabular-nums text-[var(--color-text-muted)]">8:00 am – 5:00 pm</dd>
          </div>
          <div class="flex justify-between items-center">
            <dt class="text-[var(--color-text)] font-medium">Saturday</dt>
            <dd class="tabular-nums text-[var(--color-text-muted)]">9:00 am – 2:00 pm*</dd>
          </div>
        </dl>
        <p class="mt-4 text-xs text-[var(--color-text-muted)]">*Saturdays by appointment only. Call to confirm availability.</p>
      </div>

      <!-- Address card -->
      <div class="bg-[var(--color-surface-alt)] border border-[var(--color-border-soft)] rounded-2xl p-8 shadow-xl flex flex-col h-full">
        <div class="flex items-center gap-2">
          <svg class="shrink-0 text-[var(--color-brand-primary)]" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)]">Our Address</p>
        </div>
        <h3 class="mt-2 font-display font-semibold text-2xl text-[var(--color-brand-primary)]">Able Family Dental</h3>
        <address class="not-italic mt-2 flex flex-col gap-6 flex-1 justify-between text-[var(--color-text)]">
          <div>
            <p class="leading-relaxed text-[var(--color-text)] font-medium">
              511 – 5th Street South<br />
              Lethbridge, Alberta
            </p>
          </div>
          <div class="flex items-center gap-4">
            <svg class="shrink-0 text-[var(--color-brand-primary)]" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a
              href="mailto:reception@ablefamilydental.com"
              class="text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] font-medium break-all"
            >
              reception@ablefamilydental.com
            </a>
          </div>
          <div class="flex items-center gap-4">
            <svg class="shrink-0 text-[var(--color-brand-primary)]" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a
              href="tel:+14033277202"
              class="text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] font-semibold tabular-nums text-2xl"
            >
              403.327.7202
            </a>
          </div>
        </address>
      </div>

    </div>
  </div>
</section>
