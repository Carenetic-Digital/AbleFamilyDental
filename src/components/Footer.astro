---
const year = new Date().getFullYear();

const footerNav = {
  Services: [
    { label: "Preventive Care", href: "/services/preventive" },
    { label: "Restorative", href: "/services/restorative" },
    { label: "Cosmetic Dentistry", href: "/services/cosmetic" },
    { label: "Invisalign", href: "/services/cosmetic/invisalign" },
    { label: "Oral Surgery", href: "/services/oral-surgery" },
    { label: "Sedation Dentistry", href: "/services/oral-surgery/sedation" },
    { label: "TMJ & Night Guards", href: "/services/oral-surgery/tmj-night-guards" },
    { label: "Sleep Apnea", href: "/services/oral-surgery/sleep-apnea" },
  ],
  Patients: [
    { label: "New Patients", href: "/patients/new-patients" },
    { label: "Canadian Dental Care Plan", href: "/patients/canadiandentalcareplan" },
    { label: "Patient Forms", href: "/patients/forms" },
    { label: "Insurance & Financing", href: "/patients/financial-options" },
    { label: "Our Team", href: "/about/our-team" },
    { label: "About Wildwood", href: "/about" },
    { label: "Contact", href: "/contact" },
  ],
};
---

<footer class="bg-[var(--color-brand-primary)] text-[var(--color-text-on-dark)]">
  <!-- Top of footer: Commitment to clean (centered, with explicit Read more link) -->
  <div class="container-wide pt-10 pb-8 border-b border-white/10">
    <a href="/commitment-to-clean" class="flex flex-wrap items-center justify-center gap-3 text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white group">
      <span class="inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/10 group-hover:bg-white/20 transition-colors shrink-0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
      </span>
      <span><span class="text-white font-semibold">Our commitment to clean.</span> Infection prevention and sterilization standards.</span>
      <span class="inline-flex items-center gap-1 font-semibold text-[var(--color-brand-accent-soft)] group-hover:text-white">
        Read more
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </span>
    </a>
  </div>

  <div class="container-wide pt-12 pb-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
      <!-- Brand + phone -->
      <div class="md:col-span-3">
        <a href="/" class="inline-block bg-white rounded-lg p-3 leading-none" aria-label="Wildwood Dental Clinic home">
          <picture>
            <source type="image/webp" srcset="/images/brand/wildwood-dental-clinic-logo.webp" />
            <img
              src="/images/brand/wildwood-dental-clinic-logo.png"
              alt="Wildwood Dental Clinic"
              width="250"
              height="92"
              loading="lazy"
              decoding="async"
              class="h-12 w-auto block"
            />
          </picture>
        </a>
        <p class="mt-5 text-sm text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xs">
          Family dentistry on 8th Street East, Saskatoon. Serving the community for 35+ years.
        </p>
        <a href="tel:+13063747272" class="mt-5 inline-block text-lg font-semibold tabular-nums text-[var(--color-brand-accent-soft)] hover:text-white">306.374.7272</a>
      </div>

      <!-- Nav columns -->
      {Object.entries(footerNav).map(([heading, links]) => (
        <div class="md:col-span-3">
          <h2 class="font-display text-sm font-semibold tracking-[0.18em] uppercase text-white mb-5">{heading}</h2>
          <ul class="space-y-3 text-sm">
            {links.map(link => (
              <li><a href={link.href} class="text-[var(--color-text-on-dark-muted)] hover:text-white">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Visit us: address, email, hours -->
      <div class="md:col-span-3">
        <h2 class="font-display text-sm font-semibold tracking-[0.18em] uppercase text-white mb-5">Visit Us</h2>
        <address class="not-italic text-sm text-[var(--color-text-on-dark-muted)] space-y-1">
          <div>105 – 1526 8th Street East</div>
          <div>Saskatoon, SK&nbsp; S7H 0T3</div>
          <div class="pt-1"><a href="mailto:reception@wildwooddentalclinic.com" class="hover:text-white">reception@wildwooddentalclinic.com</a></div>
        </address>
        <dl class="mt-5 text-sm text-[var(--color-text-on-dark-muted)] space-y-1">
          <div><dt class="inline text-white font-medium">Mon/Tue/Thu</dt> <dd class="inline tabular-nums">7:30 – 4:30</dd></div>
          <div><dt class="inline text-white font-medium">Wed</dt> <dd class="inline tabular-nums">7:30 – 8:30</dd></div>
          <div><dt class="inline text-white font-medium">Fri</dt> <dd class="inline tabular-nums">7:30 – 4:00</dd></div>
          <div><dt class="inline text-white font-medium">Sat/Sun</dt> <dd class="inline">Closed</dd></div>
        </dl>
      </div>
    </div>

    <!-- Accreditation & trust marks (centered, above the copyright) -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-wrap items-center justify-center gap-3" aria-label="Accredited and regulated">
      <div class="bg-[var(--color-surface-alt)] rounded-md px-4 h-16 flex items-center" title="College of Dental Surgeons of Saskatchewan">
        <img
          src="/images/brand/cdss-logo.png"
          alt="College of Dental Surgeons of Saskatchewan"
          width="300"
          height="216"
          loading="lazy"
          decoding="async"
          class="h-11 w-auto object-contain"
        />
      </div>
      <div class="bg-[var(--color-surface-alt)] rounded-md px-4 h-16 flex items-center" title="Canadian Dental Association">
        <img
          src="/images/brand/cda-logo.png"
          alt="Canadian Dental Association"
          width="301"
          height="168"
          loading="lazy"
          decoding="async"
          class="h-11 w-auto object-contain"
        />
      </div>
      <div class="bg-[var(--color-surface-alt)] rounded-md px-5 h-16 flex flex-col items-center justify-center text-center leading-none" title="Saskatchewan Dental Association">
        <span class="font-display font-semibold text-[var(--color-brand-primary)] text-base">SDA</span>
        <span class="text-[10px] text-[var(--color-text-muted)] mt-1 leading-tight">Sask. Dental Assoc.</span>
      </div>
    </div>

    <!-- Byline: copyright + legal links + corp -->
    <div class="mt-8 pt-6 border-t border-white/10 text-xs text-[var(--color-text-on-dark-muted)] flex flex-wrap gap-x-6 gap-y-3 justify-between items-center">
      <p>© {year} Wildwood Dental Clinic. All rights reserved.</p>
      <div class="flex items-center gap-5">
        <a href="/privacy" class="hover:text-white">Privacy</a>
        <a href="/accessibility-statement" class="hover:text-white">Accessibility</a>
        <span class="text-[var(--color-text-on-dark-muted)]">Part of Canadian Dental Services Corp.</span>
      </div>
    </div>
  </div>
</footer>
