---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    title: "Relaxation Dentistry for Nervous Patients",
    href: "/services/ivs/relaxation",
    description: "IV sedation allows patients with dental anxiety to receive the care they need comfortably and without distress. You stay relaxed and at ease throughout the entire visit.",
    icon: `<path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm0-2a8 8 0 1 0 0-16 8 8 0 0 0 0 16zM8 12a4 4 0 1 1 8 0H8z"/>`,
  },
  {
    title: "Sedation for Sensitive Teeth or Gag Reflex",
    href: "/services/ivs/sensitive-teeth",
    description: "Patients with heightened tooth sensitivity or a strong gag reflex can receive comfortable, uninterrupted care with IV sedation, making procedures that were once difficult entirely manageable.",
    icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
  },
  {
    title: "Stress-Free Visits with IV Sedation",
    href: "/services/ivs/stress-free",
    description: "Many patients have little or no memory of their procedure afterward. IV sedation allows multiple treatments to be completed in a single visit, reducing your total number of appointments.",
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
  {
    title: "Monitoring and Safe Sedation Care",
    href: "/services/ivs/monitoring",
    description: "Your vital signs are monitored throughout the procedure. Dr. Tyler Snow holds certification in moderate conscious IV sedation, ensuring your safety is never compromised.",
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
];
---

<BaseLayout
  title="IV Sedation Dentistry Lethbridge | Able Family Dental"
  description="IV sedation dentistry in Lethbridge at Able Family Dental. Dr. Tyler Snow is certified in moderate conscious IV sedation for anxious patients, sensitive gag reflex, and complex procedures. Call 403.327.7202."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-iv-sedation.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/5" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">IV Sedation</span>
      </nav>
      <p class="eyebrow text-white">IV Sedation Dentistry</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Fear-Free Dentistry with IV Sedation
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Dental anxiety should never stand between you and the care you need. IV sedation at Able Family Dental provides a safe, deeply relaxed experience for patients who have avoided the dentist, or who simply want a more comfortable visit.
      </p>
    </div>
  </section>

  <!-- ============================================================
       INTRO + SERVICE CARDS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <!-- Intro paragraph -->
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="eyebrow">Our approach</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Sedation dentistry for Lethbridge patients
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Dr. Tyler Snow is certified in moderate conscious IV sedation, one of the most effective options available for patients with severe dental anxiety, a sensitive gag reflex, or complex surgical needs. IV sedation is administered intravenously, allowing for precise, adjustable depth of sedation while keeping you comfortable and safe throughout your procedure. Our team monitors your vital signs continuously so you can relax knowing you are in experienced hands.
        </p>
      </div>

      <!-- 2×2 service cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-2 gap-6 max-w-4xl mx-auto">
        {services.map(svc => (
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)] shadow-md flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-4 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon} />
            </div>
            <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] mb-2">{svc.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{svc.description}</p>
            <a href={svc.href} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
              Learn More
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to book?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
