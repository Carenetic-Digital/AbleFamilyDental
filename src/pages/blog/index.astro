---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    title: "Tips for Choosing the Right Family Dental Clinic",
    date: "August 28, 2018",
    excerpt: "Selecting a dentist for the entire family can be challenging. After all, you want a provider who can meet the needs of adults and children alike, as well as someone who will be there for you as your family grows.",
    category: "Family Dentistry",
    categoryColor: "bg-[#dbeafe] text-[#1e40af]",
  },
  {
    title: "What to Expect at Your Teeth Cleaning",
    date: "August 28, 2018",
    excerpt: "You've had professional teeth cleanings twice a year for as long as you can remember, but you still may not know everything that your hygienist does during these visits and why it matters for your long-term oral health.",
    category: "Preventive Care",
    categoryColor: "bg-[#dcfce7] text-[#166534]",
  },
  {
    title: "Why Restore a Broken Tooth?",
    date: "August 28, 2018",
    excerpt: "Maybe you've been there before. You're crunching down on something hard and you suddenly feel a crack. Ignoring a broken tooth may seem tempting, but there are good reasons to address it promptly.",
    category: "Restorative Dentistry",
    categoryColor: "bg-[#fef3c7] text-[#92400e]",
  },
];

const topics = [
  {
    title: "Preventive Care",
    description: "Regular checkups, cleanings, and habits that keep problems small.",
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    title: "Restorative Dentistry",
    description: "Fillings, crowns, implants, and repairing teeth that need attention.",
    icon: `<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>`,
  },
  {
    title: "Cosmetic Dentistry",
    description: "Whitening, veneers, and options for improving the appearance of your smile.",
    icon: `<path d="M12 1L13.5 10.5L23 12L13.5 13.5L12 23L10.5 13.5L1 12L10.5 10.5Z"/>`,
  },
  {
    title: "Children's Dentistry",
    description: "Dental care from a child's first visit through the teenage years.",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
  {
    title: "Oral Surgery",
    description: "Extractions, wisdom teeth, and what to expect from surgical procedures.",
    icon: `<circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/>`,
  },
  {
    title: "Oral Health Tips",
    description: "Day-to-day habits, diet, and home care advice for a healthy mouth.",
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
];
---

<BaseLayout
  title="Learn | Wildwood Dental Clinic, Patient Education & Dental Health Resources"
  description="Explore dental health articles and patient education resources from Wildwood Dental Clinic in Saskatoon. Learn about preventive care, restorative dentistry, children's dentistry, and more."
>

  <!-- ============================================================
       HERO BANNER
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Subtle background texture -->
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-16 lg:py-20">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Blog</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Patient Education &amp; Resources</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Learn About Your Dental Health
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        We believe informed patients make better decisions about their care. Explore articles and resources from our team.
      </p>
    </div>
  </section>

  <!-- ============================================================
       ARTICLES GRID
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">

      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow">From Our Blog</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Dental Health Articles
        </h2>
        <p class="mt-3 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Practical information to help you and your family maintain good oral health between visits.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {articles.map(article => (
          <article class="bg-white rounded-2xl shadow-xl border border-[var(--color-border-soft)] p-6 flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${article.categoryColor}`}>
                {article.category}
              </span>
            </div>
            <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] leading-snug">
              {article.title}
            </h3>
            <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed line-clamp-3 flex-1">
              {article.excerpt}
            </p>
            <div class="mt-5 flex items-center justify-between pt-4 border-t border-[var(--color-border-soft)]">
              <time class="text-xs text-[var(--color-text-muted)]">{article.date}</time>
              <a
                href="#"
                class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors"
              >
                Read Article
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       TOPIC CATEGORIES
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="eyebrow">Browse by Topic</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Dental Health Topics
        </h2>
        <p class="mt-3 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Whether you're preparing for a procedure or just looking to understand your options, explore topics relevant to your care.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {topics.map(topic => (
          <a
            href="#"
            class="group bg-white rounded-xl p-6 shadow-xl border border-[var(--color-border-soft)] flex gap-4 items-start hover:border-[var(--color-brand-accent)]/40 hover:shadow-lg transition-all duration-200"
          >
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0 group-hover:bg-[var(--color-brand-primary-deep)] transition-colors">
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="white"
                stroke-width="1.75"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={topic.icon}
              />
            </div>
            <div>
              <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)] group-hover:text-[var(--color-brand-accent)] transition-colors">
                {topic.title}
              </h3>
              <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                {topic.description}
              </p>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       CDCP RESOURCE CALLOUT
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-alt)]">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-accent)]">Federal Dental Benefit</p>
          <div class="mt-1 w-10 h-0.5 bg-[var(--color-brand-accent)]"></div>
          <h2 class="mt-4 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
            Canadian Dental Care Plan
          </h2>
          <div class="mt-5 space-y-4 text-[var(--color-text)] leading-relaxed">
            <p>
              The Canadian Dental Care Plan (CDCP) is a federal government program designed to help Canadians who do not have access to private dental insurance. It provides coverage for a range of essential dental services for eligible individuals and families.
            </p>
            <p>
              Wildwood Dental Clinic participates in the CDCP and can help you understand your coverage before your appointment. If you think you or a family member may qualify, we encourage you to learn more about the program and confirm your eligibility.
            </p>
          </div>
          <div class="mt-8">
            <a href="/new-patients#cdcp" class="btn btn-primary">
              Learn About CDCP
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-xl border border-[var(--color-border-soft)]">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-14 h-14 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
              <svg width="26" height="26" viewBox="0 0 56 56" fill="none" stroke="white" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M28 6 L10 13 L10 27 C10 38 18 47 28 50 C38 47 46 38 46 27 L46 13 Z" stroke-width="3" fill="none"/>
                <polyline points="20,28 25,33 36,22" stroke-width="3.5"/>
              </svg>
            </div>
            <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)]">We Accept the CDCP</h3>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-muted)]">
              <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
              <span>Available to Canadians without private dental insurance</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-muted)]">
              <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
              <span>Covers a range of preventive and restorative dental services</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-muted)]">
              <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
              <span>Wildwood Dental Clinic is a participating provider</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-[var(--color-text-muted)]">
              <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
              <span>Our team can help confirm your coverage before your visit</span>
            </li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       STAY INFORMED / CONTACT CTA
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide text-center max-w-2xl mx-auto">
      <div class="flex items-center justify-center gap-5 mb-6">
        <div class="w-14 h-px bg-[var(--color-brand-accent)]"></div>
        <p class="font-body text-sm font-semibold tracking-[0.2em] uppercase text-[var(--color-brand-accent)]">We're Here to Help</p>
        <div class="w-14 h-px bg-[var(--color-brand-accent)]"></div>
      </div>
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
        Have a dental question?
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
        Our team is happy to answer questions at your next visit, or call us at
        <a href="tel:+13063747272" class="font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">306.374.7272</a>.
      </p>
      <div class="mt-8">
        <a href="/book" class="btn btn-primary btn-lg">
          Request an Appointment
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
