---
import BaseLayout from '../../layouts/BaseLayout.astro';

const aboutNav = [
  { name: "Our Clinic", href: "/about/our-clinic" },
  { name: "Our Doctors", href: "/about/our-team", current: true },
  { name: "Careers", href: "/about/careers" },
];

const doctors = [
  {
    name: "Dr. Dan Anderson",
    credentials: "DDS",
    education: "University of Alberta",
    bio: [
      "Dr. Anderson has been passionate about dentistry since growing up in Magrath, Alberta, where he first envisioned his future in the field. Today, he is proud to live out that dream by caring for families throughout the Lethbridge and Magrath communities. After graduating from high school in Magrath, he went on to earn his dental degree from the University of Alberta.",
      "For over 20 years, Dr. Anderson has been dedicated to providing compassionate, high-quality dental care to his patients. He values building lasting relationships with the families he serves and takes pride in supporting the health and well-being of his community.",
      "Outside of his professional life, he enjoys spending time outdoors and participating in a variety of water sports. He and his wife, Tara, are the proud parents of four children: Devon, Megan, Braden, and Ethan.",
    ],
    photo: "/images/team/dr-dan-anderson.jpg",
    photoWebp: null,
    initials: "DA",
  },
  {
    name: "Dr. Mark Still",
    credentials: "DDS",
    education: "University of Alberta, 2011",
    bio: [
      "Born and raised on a ranch in Mountain View, Alberta, Dr. Mark Still developed a strong work ethic and appreciation for community early in life. While he valued his upbringing on the farm, he discovered at a young age that his true passion was dentistry.",
      "He attended high school in Cardston before pursuing post-secondary studies at the University of Alberta in Edmonton, where he earned his Bachelor of Science degree. He went on to complete his dental education in 2011.",
      "Since joining Able Family Dental in 2013, Dr. Still has built meaningful relationships with both his patients and his team. He is known for his compassionate approach and dedication to helping individuals achieve and maintain healthy, confident smiles.",
      "Outside of the office, Dr. Still enjoys an active family life with his wife and their four children. Together, they spend much of their time camping and participating in sports and various activities. His passion for dentistry is matched by his genuine care for the people he serves, making him a valued member of his community.",
    ],
    photo: "/images/team/dr-mark-still.jpg",
    photoWebp: null,
    initials: "MS",
  },
  {
    name: "Dr. Tyler Snow",
    credentials: "DDS",
    education: "University of Alberta",
    bio: [
      "Dr. Tyler Snow and his lovely wife Morgan both grew up in southern Alberta and are happy to call it home. They have four beautiful children and Dr. Snow enjoys spending as much of his free time as he can being with them.",
      "Dr. Snow began his education at the University of Lethbridge and went on to the University of Alberta to complete a Bachelor of Medical Science and a Doctorate of Dental Surgery. He enjoys the variety of services that general dentistry involves. Dr. Snow is certified to provide several forms of sedation, including nitrous oxide (laughing gas), oral sedation, and moderate conscious IV sedation. This allows him to provide treatment for patients who struggle with dental anxiety or require more invasive surgical treatment such as wisdom tooth removal. Dr. Snow is also Neuromodulator Level 2 certified, allowing him to provide Botox for both upper face wrinkles and teeth grinding.",
      "When he is not doing dentistry or playing with his kids, Dr. Snow enjoys watching football, making barbecue, and working on his old trucks.",
    ],
    photo: "/images/team/dr-tyler-snow.jpg",
    photoWebp: null,
    initials: "TS",
  },
];
---

<BaseLayout
  title="Meet Our Doctors | Able Family Dental Lethbridge"
  description="Meet our doctors at Able Family Dental in Lethbridge, experienced dentists dedicated to comprehensive, patient-centred care."
>

  <!-- ============================================================
       HERO BANNER
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-16 lg:py-20">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/about/our-clinic/" class="text-white hover:text-white/80 transition-colors">About</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Our Doctors</span>
      </nav>
      <p class="eyebrow text-white">Able Family Dental</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Our Doctors
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Our dentists trained at the University of Alberta and are licensed by the Alberta Dental Association and College. They are committed to compassionate, patient-centred care for families throughout Lethbridge and the surrounding communities.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Intro -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Our dentists
            </h2>
            <p class="text-[var(--color-text)] leading-relaxed">
              Able Family Dental is home to three general dentists, all trained at the University of Alberta. Together, they bring decades of experience and a broad range of clinical interests across preventive, restorative, cosmetic, and family dentistry.
            </p>
          </div>

          <!-- Doctor grid -->
          <div class="grid sm:grid-cols-2 gap-8">
            {doctors.map(doc => (
              <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-[var(--color-border-soft)] flex flex-col">
                {doc.photo ? (
                  <picture>
                    {doc.photoWebp && <source type="image/webp" srcset={doc.photoWebp} />}
                    <img
                      src={doc.photo}
                      alt={doc.name}
                      width="600"
                      height="600"
                      loading="lazy"
                      decoding="async"
                      class="w-full aspect-square object-cover object-top"
                    />
                  </picture>
                ) : (
                  <div class="w-full aspect-square bg-[var(--color-surface-cool)] flex items-center justify-center">
                    <span class="font-display font-semibold text-[length:var(--text-4xl)] text-[var(--color-brand-primary)] opacity-30" aria-hidden="true">{doc.initials}</span>
                  </div>
                )}
                <div class="p-6 flex flex-col flex-1">
                  <div>
                    <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">{doc.name}</h3>
                    <p class="text-sm font-medium text-[var(--color-brand-accent)]">{doc.credentials}; {doc.education}</p>
                  </div>
                  <div class="mt-3 h-px bg-[var(--color-border-soft)]"></div>
                  <div class="mt-3 flex-1 space-y-3">
                    {doc.bio.map(para => (
                      <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{para}</p>
                    ))}
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- Supporting staff note -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-accent)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Our full clinical team</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  In addition to our dentists, Able Family Dental is supported by a team of dental hygienists, dental assistants, and administrative staff who work together to ensure every visit runs smoothly. Our hygienists play a central role in preventive care, and our reception team is always happy to answer questions about appointments, insurance, and patient forms.
                </p>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or request an appointment online, new patients welcome.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="/refer/" class="mt-2 btn btn-outline w-full block text-center">Refer Patient</a>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <!-- About nav -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">About Able Family Dental</h3>
            <ul class="space-y-2">
              {aboutNav.map(item => (
                <li>
                  {item.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {item.name}
                    </span>
                  ) : (
                    <a href={item.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {item.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

          <!-- Credentials -->
          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <h3 class="font-display font-semibold text-sm text-[var(--color-brand-primary)] mb-3">Professional Standards</h3>
            <ul class="space-y-2 text-sm text-[var(--color-text-muted)]">
              {[
                "Licensed by the Alberta Dental Association and College",
                "Members of the Canadian Dental Association",
              ].map(item => (
                <li class="flex items-start gap-2">
                  <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent)]" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">
        Meet your dentist in person
      </h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto leading-relaxed">
        Call us at <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or schedule an appointment using our online booking system, new patients are welcome.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
