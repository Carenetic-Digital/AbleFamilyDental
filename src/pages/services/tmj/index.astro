---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const subServices = [
  { name: "TMJ Overview", href: "/services/tmj" },
  { name: "Diagnosis", href: "/services/tmj/diagnosis" },
  { name: "Botulinum Toxin for Jaw Pain", href: "/services/tmj/botox" },
  { name: "Night Guards", href: "/services/tmj/night-guards" },
  { name: "Bite Correction", href: "/services/tmj/bite-correction" },
];

const services = [
  {
    title: "TMJ Diagnosis",
    href: "/services/tmj/diagnosis",
    description: "A thorough assessment of your symptoms, jaw movement, bite, and joint, the starting point for understanding what is contributing to your condition and determining the most appropriate approach.",
    icon: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  },
  {
    title: "Night Guards",
    href: "/services/tmj/night-guards",
    description: "A custom-fabricated occlusal splint worn during sleep to reduce the effects of grinding and clenching on the teeth, jaw muscles, and joint. Custom guards fit accurately and are designed to distribute force evenly across the dental arch.",
    icon: `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`,
  },
  {
    title: "Bite Correction",
    href: "/services/tmj/bite-correction",
    description: "In some cases, minor adjustments to how the teeth come together can reduce uneven loading on the jaw joint and muscles. This is assessed individually and is not appropriate for every patient.",
    icon: `<line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>`,
  },
  {
    title: "Botulinum Toxin for Jaw Pain",
    href: "/services/tmj/botox",
    description: "Injections of botulinum toxin into the jaw muscles may help reduce muscle overactivity associated with clenching and grinding, and can relieve related muscle pain. This is used therapeutically and is discussed on a case-by-case basis.",
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
];
---

<BaseLayout
  title="TMJ & Jaw Pain | Able Family Dental Lethbridge"
  description="TMJ disorder assessment and treatment at Able Family Dental in Lethbridge, night guards, bite evaluation, and care for jaw pain and headaches."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/sourced/service-tmj-treatment.jpg"
        alt="TMJ treatment, jaw examination"
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">TMJ &amp; Jaw</span>
      </nav>
      <p class="eyebrow text-white">Able Family Dental</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        TMJ &amp; Jaw Conditions
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        The temporomandibular joint connects the jaw to the skull and plays a role in chewing, speaking, and mouth opening. Dysfunction in this joint or the surrounding muscles can cause a range of symptoms, from jaw pain and clicking to headaches and limited mouth opening.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- What is the TMJ -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              About the temporomandibular joint
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                The temporomandibular joint (TMJ) is the hinge-like joint located just in front of each ear, where the lower jaw connects to the skull. You have one on each side, and both must work in coordination to allow you to open and close your mouth, chew, and speak.
              </p>
              <p>
                When problems develop with the joint itself, the disc within the joint, or the surrounding muscles, they are collectively described as temporomandibular disorders (TMD). TMD is quite common and can range from occasional mild discomfort to persistent symptoms that affect daily function.
              </p>
              <p>
                The causes of TMD are often multifactorial, meaning multiple contributing factors are typically involved rather than a single identifiable cause. Management is therefore individualized, based on a careful assessment of each patient's symptoms, history, and findings on examination.
              </p>
            </div>
          </div>

          <!-- Common symptoms -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Common symptoms
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Symptoms associated with TMD can vary considerably from person to person, and some may seem unrelated to the jaw at first. They include:
              </p>
              <ul class="mt-3 space-y-3">
                {[
                  "Jaw pain or soreness, particularly in the morning or after eating",
                  "Clicking, popping, or grating sounds when opening or closing the mouth",
                  "Limited mouth opening, or the jaw locking open or closed",
                  "Headaches, particularly around the temples or at the base of the skull",
                  "Earaches or a feeling of fullness in the ears",
                  "Facial muscle tension or fatigue",
                  "Neck and shoulder tension",
                  "Worn or sensitive teeth from clenching or grinding (bruxism)",
                ].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                    <span class="text-[var(--color-text)] leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Services we offer -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              TMJ services at Able Family Dental
            </h2>
            <div class="grid sm:grid-cols-2 gap-6">
              {services.map(svc => (
                <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)] shadow-md flex flex-col">
                  <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-4 shrink-0">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon} />
                  </div>
                  <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] mb-2">{svc.title}</h3>
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{svc.description}</p>
                  <a href={svc.href} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
                    Learn More
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              ))}
            </div>
          </div>

          <!-- Approach note -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-7 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] leading-tight">
              A conservative approach
            </h2>
            <div class="mt-4 space-y-3 text-[var(--color-text)] leading-relaxed">
              <p>
                Most TMJ conditions are managed conservatively in the first instance, with night guards, physiotherapy exercises, dietary modifications, and stress management guidance. More involved interventions are considered only when conservative measures have been tried and symptoms are not adequately controlled.
              </p>
              <p>
                For complex or severe joint conditions, referral to an oral and maxillofacial surgeon or other specialist may be appropriate. We will advise you on this and help coordinate care if needed.
              </p>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or request an appointment online, new patients welcome.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="/refer/" class="mt-2 btn btn-outline w-full block text-center">Refer Patient</a>>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <!-- Sub-services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">TMJ &amp; Jaw Services</h3>
            <ul class="space-y-2">
              {subServices.map(svc => (
                <li>
                  <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                    <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                    {svc.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to get started?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
