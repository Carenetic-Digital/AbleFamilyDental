---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic } from '../data/clinic';
---

<BaseLayout
  title="Refer a Patient | Able Family Dental, Lethbridge"
  description={`Refer a patient to Able Family Dental in Lethbridge. General dentists and healthcare providers can submit a referral online. Call ${clinic.phoneDisplay} with questions.`}
>

  <!-- ============================================================
       HERO BANNER (Contact Us style)
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/refer-hero.jpg"
        alt=""
        width="1537"
        height="1023"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Refer a Patient</span>
      </nav>
      <p class="eyebrow" style="color: white;">For Healthcare Providers</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Refer a Patient
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Healthcare providers and referring offices can use this secure form to send patient referrals to our Lethbridge clinic. We’ll follow up to coordinate care.
      </p>
    </div>
  </section>

  <!-- ============================================================
       QUICK-INFO ROW
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Call Us</p>
            <a
              href={`tel:${clinic.phoneTel}`}
              class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors tabular-nums"
            >
              {clinic.phoneDisplay}
            </a>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">
              Toll-free{' '}
              <a href={`tel:${clinic.tollFreeTel}`} class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] tabular-nums">{clinic.tollFreeDisplay}</a>
            </p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">For urgent referral questions</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Email Us</p>
            <a
              href={`mailto:${clinic.email}`}
              class="font-semibold text-sm text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors break-all"
            >
              {clinic.email}
            </a>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">We respond within one business day</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Find Us</p>
            <p class="font-semibold text-[var(--color-brand-primary)] leading-snug">
              {clinic.streetAddress}<br />{clinic.city}, {clinic.regionAbbr}
            </p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">{clinic.city}, {clinic.region}</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       MAIN: FORM + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">

        <!-- LEFT: Referral form -->
        <div class="bg-white rounded-2xl shadow-xl p-8 border border-[var(--color-border-soft)]">
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-2">
            Submit a Referral
          </h2>
          <p class="mb-6 text-sm text-[var(--color-text-muted)] leading-relaxed">
            Please include as much clinical detail as possible so our team can triage the referral appropriately.
          </p>
          <script is:inline type="text/javascript" src="https://form.jotform.com/jsform/230925045692256"></script>
          <p class="mt-4 text-sm text-[var(--color-text-muted)] leading-relaxed">
            For urgent concerns, please call us directly at{' '}
            <a href={`tel:${clinic.phoneTel}`} class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)]">{clinic.phoneDisplay}</a>.
          </p>
        </div>

        <!-- RIGHT: Referring office info -->
        <div class="flex flex-col gap-6">

          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <div class="flex items-center gap-2 mb-4">
              <svg class="text-[var(--color-brand-accent-soft)] shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <h2 class="font-display font-semibold text-lg text-white">For Referring Offices</h2>
            </div>
            <p class="text-sm text-[var(--color-text-on-dark-muted)] leading-relaxed">
              We welcome referrals from general dentists and other healthcare providers. Our team will follow up to coordinate care and keep you informed.
            </p>
            <div class="mt-5 pt-5 border-t border-white/10 space-y-2 text-sm text-[var(--color-text-on-dark-muted)]">
              <p class="font-semibold text-white">{clinic.name}</p>
              <p>{clinic.streetAddress}<br/>{clinic.city}, {clinic.region}</p>
            </div>
            <a href={`tel:${clinic.phoneTel}`} class="mt-4 flex items-center gap-3 text-white hover:text-[var(--color-brand-accent-soft)] transition-colors">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span class="font-semibold tabular-nums">{clinic.phoneDisplay}</span>
            </a>
          </div>

          <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex items-center gap-3 mb-5">
              <svg class="text-[var(--color-brand-primary)] shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <h2 class="font-display font-semibold text-xl text-[var(--color-brand-primary)]">Office Hours</h2>
            </div>
            <dl class="space-y-0">
              {clinic.hours.map((row, i) => (
                <div class={`flex justify-between items-center py-3 ${i < clinic.hours.length - 1 ? 'border-b border-[var(--color-border-soft)]' : ''}`}>
                  <dt class="text-[var(--color-text)] font-medium text-sm">{row.day}</dt>
                  <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">{row.hours}</dd>
                </div>
              ))}
            </dl>
            <p class="mt-3 text-xs text-[var(--color-text-muted)]">{clinic.hoursNote}</p>
          </div>

          <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-base text-[var(--color-brand-primary)] mb-3">Need to book directly?</h2>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Patients and families can request an appointment online without a formal referral.
            </p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">
        Questions about a referral?
      </h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">
        Call <a href={`tel:${clinic.phoneTel}`} class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">{clinic.phoneDisplay}</a> and our team will be happy to help.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={`tel:${clinic.phoneTel}`} class="btn btn-lg border border-white font-bold tabular-nums text-white hover:bg-white/10 transition-colors">
          {clinic.phoneDisplay}
        </a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
