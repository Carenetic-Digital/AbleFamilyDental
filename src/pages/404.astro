---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Wildwood Dental Clinic"
  description="The page you're looking for doesn't exist. Find what you need on our services, patient, or contact pages."
  noindex={true}
>
  <section class="bg-[var(--color-surface-alt)] section-y">
    <div class="container-narrow text-center">
      <p class="eyebrow">Error 404</p>
      <h1 class="mt-3 font-display text-[length:var(--text-6xl)] font-semibold text-[var(--color-brand-primary)] leading-tight">
        We couldn't find that page.
      </h1>
      <p class="mt-5 max-w-lg mx-auto text-lg text-[var(--color-text-muted)] leading-relaxed">
        The page may have moved, or the link is no longer correct. Here are a few places to start.
      </p>

      <div class="mt-10 grid sm:grid-cols-3 gap-4 max-w-2xl mx-auto text-left">
        <a href="/services/" class="card">
          <h2 class="font-display text-lg font-semibold text-[var(--color-brand-primary)]">Services</h2>
          <p class="mt-1.5 text-sm text-[var(--color-text-muted)]">Browse preventive, restorative, cosmetic, and surgical care.</p>
        </a>
        <a href="/book/" class="card">
          <h2 class="font-display text-lg font-semibold text-[var(--color-brand-primary)]">Book a visit</h2>
          <p class="mt-1.5 text-sm text-[var(--color-text-muted)]">Request a new-patient appointment online.</p>
        </a>
        <a href="/contact/" class="card">
          <h2 class="font-display text-lg font-semibold text-[var(--color-brand-primary)]">Contact</h2>
          <p class="mt-1.5 text-sm text-[var(--color-text-muted)]">Phone, email, and directions to the clinic.</p>
        </a>
      </div>

      <div class="mt-10">
        <a href="/" class="btn btn-primary">Back to homepage</a>
      </div>
    </div>
  </section>
</BaseLayout>
