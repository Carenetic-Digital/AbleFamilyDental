---
import BaseLayout from '../../layouts/BaseLayout.astro';

const existingPatientsNav = [
  { name: "Existing Patients Overview", href: "/existing-patients/" },
  { name: "Post-Visit Instructions", href: "/existing-patients/post-visit/" },
];
---

<BaseLayout
  title="Patient Forms | Existing Patients | Able Family Dental Lethbridge"
  description="Update your dental medical history and insurance coverage online at Able Family Dental in Lethbridge."
>

  <!-- ============================================================
       HERO BANNER
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/clinic-patient.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/existing-patients/" class="text-white hover:text-white/80 transition-colors">Existing Patients</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Patient Forms</span>
      </nav>
      <p class="eyebrow text-white">Existing Patients</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Patient Forms
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Keeping your health and insurance information current helps us provide safe, informed care at every visit.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Why updates matter -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Why we ask for updates
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Your health can change between visits. New medications, diagnoses, allergies, or insurance details all affect how we plan and deliver your dental care.
              </p>
              <p>
                For example, certain medications can affect bleeding or how your body responds to dental materials. Changes in coverage can also affect how claims are submitted. Updating your records ahead of time helps your appointment run smoothly and keeps your care appropriate for your current health status.
              </p>
              <p>
                At each visit we may ask whether anything has changed. Completing the forms below before your appointment saves time at the clinic.
              </p>
            </div>
          </div>

          <!-- Health history update -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Dental medical history update
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Use this form if your medications, health conditions, allergies, or contact information have changed since your last appointment. You can also complete it if it has been some time since your records were last reviewed in full.
              </p>
              <p>
                Complete the form below before your next visit, or let our team know at check-in and we can update your records in the office.
              </p>
            </div>
            <div id="health-history-form" class="mt-6 scroll-mt-24 md:scroll-mt-56 rounded-2xl border border-[var(--color-border-soft)] bg-white shadow-sm overflow-hidden">
              <iframe
                title="Dental Medical and History Update"
                allowtransparency="true"
                allowfullscreen="true"
                allow="geolocation; microphone; camera"
                src="https://hipaa.jotform.com/202384548978269"
                loading="lazy"
                class="w-full border-0 block"
                style="height: 1100px;"
              ></iframe>
            </div>
          </div>

          <!-- Insurance coverage form -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Patient Insurance Coverage Information
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                If your insurance details have changed, or you’d like to share updated coverage information ahead of your next visit, complete this form. Uploading a photo of your insurance card helps speed up check-in.
              </p>
            </div>
            <div id="insurance-coverage-form" class="mt-6 scroll-mt-24 md:scroll-mt-56 rounded-2xl border border-[var(--color-border-soft)] bg-white shadow-sm overflow-hidden">
              <iframe
                title="Patient Insurance Coverage Information"
                allowtransparency="true"
                allowfullscreen="true"
                allow="geolocation; microphone; camera"
                src="https://hipaa.jotform.com/220584308463254"
                loading="lazy"
                class="w-full border-0 block"
                style="height: 1100px;"
              ></iframe>
            </div>
          </div>

          <!-- Privacy -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Privacy &amp; confidentiality</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  All patient information collected at Able Family Dental is handled in accordance with Alberta's privacy legislation and the federal Personal Information Protection and Electronic Documents Act (PIPEDA). Your patient records are confidential, stored securely, and accessed only by members of your care team. We do not share your personal health information without your consent, except as required by law.
                </p>
              </div>
            </div>
          </div>

          <!-- Contact to ask -->
          <div class="bg-[var(--color-surface-alt)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)] mb-3">Questions about forms?</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">
              If you have questions about updating your records or completing paperwork in advance, please call our reception team, they’re happy to help.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="tel:+14033277202" class="btn btn-primary">Call 403.327.7202</a>
              <a href="/contact/" class="btn btn-outline">Contact Us</a>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Book your next recall or follow-up appointment online, or call us directly.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Existing Patients</h3>
            <ul class="space-y-2">
              {existingPatientsNav.map(item => (
                <li>
                  <a href={item.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                    <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                    {item.name}
                  </a>
                </li>
              ))}
              <li>
                <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                  Patient Forms
                </span>
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <h3 class="font-display font-semibold text-sm text-[var(--color-brand-primary)] mb-2">Contact Us</h3>
            <p class="text-xs text-[var(--color-text-muted)] mb-3">Our reception team can answer questions about forms, appointments, and your records.</p>
            <a href="tel:+14033277202" class="font-semibold text-sm text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">403.327.7202</a>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">
        Ready for your next visit?
      </h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">
        Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or book online.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
