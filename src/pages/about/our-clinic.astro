---
import BaseLayout from '../../layouts/BaseLayout.astro';

const aboutNav = [
  { name: "Our Clinic", href: "/about/our-clinic", current: true },
  { name: "Our Team", href: "/about/our-team" },
  { name: "Careers", href: "/about/careers" },
];

const differentiators = [
  {
    title: "Family-Oriented Care",
    body: "We welcome patients of all ages, from young children to seniors, and work to create a comfortable and supportive environment.",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
  {
    title: "Comfortable Experience",
    body: "Comfortable seating, personal televisions, and sedation options including nitrous oxide and oral sedation help ease dental anxiety.",
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
  {
    title: "Direct Insurance Billing",
    body: "We bill most major insurance plans directly so you spend less time on paperwork and more time focused on your health.",
    icon: `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`,
  },
  {
    title: "Extended Hours",
    body: "Open Wednesday evenings until 8:30 pm, giving working patients and families more flexibility to schedule appointments.",
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    title: "Minimal Wait Times",
    body: "We respect your time. Our scheduling is designed to minimize wait times and get you in and out efficiently.",
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    title: "Ample Free Parking",
    body: "Our 8th Street East location offers convenient, free parking right outside the clinic, no hunting for a spot before your appointment.",
    icon: `<circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"/>`,
  },
];

const aboutSections = [
  {
    title: "Our Team",
    href: "/about/our-team",
    body: "Meet our six dentists, all trained at the University of Saskatchewan and licensed by the College of Dental Surgeons of Saskatchewan, and learn about the clinical team that supports your care.",
    cta: "Meet Our Team",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
    highlights: [
      "Six general dentists",
      "University of Saskatchewan trained",
      "Dental hygienists, assistants & admin",
      "Patient-centred care approach",
    ],
  },
  {
    title: "Careers",
    href: "/about/careers",
    body: "We're always interested in hearing from qualified dental professionals. Learn about the types of roles at our clinic and how to reach us about current or future opportunities.",
    cta: "View Careers",
    icon: `<rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
    highlights: [
      "Dentists & dental hygienists",
      "Dental assistants",
      "Administrative & reception",
      "Established Saskatoon practice",
    ],
  },
];
---

<BaseLayout
  title="About Wildwood Dental Clinic | Saskatoon Family Dentistry"
  description="Learn about Wildwood Dental Clinic in Saskatoon, including our history, patient care approach, facility, technology, and family dentistry team."
>

  <!-- ============================================================
       HERO BANNER
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/sourced/clinic-interior-dental-office.png"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">About</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Serving Saskatoon for over 35 years</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        About Wildwood Dental Clinic
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        A family-oriented general dental practice on 8th Street East in Saskatoon, focused on preventive care, clear communication, and a welcoming environment for patients of every age.
      </p>
    </div>
  </section>

  <!-- ============================================================
       OUR STORY
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-brand-accent)]">Our Story</p>
        <div class="mt-1 w-10 h-0.5 bg-[var(--color-brand-accent)]"></div>
        <h2 class="mt-4 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          A Saskatoon dental home for over 35 years
        </h2>
        <div class="mt-5 space-y-4 text-[var(--color-text)] leading-relaxed">
          <p>
            Wildwood Dental Clinic has been serving Saskatoon families from our 8th Street East location since we first opened our doors. Over those years, we've built lasting relationships with patients across the city, many of whom have been coming to us for decades, and many who have brought their children and grandchildren along the way.
          </p>
          <p>
            Our team of six general dentists provides a comprehensive range of dental services under one roof: from routine checkups and cleanings to dental implants, Invisalign, sedation dentistry, and more. Whether you're a new patient or a familiar face, you'll find a professional, friendly environment designed around your comfort and your health.
          </p>
          <p>
            We're a proud part of the Saskatoon community, and we take that seriously, from the training our dentists received right here in Saskatchewan to the professional standards we uphold through the College of Dental Surgeons of Saskatchewan and our Commitment to Clean designation.
          </p>
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/book/" class="btn btn-primary">Request an Appointment</a>
          <a href="/contact/" class="btn btn-outline">Get in Touch</a>
        </div>
      </div>

      <div>
        <img
          src="/images/about/wildwood-exterior.png"
          alt="Wildwood Dental Clinic exterior on 8th Street East, Saskatoon"
          width="900"
          height="700"
          loading="lazy"
          decoding="async"
          class="w-full rounded-2xl shadow-xl object-cover"
        />
      </div>

    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- Main content -->
        <div class="space-y-10">

          <!-- Our approach -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Our approach to care
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                We believe good dental care begins with clear communication. When we find something at your exam, we take the time to explain what it is, what it means, and what the options are, including what happens if you decide to wait. Our goal is to give you the information you need to make decisions that work for your life.
              </p>
              <p>
                Prevention is central to how we practice. Regular checkups and cleanings are the foundation of long-term oral health, and we focus on helping patients understand the habits and routines that support healthy teeth and gums between visits.
              </p>
              <p>
                We also understand that dental visits can feel stressful for some patients. We work to make every appointment as comfortable as possible, and we offer sedation options, including nitrous oxide and oral sedation, for patients who would benefit from additional support.
              </p>
            </div>
          </div>

          <!-- Clinic photos carousel -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
              Our space
            </h2>
            <div class="flex items-center gap-3" aria-roledescription="carousel" aria-label="Clinic photos">
              <button id="space-prev" aria-label="Previous" class="shrink-0 w-9 h-9 rounded-full border border-[var(--color-border-soft)] bg-white shadow-sm flex items-center justify-center text-[var(--color-brand-primary)] hover:bg-[var(--color-surface-cool)] transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <!-- 4-slot sliding track: s0(off-left) | s1(visible) | s2(visible) | s3(off-right) -->
              <div class="overflow-hidden flex-1" id="space-viewport" style="opacity:0">
                <div class="flex gap-4" id="space-track">
                  <img id="space-s0" src="/images/about/wildwood-seating.png"   alt="" aria-hidden="true" width="800" height="600" loading="lazy" decoding="async" class="shrink-0 w-[calc(50%-8px)] rounded-xl shadow-xl object-cover aspect-[4/3]" />
                  <img id="space-s1" src="/images/about/wildwood-exterior.png"  alt="Wildwood Dental Clinic exterior"              width="800" height="600" loading="lazy" decoding="async" class="shrink-0 w-[calc(50%-8px)] rounded-xl shadow-xl object-cover aspect-[4/3]" />
                  <img id="space-s2" src="/images/about/wildwood-reception.png" alt="Wildwood Dental Clinic reception area"         width="800" height="600" loading="lazy" decoding="async" class="shrink-0 w-[calc(50%-8px)] rounded-xl shadow-xl object-cover aspect-[4/3]" />
                  <img id="space-s3" src="/images/about/wildwood-seating.png"   alt="" aria-hidden="true" width="800" height="600" loading="lazy" decoding="async" class="shrink-0 w-[calc(50%-8px)] rounded-xl shadow-xl object-cover aspect-[4/3]" />
                </div>
              </div>
              <button id="space-next" aria-label="Next" class="shrink-0 w-9 h-9 rounded-full border border-[var(--color-border-soft)] bg-white shadow-sm flex items-center justify-center text-[var(--color-brand-primary)] hover:bg-[var(--color-surface-cool)] transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>

          <script is:inline>
            (function () {
              var slides = [
                { src: '/images/about/wildwood-exterior.png',  alt: 'Wildwood Dental Clinic exterior' },
                { src: '/images/about/wildwood-reception.png', alt: 'Wildwood Dental Clinic reception area' },
                { src: '/images/about/wildwood-seating.png',   alt: 'Wildwood Dental Clinic patient seating area' },
              ];
              var N = slides.length;
              var current = 0;
              var busy = false;
              var track    = document.getElementById('space-track');
              var viewport = document.getElementById('space-viewport');
              var s = [
                document.getElementById('space-s0'),
                document.getElementById('space-s1'),
                document.getElementById('space-s2'),
                document.getElementById('space-s3'),
              ];

              function idx(n) { return ((n % N) + N) % N; }

              function assign(el, n, ghost) {
                var d = slides[idx(n)];
                el.src = d.src;
                el.alt = ghost ? '' : d.alt;
                ghost ? el.setAttribute('aria-hidden', 'true') : el.removeAttribute('aria-hidden');
              }

              function getStep() {
                var gap = parseFloat(window.getComputedStyle(track).columnGap) || 16;
                return s[1].offsetWidth + gap;
              }

              function snap() {
                track.style.transition = 'none';
                track.offsetHeight;
                track.style.transform = 'translateX(-' + getStep() + 'px)';
              }

              function go(dir) {
                if (busy) return;
                busy = true;
                assign(dir === 1 ? s[3] : s[0], current + (dir === 1 ? 2 : -1), true);
                var step = getStep();
                track.style.transition = 'transform 0.4s ease-in-out';
                track.style.transform = dir === 1
                  ? 'translateX(-' + (2 * step) + 'px)'
                  : 'translateX(0px)';
                track.addEventListener('transitionend', function h(e) {
                  if (e.propertyName !== 'transform') return;
                  track.removeEventListener('transitionend', h);
                  current = idx(current + dir);
                  assign(s[1], current,     false);
                  assign(s[2], current + 1, false);
                  assign(s[0], current - 1, true);
                  assign(s[3], current + 2, true);
                  snap();
                  busy = false;
                });
              }

              requestAnimationFrame(function () {
                snap();
                viewport.style.opacity = '1';
              });

              document.getElementById('space-prev').addEventListener('click', function () { go(-1); });
              document.getElementById('space-next').addEventListener('click', function () { go(1); });
            })();
          </script>

          <!-- Differentiators grid -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
              What patients can expect
            </h2>
            <div class="grid sm:grid-cols-2 gap-5">
              {differentiators.map(item => (
                <div class="bg-white rounded-xl p-5 border border-[var(--color-border-soft)] flex gap-4 items-start">
                  <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
                  </div>
                  <div>
                    <h3 class="font-display font-semibold text-sm text-[var(--color-brand-primary)]">{item.title}</h3>
                    <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">{item.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Our Technology -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Our Technology
            </h2>
            <p class="text-[var(--color-text)] leading-relaxed mb-6">
              Wildwood Dental Clinic uses modern dental technology to support accurate diagnosis and patient-centred care. Our equipment includes in-house digital X-rays for clear, low-radiation imaging and CEREC Primemill for same-day ceramic restorations.
            </p>
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="rounded-2xl overflow-hidden">
                <img
                  src="/images/bugherd/CEREC_Primemill.png"
                  alt="CEREC Primemill in-office milling unit"
                  width="800"
                  height="600"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-72 object-cover"
                />
                <div class="bg-white px-4 py-3 border border-t-0 border-[var(--color-border-soft)] rounded-b-2xl">
                  <p class="text-sm font-semibold text-[var(--color-brand-primary)]">CEREC Primemill</p>
                  <p class="text-xs text-[var(--color-text-muted)] mt-0.5">Same-day ceramic restorations</p>
                </div>
              </div>
              <div class="rounded-2xl overflow-hidden">
                <img
                  src="/images/bugherd/Xray.png"
                  alt="Digital X-ray imaging"
                  width="800"
                  height="600"
                  loading="lazy"
                  decoding="async"
                  class="w-full h-72 object-cover"
                />
                <div class="bg-white px-4 py-3 border border-t-0 border-[var(--color-border-soft)] rounded-b-2xl">
                  <p class="text-sm font-semibold text-[var(--color-brand-primary)]">Digital X-Rays</p>
                  <p class="text-xs text-[var(--color-text-muted)] mt-0.5">Low-radiation digital imaging</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Location & access -->
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-4">
              Location &amp; accessibility
            </h2>
            <div class="space-y-3 text-[var(--color-text)] leading-relaxed">
              <p>
                We're located at <strong>105 – 1526 8th Street East, Saskatoon, SK S7H 0T3</strong>, between Preston and Cumberland Avenues on the south side of 8th Street East.
              </p>
              <ul class="space-y-2 mt-3">
                {[
                  "Free on-site parking directly in front of the clinic",
                  "Wheelchair accessible entrance and treatment rooms",
                  "Accessible parking spaces near the entrance",
                  "Bus routes within one block on 8th Street East",
                ].map(item => (
                  <li class="flex items-center gap-2.5 text-sm text-[var(--color-text-muted)]">
                    <svg class="shrink-0 text-[var(--color-brand-accent)]" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <div class="mt-4">
                <a
                  href="https://maps.google.com/?q=105-1526+8th+Street+East+Saskatoon+SK"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors"
                >
                  Get Directions
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">

          <!-- Booking card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or request an appointment online, new patients welcome.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Request Appointment</a>
            <a href="tel:+13063747272" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">306.374.7272</a>
          </div>

          <!-- About nav -->
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">About Wildwood</h3>
            <ul class="space-y-2">
              {aboutNav.map(item => (
                <li>
                  {item.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {item.name}
                    </span>
                  ) : (
                    <a href={item.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {item.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

          <!-- Contact card -->
          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)] mb-3">Get in Touch</h3>
            <div class="space-y-2 text-sm text-[var(--color-text-muted)]">
              <p><strong class="text-[var(--color-text)]">Wildwood Dental Clinic</strong></p>
              <p>105 – 1526 8th Street East<br/>Saskatoon, SK</p>
              <p>
                <a href="tel:+13063747272" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent)] transition-colors">306.374.7272</a>
              </p>
            </div>
            <a href="/contact/" class="mt-4 inline-block text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">Contact Us →</a>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PROFESSIONAL STANDARDS & CREDENTIALS
       ============================================================ -->
  <section class="pt-[var(--spacing-section)] pb-0 bg-[var(--color-surface)] relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 30% 30%, rgba(74,118,210,0.08) 0%, transparent 58%);" aria-hidden="true"></div>

    <div class="container-wide relative grid lg:grid-cols-[40fr_60fr] gap-10 lg:gap-14 items-start pb-2">

      <!-- LEFT: Copy -->
      <div>
        <p class="eyebrow">Patient Care Standards</p>
        <div class="mt-3 w-12 h-[3px] bg-[var(--color-brand-accent)] rounded-sm"></div>
        <h2 class="mt-5 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Committed to Safe, Professional Dental Care
        </h2>
        <div class="mt-5 space-y-4 text-[var(--color-text-muted)] leading-[1.7]">
          <p>At Wildwood Dental Clinic, we are committed to providing patient-centred dental care in a professional, respectful, and compliant environment.</p>
          <p>Our team follows the guidelines set by the College of Dental Surgeons of Saskatchewan and references trusted national dental resources to support patient education.</p>
          <p>As part of the Canadian Dental Services Corp. network, we support cleanliness, sterilization, and infection prevention standards through the Commitment to Clean program.</p>
        </div>
      </div>

      <!-- RIGHT: Credential cards + skyline -->
      <div class="flex flex-col gap-0">

        <div class="grid grid-cols-3 max-[559px]:grid-cols-1 gap-4">

          <!-- CDSS -->
          <div class="rounded-[var(--radius-lg)] bg-white flex flex-col items-center">
            <div class="w-full aspect-square bg-white rounded-[var(--radius-lg)] overflow-hidden flex items-center justify-center p-5">
              <img
                src="/images/logos/CollegeofDentalSurgeons.png"
                alt="College of Dental Surgeons of Saskatchewan"
                width="300"
                height="216"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-contain"
              />
            </div>
          </div>

          <!-- CDA -->
          <div class="rounded-[var(--radius-lg)] bg-white flex flex-col items-center">
            <div class="w-full aspect-square bg-white rounded-[var(--radius-lg)] overflow-hidden flex items-center justify-center p-5">
              <img
                src="/images/brand/cda-logo.png"
                alt="Canadian Dental Association"
                width="301"
                height="168"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-contain"
              />
            </div>
          </div>

          <!-- Commitment to Clean -->
          <div class="rounded-[var(--radius-lg)] bg-white flex flex-col items-center">
            <div class="w-full aspect-square bg-white rounded-[var(--radius-lg)] overflow-hidden flex items-center justify-center p-5">
              <img
                src="/images/logos/Commitment-to-Clean-shield.png"
                alt="Commitment to Clean — Canadian Dental Services"
                width="400"
                height="400"
                loading="lazy"
                decoding="async"
                class="w-[75%] h-[75%] object-contain"
              />
            </div>
          </div>

        </div>

        <!-- Skyline graphic -->
        <div class="w-full" style="aspect-ratio: 16/5;">
          <img
            src="/images/brand/saskatoon-skyline.png"
            alt=""
            aria-hidden="true"
            width="1600"
            height="500"
            loading="lazy"
            decoding="async"
            class="w-full h-full object-contain object-bottom mix-blend-multiply"
            style="filter: sepia(1) brightness(2.2) saturate(0.35); opacity: 0.45;"
          />
        </div>

      </div>

    </div>
  </section>

  <!-- ============================================================
