---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    title: "Emergency Appointments",
    href: "/services/emergency/appointments",
    description: "Call us as soon as you notice a problem. We keep time in our schedule for urgent situations and will work to see you as quickly as possible.",
    icon: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  },
  {
    title: "Same-Day Emergency Appointments",
    href: "/services/emergency/same-day",
    description: "Wildwood Dental makes every effort to accommodate dental emergencies on the same day you call. Describe your symptoms clearly so we can prepare for your arrival.",
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    title: "Toothache Relief",
    href: "/services/emergency/toothache",
    description: "Persistent or severe tooth pain can signal decay, infection, or nerve involvement. We assess the cause and provide appropriate care to relieve pain and address the underlying issue.",
    icon: `<path d="M12 2C9 2 7 4 7 7c0 1.5.5 2.5 1 3.5.5 1 1 2 1 3.5 0 2 .5 4 3 4 1 0 1.5-1 2-1.5.5.5 1 1.5 2 1.5 2.5 0 3-2 3-4 0-1.5.5-2.5 1-3.5.5-1 1-2 1-3.5 0-3-2-5-5-5z"/>`,
  },
  {
    title: "Broken/Chipped Tooth Emergency Repair",
    href: "/services/emergency/broken-tooth",
    description: "A broken or chipped tooth can leave a sharp edge, expose the inner tooth structure, or cause significant pain. Prompt assessment helps prevent further damage.",
    icon: `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  },
  {
    title: "Knocked-Out Tooth Treatment",
    href: "/services/emergency/knocked-out-tooth",
    description: "A knocked-out tooth is time-critical. Handle the tooth by the crown, keep it moist, and call us immediately. Acting quickly gives the best chance of successful replantation.",
    icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>`,
  },
];
---

<BaseLayout
  title="Emergency Dental Care | Wildwood Dental Clinic"
  description="Dental emergency in Saskatoon? Call Wildwood Dental Clinic at 306.374.7272, we make every effort to see emergency patients the same day. Learn what to do while you wait."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-emergency-pexels.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Emergency Services</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Wildwood Dental Clinic</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Emergency Dental Care in Saskatoon
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        If you are experiencing a dental emergency, call us immediately at <a href="tel:+13063747272" class="text-white font-semibold">306.374.7272</a>. We make every effort to accommodate same-day emergency appointments.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="space-y-10 max-w-3xl">

        <!-- Call first -->
        <div class="bg-[var(--color-surface-alt)] rounded-2xl p-7 border border-[var(--color-border-soft)]">
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.57 3.38 2 2 0 0 1 3.54 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div>
              <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">Call before you come in</h3>
              <p class="mt-1.5 text-[var(--color-text-muted)] leading-relaxed">
                Please call <a href="tel:+13063747272" class="text-[var(--color-brand-primary)] font-semibold hover:text-[var(--color-brand-accent)] transition-colors">306.374.7272</a> before arriving at the clinic. Our team will advise you on next steps, how urgently you need to be seen, and any first-aid measures you can take in the meantime. Walk-ins during a dental emergency can create delays for both you and other patients.
              </p>
            </div>
          </div>
        </div>

        <!-- What qualifies -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
            What counts as a dental emergency?
          </h2>
          <p class="mt-4 text-[var(--color-text)] leading-relaxed">
            If you are unsure whether your situation is a dental emergency, call us and describe your symptoms. Our team can help you decide. Common dental emergencies include:
          </p>
          <ul class="mt-5 space-y-3">
            {[
              "Severe toothache that does not resolve",
              "A knocked-out tooth (this is time-sensitive, call immediately)",
              "A broken or cracked tooth with a sharp edge or significant pain",
              "A lost filling or crown that is causing pain or leaving a sharp surface",
              "Swelling of the face, jaw, or gums",
              "A suspected abscess (dental infection)",
              "Dental injury from an accident or trauma",
            ].map(item => (
              <li class="flex items-start gap-3">
                <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                <span class="text-[var(--color-text)] leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- What to do while you wait -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
            What to do while you wait
          </h2>
          <p class="mt-4 text-[var(--color-text)] leading-relaxed">
            First-aid steps depend on the nature of the emergency. Here is guidance for common situations:
          </p>

          <div class="mt-6 space-y-6">
            {[
              {
                situation: "Knocked-out tooth",
                steps: [
                  "Handle the tooth by the crown (the white part), not the root.",
                  "Rinse gently with clean water if it is dirty. Do not scrub or remove any attached tissue.",
                  "Keep the tooth moist: ideally place it back in the socket, or store it in milk or between your cheek and gum.",
                  "Come in or go to emergency care as quickly as possible, time is critical.",
                ],
              },
              {
                situation: "Broken or chipped tooth",
                steps: [
                  "Rinse your mouth with warm water.",
                  "Apply a cold compress to the outside of your cheek to reduce swelling.",
                  "Save any tooth fragments if possible.",
                  "Call us to arrange prompt assessment.",
                ],
              },
              {
                situation: "Lost filling or crown",
                steps: [
                  "Temporary dental cement, available at most pharmacies, can be used to protect the area until your appointment.",
                  "Avoid chewing on that side.",
                  "Call us to schedule repair as soon as possible.",
                ],
              },
              {
                situation: "Abscess or facial swelling",
                steps: [
                  "Do not attempt to lance or drain the area yourself.",
                  "Call us immediately, dental abscesses can progress and require prompt attention.",
                  "If swelling is affecting your ability to breathe or swallow, go to the nearest hospital emergency department without delay.",
                ],
              },
            ].map(item => (
              <div class="rounded-2xl border border-[var(--color-border-soft)] overflow-hidden">
                <div class="bg-[var(--color-brand-primary)] px-6 py-3">
                  <h3 class="font-display font-semibold text-white">{item.situation}</h3>
                </div>
                <ul class="px-6 py-4 space-y-2">
                  {item.steps.map(step => (
                    <li class="flex items-start gap-3 text-sm text-[var(--color-text)] leading-relaxed">
                      <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                      {step}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

        <!-- After hours -->
        <div class="bg-[var(--color-surface-cool)] rounded-2xl p-7 border border-[var(--color-border-soft)]">
          <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] leading-tight">
            After hours
          </h2>
          <div class="mt-4 space-y-3 text-[var(--color-text)] leading-relaxed">
            <p>
              If you are unable to reach the clinic and you have facial swelling that is affecting your breathing or swallowing, proceed to the nearest hospital emergency department. These symptoms can indicate a spreading infection that requires immediate medical attention.
            </p>
            <p>
              For non-life-threatening concerns outside of office hours, calling and leaving a message will allow us to follow up as soon as we are available.
            </p>
          </div>
        </div>

        <!-- Same-day appointments -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
            Same-day appointments
          </h2>
          <div class="mt-4 space-y-4 text-[var(--color-text)] leading-relaxed">
            <p>
              Wildwood Dental makes every effort to accommodate patients experiencing dental emergencies on the same day they call. We understand that dental pain is not something most people can simply wait out, and that some emergencies, like a knocked-out tooth, are time-sensitive.
            </p>
            <p>
              When you call, describe your symptoms clearly so our team can prioritize appropriately and prepare for your arrival.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       SUBSERVICE CARDS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <p class="eyebrow">Emergency services</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          What we treat
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          From toothaches to knocked-out teeth, our team is ready to assess and treat a wide range of dental emergencies. Call us first so we can prepare for your arrival.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(svc => (
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)] shadow-md flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-4 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon} />
            </div>
            <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] mb-2">{svc.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{svc.description}</p>
            <a href={svc.href} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
              Learn More
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white">Have questions about your treatment?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> or book an appointment.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
