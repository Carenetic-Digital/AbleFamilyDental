---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: "Preventive",
    href: "/services/preventive",
    blurb: "Cleanings, exams, and everyday care that keeps small issues small.",
    services: [
      { name: "Cleanings & Check-ups", href: "/services/preventive/cleanings-checkups" },
      { name: "Sealants", href: "/services/preventive/sealants" },
      { name: "Fluoride", href: "/services/preventive/fluoride" },
      { name: "X-Rays & 3D Imaging", href: "/services/preventive/x-rays" },
      { name: "Periodontal Treatment", href: "/services/preventive/periodontal-treatment" },
      { name: "Oral Cancer Screening", href: "/services/preventive/oral-cancer-screening" },
    ],
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  },
  {
    title: "Restorative",
    href: "/services/restorative",
    blurb: "Bringing teeth back to full function — repairing, rebuilding, and replacing.",
    services: [
      { name: "Fillings", href: "/services/restorative/fillings" },
      { name: "Bridges", href: "/services/restorative/bridges" },
      { name: "Crowns", href: "/services/restorative/crowns" },
      { name: "Dentures", href: "/services/restorative/dentures" },
      { name: "Implants", href: "/services/restorative/implants" },
      { name: "Root Canal Treatment", href: "/services/restorative/root-canal" },
    ],
    icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
  },
  {
    title: "Cosmetic",
    href: "/services/cosmetic",
    blurb: "Refining the appearance of your smile while keeping it healthy.",
    services: [
      { name: "Teeth Whitening", href: "/services/cosmetic/teeth-whitening" },
      { name: "Porcelain Veneers", href: "/services/cosmetic/veneers" },
      { name: "Dental Bonding", href: "/services/cosmetic/bonding" },
      { name: "Tooth Reshaping", href: "/services/cosmetic/tooth-reshaping" },
      { name: "Bite Correction", href: "/services/cosmetic/bite-correction" },
      { name: "Invisalign", href: "/services/cosmetic/invisalign" },
    ],
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  },
  {
    title: "Oral Surgery & Other",
    href: "/services/oral-surgery",
    blurb: "Comfort-focused care for extractions, TMJ, sleep apnea, and more.",
    services: [
      { name: "Children's Dentistry", href: "/services/oral-surgery/childrens-dentistry" },
      { name: "Emergency Dental Care", href: "/services/oral-surgery/emergency" },
      { name: "Wisdom Tooth Extraction", href: "/services/oral-surgery/wisdom-teeth" },
      { name: "TMJ & Night Guards", href: "/services/oral-surgery/tmj-night-guards" },
      { name: "Sports Guards", href: "/services/oral-surgery/sports-guards" },
      { name: "Snoring & Sleep Apnea", href: "/services/oral-surgery/sleep-apnea" },
      { name: "Sedation", href: "/services/oral-surgery/sedation" },
    ],
    icon: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.93 12 19.79 19.79 0 0 1 1.87 3.42 2 2 0 0 1 3.84 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>`,
  },
];
---

<BaseLayout
  title="Dental Services | Wildwood Dental Clinic Saskatoon"
  description="Wildwood Dental Clinic offers comprehensive dental care for the whole family — preventive, restorative, cosmetic, and oral surgery services on 8th Street East in Saskatoon."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-16 lg:py-20">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Services</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Comprehensive Dental Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Our Dental Services
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        From routine checkups to full-mouth restorations, Wildwood Dental Clinic offers care for the whole family — all under one roof on 8th Street East.
      </p>
    </div>
  </section>

  <!-- ============================================================
       FOUR CATEGORY CARDS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-8">
        {categories.map(cat => (
          <div class="bg-white rounded-2xl shadow-xl p-8 border border-[var(--color-border-soft)] flex flex-col">
            <!-- Icon + Title -->
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={cat.icon} />
              </div>
              <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)]">
                {cat.title}
              </h2>
            </div>
            <p class="text-[var(--color-text-muted)] leading-relaxed mb-5">{cat.blurb}</p>
            <!-- Service links -->
            <ul class="space-y-2 mb-6 flex-1">
              {cat.services.map(svc => (
                <li>
                  <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text)] hover:text-[var(--color-brand-accent)] transition-colors group">
                    <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0 group-hover:scale-125 transition-transform" aria-hidden="true"></span>
                    {svc.name}
                  </a>
                </li>
              ))}
            </ul>
            <!-- Explore link -->
            <a href={cat.href} class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors mt-auto">
              Explore {cat.title}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       EMERGENCY CALLOUT
       ============================================================ -->
  <section class="bg-[var(--color-surface-alt)] py-14">
    <div class="container-wide">
      <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-10">
        <div class="w-16 h-16 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
        <div class="text-center sm:text-left flex-1">
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
            Dental Emergency?
          </h2>
          <p class="mt-2 text-[var(--color-text-muted)] leading-relaxed">
            Call us immediately at <a href="tel:+13063747272" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent)] transition-colors">306.374.7272</a> — we will do our best to see you the same day.
          </p>
        </div>
        <div class="shrink-0">
          <a href="tel:+13063747272" class="btn btn-primary btn-lg whitespace-nowrap">Call Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to get started?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> or book online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/patients/book" class="btn btn-primary btn-lg">Book an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
