---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Request an Appointment | Able Family Dental, Lethbridge"
  description="Schedule your dental appointment at Able Family Dental on 5th Street South in Lethbridge. New and existing patients welcome. Call 403.327.7202 or request online."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-14 lg:py-18">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Request an Appointment</span>
      </nav>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div>
          <p class="eyebrow text-white">Able Family Dental</p>
          <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white">
            Request an Appointment
          </h1>
          <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
            Request your dental visit online. We'll confirm your appointment by phone or email within one business day.
          </p>
        </div>
        <a
          href="tel:+14033277202"
          class="hidden lg:inline-flex items-center gap-3 bg-white/10 hover:bg-white/20 transition-colors rounded-xl px-6 py-4 text-white shrink-0"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div>
            <p class="text-xs text-[var(--color-text-on-dark-muted)]">Prefer to call?</p>
            <p class="font-semibold tabular-nums text-lg leading-tight">403.327.7202</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       MAIN: FORM + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_340px] gap-10 items-start">

        <!-- =====================================================
             LEFT: JOTFORM EMBED
             ===================================================== -->
        <div>
          <iframe
            id="JotFormIFrame-261603747107051"
            title="Appointment Request Form"
            allowtransparency="true"
            allowfullscreen="true"
            allow="geolocation; microphone; camera"
            src="https://form.jotform.com/261603747107051"
            frameborder="0"
            style="min-width:100%;max-width:100%;height:539px;border:none;margin-top:-70px;"
            scrolling="no"
          ></iframe>
          <script src="https://cdn.jotfor.ms/s/umd/latest/for-form-embed-handler.js" is:inline></script>
          <script is:inline>
            window.jotformEmbedHandler("iframe[id='JotFormIFrame-261603747107051']", "https://form.jotform.com/")
          </script>
        </div>

        <!-- =====================================================
             RIGHT: SIDEBAR
             ===================================================== -->
        <aside class="space-y-5 lg:sticky lg:top-24">

          <!-- Plan Your Visit -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <div class="flex items-center gap-2 mb-4">
              <svg class="text-[var(--color-brand-accent)] shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <h2 class="font-display font-semibold text-base text-white">Plan Your Visit</h2>
            </div>
            <div class="space-y-2 text-sm text-[var(--color-text-on-dark-muted)]">
              <p class="font-semibold text-white">Able Family Dental</p>
              <p>511 – 5th Street South<br/>Lethbridge, Alberta</p>
            </div>
            <a
              href="https://maps.app.goo.gl/pAJAeiNddySjEkKc8"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-white hover:text-[var(--color-brand-accent-soft)] transition-colors"
            >
              Get Directions
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <div class="mt-5 pt-5 border-t border-white/10">
              <a href="tel:+14033277202" class="flex items-center gap-3 text-white hover:text-[var(--color-brand-accent-soft)] transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span class="font-semibold tabular-nums">403.327.7202</span>
              </a>
            </div>
          </div>

          <!-- Office Hours -->
          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <div class="flex items-center gap-2 mb-4">
              <svg class="text-[var(--color-brand-primary)] shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <h2 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Office Hours</h2>
            </div>
            <dl class="space-y-2 text-sm">
              {[
                { day: "Monday", hours: "7:30 am – 4:30 pm" },
                { day: "Tuesday", hours: "7:30 am – 4:30 pm" },
                { day: "Wednesday", hours: "7:30 am – 8:30 pm", extended: true },
                { day: "Thursday", hours: "7:30 am – 4:30 pm" },
                { day: "Friday", hours: "7:30 am – 4:00 pm" },
              ].map(row => (
                <div class={`flex justify-between items-center py-1.5 border-b border-[var(--color-border-soft)] last:border-0 ${row.extended ? 'bg-[var(--color-surface-alt)] -mx-2 px-2 rounded-lg' : ''}`}>
                  <dt class={`font-medium ${row.extended ? 'text-[var(--color-brand-primary)]' : 'text-[var(--color-text)]'}`}>{row.day}</dt>
                  <dd class="tabular-nums text-[var(--color-text-muted)] flex items-center gap-1.5">
                    {row.hours}
                    {row.extended && <span class="text-xs font-semibold text-[var(--color-brand-accent)] bg-[var(--color-brand-accent)]/10 px-1.5 py-0.5 rounded">Extended</span>}
                  </dd>
                </div>
              ))}
            </dl>
          </div>

          <!-- Arrival Tips -->
          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-base text-[var(--color-brand-primary)] mb-4">Arrival Tips</h2>
            <ul class="space-y-3">
              {[
                { icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`, text: "Arrive 10 minutes early for your first appointment to complete any remaining paperwork." },
                { icon: `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`, text: "Bring your insurance card and a piece of photo ID." },
                { icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`, text: "New patients can complete forms online in advance via the Patients page." },
                { icon: `<circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"/>`, text: "Street parking is available on 5th Street South and nearby streets." },
              ].map(tip => (
                <li class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-[var(--color-surface-cool)] flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={tip.icon} />
                  </div>
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{tip.text}</p>
                </li>
              ))}
            </ul>
          </div>

          <!-- Accessibility -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-sm text-[var(--color-brand-primary)] mb-3">Accessibility</h2>
            <ul class="space-y-1.5 text-sm text-[var(--color-text-muted)]">
              <li class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Wheelchair accessible entrance and treatment rooms
              </li>
              <li class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Accessible washroom on site
              </li>
              <li class="flex items-center gap-2">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Lethbridge Transit routes nearby
              </li>
            </ul>
          </div>

        </aside>

      </div>
    </div>
  </section>

  <!-- ============================================================
       VISIT INFORMATION
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="mb-8">
        <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)]">Visit Information</h2>
        <p class="mt-2 text-[var(--color-text-muted)]">Everything you need to know before your visit.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          {
            label: "Accepting New Patients",
            note: "We welcome new patients and families.",
            positive: true,
            icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>`,
          },
          {
            label: "Direct Billing Available",
            note: "We bill most major insurance carriers directly.",
            positive: true,
            icon: `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`,
          },
          {
            label: "Wheelchair-Accessible Entrance",
            note: "Our entrance is fully accessible.",
            positive: true,
            icon: `<circle cx="12" cy="5" r="1"/><path d="M9 20l1-5h4l1 5"/><path d="M8 15l1-5h6l1 5"/><path d="M6 20a5 5 0 0 1 5-5"/>`,
          },
          {
            label: "Accessible Washroom",
            note: "Our washroom is wheelchair accessible.",
            positive: true,
            icon: `<path d="M12 22V12"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><circle cx="12" cy="5" r="3"/>`,
          },
        ].map(item => (
          <div class="bg-white rounded-2xl p-5 border border-[var(--color-border-soft)] flex items-start gap-4">
            <div class={`w-10 h-10 rounded-full flex items-center justify-center shrink-0 ${item.positive ? 'bg-[var(--color-brand-primary)]' : 'bg-[var(--color-surface-alt)]'}`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={item.positive ? 'white' : 'var(--color-text-muted)'} stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-sm text-[var(--color-brand-primary)]">{item.label}</p>
              <p class="mt-0.5 text-xs text-[var(--color-text-muted)] leading-relaxed">{item.note}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       EMERGENCY CALLOUT
       ============================================================ -->
  <section class="bg-[var(--color-surface-alt)] py-12">
    <div class="container-wide flex flex-col sm:flex-row items-center justify-between gap-6">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div>
          <h2 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">Dental Emergency?</h2>
          <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed max-w-lg">
            Don't use this form for urgent dental concerns. Call us directly. We'll do our best to see you the same day.
          </p>
        </div>
      </div>
      <a href="tel:+14033277202" class="btn btn-primary btn-lg shrink-0 flex items-center gap-2">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call 403.327.7202
      </a>
    </div>
  </section>

</BaseLayout>
