---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "Scaling & Root Planing", href: "/services/periodontal/scaling-root-planing", current: true },
  { name: "Gum Disease Treatment", href: "/services/periodontal/gum-disease" },
  { name: "Gum Contouring", href: "/services/periodontal/gum-contouring" },
];
---

<BaseLayout
  title="Periodontal (Gum) Treatment Saskatoon | Periodontal Care | Wildwood Dental Clinic"
  description="Gum disease assessment and treatment at Wildwood Dental Clinic in Saskatoon — from improved home care to scaling and root planing for more advanced cases."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel — desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/sourced/service-periodontal-teeth-checkup.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/periodontal" class="hover:text-white transition-colors">Periodontal Care</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Periodontal Treatment</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Periodontal Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Periodontal Treatment
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Gum health is an important part of your overall oral health — and overall health. We assess and treat gum disease at every stage, from early inflammation to more advanced conditions.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Specialty disclaimer -->
          <div class="bg-[var(--color-surface-alt)] rounded-2xl p-5 border border-[var(--color-border-soft)] flex gap-4 items-start">
            <svg class="shrink-0 mt-0.5 text-[var(--color-brand-primary)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Periodontal services at Wildwood Dental Clinic are provided by our general dentist team. Our dentists are not licensed specialists in periodontics.</p>
          </div>

          <!-- What is gum disease -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What is gum (periodontal) disease?
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Periodontal disease is an infection of the tissues that support your teeth — the gums, periodontal ligament, and the bone that anchors each tooth in place. It is caused by the bacteria found in plaque, which forms continuously on teeth and along the gumline.
              </p>
              <p>
                Gum disease is very common, and many people are unaware they have it because the early stages often cause no pain. Regular dental examinations are one of the most reliable ways to detect and address it before it progresses.
              </p>
              <p>
                Research has also established links between periodontal health and a number of systemic conditions, including cardiovascular disease and diabetes — which is one reason we consider gum assessment a core part of every dental visit, not just a secondary concern.
              </p>
            </div>
          </div>

          <!-- Image break -->
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/images/services/hero-periodontal-pexels.jpg"
              alt="Periodontal gum treatment procedure"
              width="800"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full h-56 sm:h-72 object-cover"
            />
          </div>


          <!-- Stages -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Stages of gum disease
            </h2>
            <div class="space-y-6">
              {[
                {
                  stage: "Gingivitis",
                  detail: "The earliest and most reversible stage. The gums become inflamed — often appearing red, swollen, or prone to bleeding when brushing. There is no bone loss at this stage. Gingivitis is typically addressed through improved home care and a professional cleaning, and can be resolved with consistent effort."
                },
                {
                  stage: "Mild to Moderate Periodontitis",
                  detail: "When gingivitis is not addressed, bacteria can begin to work their way below the gumline, causing pockets to form between the gum and tooth. Some bone loss may be present. Treatment at this stage often involves scaling and root planing, along with a more frequent recall schedule."
                },
                {
                  stage: "Advanced Periodontitis",
                  detail: "In more severe cases, significant bone and tissue loss occurs, teeth may loosen, and the supporting structures can be compromised. Management is more involved and may require referral to a periodontist for specialist care alongside what we provide in practice."
                },
              ].map(item => (
                <div class="border-l-4 border-[var(--color-brand-accent)] pl-5">
                  <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">{item.stage}</h3>
                  <p class="mt-2 text-[var(--color-text)] leading-relaxed">{item.detail}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Treatment options -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Treatment options
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                The appropriate treatment depends on the stage and severity of the condition. For most patients with early gum disease, improved home care combined with a professional cleaning is an effective starting point.
              </p>
              <p>
                For more advanced cases, <strong class="text-[var(--color-brand-primary)]">scaling and root planing</strong> — often called a "deep cleaning" — is the standard non-surgical treatment. This involves a thorough cleaning of the root surfaces below the gumline, typically done under local anesthetic for comfort. The goal is to remove the bacterial deposits and smooth the root surfaces so the gum tissue can reattach and heal.
              </p>
              <p>
                Scaling and root planing is usually performed in sections (one or two quadrants at a time) so each area can be treated thoroughly. Most patients find the procedure comfortable with the anesthetic in place.
              </p>
            </div>
          </div>

          <!-- Maintenance -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Ongoing maintenance
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                After active treatment for gum disease, regular monitoring is important. Patients with a history of periodontitis are typically placed on a periodontal maintenance schedule — more frequent recall appointments (often every 3–4 months) to carefully monitor pocket depths, bone levels, and gum health over time.
              </p>
              <p>
                Gum disease cannot be cured in the way an infection can be — it can be managed and stabilised, but it requires ongoing attention. Our hygienists work closely with each patient to support long-term gum health with a combination of in-office care and personalised home-care guidance.
              </p>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or book online — new patients welcome.</p>
            <a href="/patients/book" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="tel:+13063747272" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">306.374.7272</a>
          </div>

          <!-- Info note -->
          <div class="bg-[var(--color-surface-alt)] rounded-2xl p-5 border border-[var(--color-border-soft)]">
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              <strong class="text-[var(--color-brand-primary)]">Signs to watch for:</strong> bleeding gums when brushing, persistent bad breath, gum recession, or teeth that feel loose. If you notice any of these, call us to schedule a visit.
            </p>
          </div>

          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Periodontal Care</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to get started?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> or book online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/patients/book" class="btn btn-primary btn-lg">Book an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
