---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "X-Rays & 3D Imaging", href: "/services/diagnostic/x-rays" },
  { name: "Intraoral Cameras", href: "/services/diagnostic/intraoral-cameras", current: true },
  { name: "CBCT Scans", href: "/services/diagnostic/cbct" },
  { name: "Oral Cancer Screening", href: "/services/diagnostic/oral-cancer-screening" },
];
---

<BaseLayout
  title="Intraoral Cameras | Diagnostic Services | Wildwood Dental Clinic"
  description="Intraoral cameras at Wildwood Dental Clinic in Saskatoon allow us to see inside your mouth in detail and share findings with you in real time."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel — desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/diagnostic-camera.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/diagnostic" class="hover:text-white transition-colors">Diagnostic Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Intraoral Cameras</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Diagnostic Services</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Intraoral Cameras
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Intraoral cameras let us share exactly what we see — helping you understand your oral health and participate in decisions about your care.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- What they are -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What is an intraoral camera?
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                An intraoral camera is a small, pen-shaped device with a camera and light at the tip. It is used during examinations to capture close-up images and video of the inside of your mouth — your teeth, gums, and surrounding tissue — which are displayed on a screen in real time.
              </p>
              <p>
                The device is comfortable to use and does not produce any radiation. It is a visual tool, used alongside x-rays and clinical examination rather than as a replacement for them.
              </p>
            </div>
          </div>

          <!-- Image break -->
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/images/sourced/service-diagnostic-xrays.jpg"
              alt="Dental x-rays used for diagnostic imaging"
              width="800"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full h-56 sm:h-72 object-cover"
            />
          </div>


          <!-- What they show -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What intraoral cameras can show
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                The camera produces magnified, high-resolution images that make it easier to see detail that may not be obvious to the naked eye during a standard visual exam. This can include:
              </p>
              <ul class="space-y-3 mt-3">
                {[
                  { label: "Early decay", detail: "Discolouration or changes in the tooth surface that may indicate the beginning of a cavity — particularly on the biting surfaces of back teeth where grooves can be difficult to inspect visually." },
                  { label: "Cracks and fractures", detail: "Fine cracks in enamel can be difficult to detect without magnification. An intraoral camera can help make these visible for further assessment." },
                  { label: "Worn or damaged restorations", detail: "Old fillings, crowns, or other restorations can chip, crack, or begin to break down over time. The camera allows us to document the current condition and monitor changes over time." },
                  { label: "Gum tissue appearance", detail: "The condition of the gum tissue — whether it appears healthy, inflamed, or otherwise changed — can be captured and discussed with you directly." },
                ].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                    <span><strong class="text-[var(--color-brand-primary)]">{item.label}:</strong> {item.detail}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- How it helps patients -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Seeing what the dentist sees
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                One of the practical benefits of intraoral cameras is that they allow us to share our findings with you directly. Rather than relying on descriptions alone, we can show you an image of the area we are concerned about — which often makes it easier to understand what is happening and to ask questions.
              </p>
              <p>
                Images can also be saved to your records and compared at future appointments, which helps us track how a particular area is changing over time. This is particularly useful when monitoring a tooth or area that does not yet require treatment but warrants observation.
              </p>
            </div>
          </div>

          <!-- Alongside other tools -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-accent)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Used alongside other diagnostic tools</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  Intraoral cameras show the surfaces of the teeth and gums, but they cannot see between teeth or below the gumline the way x-rays can. They are most useful as a complement to a thorough clinical exam and appropriate imaging — giving a clearer picture of conditions that are visible on the surface, while other tools address what lies beneath.
                </p>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or book online — new patients welcome.</p>
            <a href="/book" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="tel:+13063747272" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">306.374.7272</a>
          </div>

          <!-- Sibling services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Diagnostic Services</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to get started?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> or book online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book" class="btn btn-primary btn-lg">Book an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
