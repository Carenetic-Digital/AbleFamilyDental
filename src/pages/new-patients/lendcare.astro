---
import BaseLayout from '../../layouts/BaseLayout.astro';

---

<BaseLayout
  title="Patient Financing with LendCare | Wildwood Dental Clinic Saskatoon"
  description="Wildwood Dental Clinic offers patient financing through LendCare. Spread the cost of dental treatment over time with flexible monthly payment plans."
>

  <!-- ============================================================
       HERO — light gradient, two-column (matches design)
       ============================================================ -->
  <section style="background: linear-gradient(165deg,#f6f8fb 0%,#eef2f7 100%); padding: 70px 0 76px;">
    <div class="container-wide" style="display: grid; grid-template-columns: 1fr 1.02fr; gap: 64px; align-items: center;">

      <!-- Left: copy -->
      <div>
        <div style="display: inline-flex; align-items: center; gap: 13px; margin-bottom: 24px;">
          <span style="width:40px;height:40px;border-radius:50%;background:var(--color-brand-primary);display:flex;align-items:center;justify-content:center;color:#fff;flex:0 0 auto;">
            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg>
          </span>
          <span class="eyebrow" style="color:var(--color-brand-accent);">Patient Financing</span>
        </div>
        <h1 class="font-display" style="font-size: clamp(38px,5vw,56px); font-weight:800; letter-spacing:-.01em; line-height:1.1; color:var(--color-brand-primary); position:relative; display:inline-block;">
          Flexible payment<span aria-hidden="true" style="display:inline-block;width:11px;height:11px;border-radius:50%;background:#e3392b;vertical-align:top;margin:6px 0 0 16px;"></span><br/>options with LendCare
        </h1>
        <p style="margin-top:26px;font-size:17px;color:#566373;max-width:480px;line-height:1.75;">
          We offer patient financing through LendCare, a Canadian healthcare financing provider. LendCare allows you to spread the cost of dental treatment over time with flexible payment plans, making it easier to move forward with recommended care without having to pay everything upfront.
        </p>
      </div>

      <!-- Right: image card with overlay -->
      <div style="position:relative;border-radius:14px;overflow:hidden;box-shadow:0 24px 56px rgba(20,54,95,.16);">
        <img
          src="/images/services/content-consultation.jpg"
          alt="Patient consultation at Wildwood Dental Clinic"
          width="700"
          height="440"
          loading="eager"
          decoding="async"
          style="width:100%;height:440px;object-fit:cover;display:block;"
        />
        <div style="position:absolute;left:18px;right:18px;bottom:18px;background:#fff;border-radius:12px;box-shadow:0 12px 30px rgba(20,54,95,.18);display:flex;align-items:center;gap:16px;padding:14px 16px;">
          <span style="width:46px;height:46px;border-radius:50%;background:linear-gradient(180deg,#eeb24f,#d8901f);display:flex;align-items:center;justify-content:center;color:#fff;flex:0 0 auto;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M2 20h20"/></svg>
          </span>
          <span style="font-size:14.5px;color:var(--color-brand-primary);font-weight:700;line-height:1.35;flex:1;">Apply online in minutes<br/>or ask our team in clinic.</span>
          <a
            href="https://applicant.myfrontline.app/LendCare/3HNXQ6HZ5AV3"
            target="_blank"
            rel="noopener noreferrer"
            style="display:inline-flex;align-items:center;gap:8px;background:var(--color-brand-primary);color:#fff;padding:12px 18px;border-radius:7px;font-weight:700;font-size:14px;text-decoration:none;white-space:nowrap;transition:filter .18s ease;"
            onmouseover="this.style.filter='brightness(1.12)'" onmouseout="this.style.filter=''"
          >
            Apply with LendCare
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ============================================================
       FAQ ACCORDION
       ============================================================ -->
  <section style="padding: 64px 0 18px;">
    <div class="container-wide">
      <div style="display:flex;flex-direction:column;gap:16px;">

        <details class="lc-faq lc-faq--first" open>
          <summary>
            <span class="lc-pm" aria-hidden="true"></span>
            <span class="lc-q">How does LendCare work?</span>
            <svg class="lc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="lc-ans lc-ans--bordered">Applying for financing is simple. You can complete an application online or ask our team for assistance during your visit. If approved, you'll be able to select a payment plan that fits your budget and pay for treatment over time rather than all at once.</div>
        </details>

        <details class="lc-faq">
          <summary>
            <span class="lc-pm" aria-hidden="true"></span>
            <span class="lc-q">What treatments can be financed?</span>
            <svg class="lc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="lc-ans">Financing can be applied to a wide range of dental treatments, from restorative and cosmetic care to major procedures such as crowns, implants, orthodontics, and oral surgery. If you're unsure whether your treatment qualifies, our team is happy to confirm during your visit.</div>
        </details>

        <details class="lc-faq">
          <summary>
            <span class="lc-pm" aria-hidden="true"></span>
            <span class="lc-q">Is approval guaranteed?</span>
            <svg class="lc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="lc-ans">Approval is not guaranteed. LendCare reviews each application individually, and financing is subject to credit approval. Many patients do qualify, and our team can help you start an application to find out which options are available to you.</div>
        </details>

        <details class="lc-faq">
          <summary>
            <span class="lc-pm" aria-hidden="true"></span>
            <span class="lc-q">Can I make monthly payments?</span>
            <svg class="lc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="lc-ans">Yes. LendCare offers flexible monthly payment plans so you can spread the cost of treatment over time instead of paying everything upfront. Once you're approved, you'll be able to choose a plan that fits your budget.</div>
        </details>

        <details class="lc-faq">
          <summary>
            <span class="lc-pm" aria-hidden="true"></span>
            <span class="lc-q">What are the payment terms?</span>
            <svg class="lc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="lc-ans">Payment terms vary depending on the amount financed and your individual qualifications. Term lengths, rates, and monthly amounts are presented to you before you accept any offer, so you can decide what works best for you.</div>
        </details>

        <details class="lc-faq">
          <summary>
            <span class="lc-pm" aria-hidden="true"></span>
            <span class="lc-q">Who can I contact if I have questions?</span>
            <svg class="lc-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="lc-ans">Our team is always happy to help. Call us at 306.374.7272 or ask at your next appointment, and we'll walk you through the financing options and answer any questions about applying through LendCare.</div>
        </details>

      </div>
    </div>
  </section>

  <!-- ============================================================
       WE'RE HERE TO HELP
       ============================================================ -->
  <section style="padding: 42px 0 0;">
    <div class="container-wide">
      <div style="background:linear-gradient(165deg,#fbf2e0,#f7ecd6);border:1px solid #f0e2c6;border-radius:14px;padding:36px 44px;display:grid;grid-template-columns:1.4fr 1fr;gap:40px;align-items:center;">

        <div style="display:flex;align-items:flex-start;gap:22px;">
          <span style="width:64px;height:64px;border-radius:50%;border:2px solid var(--color-brand-accent);color:var(--color-brand-accent-hover);display:flex;align-items:center;justify-content:center;flex:0 0 auto;background:rgba(255,255,255,.4);">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 5.5c-1.5-1.3-3.2-2-5-2C4 3.5 2 5.7 2 9c0 2.4.9 4.6 1.7 7 .6 1.8 1 4 2.3 4 1.2 0 1.3-2 1.8-3.6.4-1.3.8-2.4 2.2-2.4s1.8 1.1 2.2 2.4c.5 1.6.6 3.6 1.8 3.6 1.3 0 1.7-2.2 2.3-4 .8-2.4 1.7-4.6 1.7-7 0-3.3-2-5.5-5-5.5-1.8 0-3.5.7-5 2Z"/>
            </svg>
          </span>
          <div>
            <h2 class="font-display" style="font-size:26px;color:var(--color-brand-primary);font-weight:700;">We're here to help.</h2>
            <p style="margin-top:10px;color:#6a614c;font-size:15px;line-height:1.65;max-width:460px;">Have questions about financing options or whether your treatment may qualify? Our team is happy to walk you through the process and help you find the best solution for your needs.</p>
          </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:20px;border-left:1px solid rgba(200,136,31,.3);padding-left:40px;">
          <div style="display:flex;align-items:center;gap:14px;">
            <span style="width:42px;height:42px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;color:var(--color-brand-accent-hover);flex:0 0 auto;box-shadow:0 4px 12px rgba(200,136,31,.16);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
            </span>
            <div>
              <b class="font-display" style="display:block;color:var(--color-brand-primary);font-size:16px;font-weight:700;">Call us</b>
              <a href="tel:+13063747272" class="font-display" style="color:var(--color-brand-primary);font-size:18px;font-weight:700;text-decoration:none;">306.374.7272</a>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:14px;">
            <span style="width:42px;height:42px;border-radius:50%;background:#fff;display:flex;align-items:center;justify-content:center;color:var(--color-brand-accent-hover);flex:0 0 auto;box-shadow:0 4px 12px rgba(200,136,31,.16);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/></svg>
            </span>
            <div>
              <b class="font-display" style="display:block;color:var(--color-brand-primary);font-size:16px;font-weight:700;">Book an appointment</b>
              <span style="color:#6a614c;font-size:14px;">We're here when you're ready.</span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       DISCLAIMER
       ============================================================ -->
  <section style="padding: 24px 0 70px;">
    <div class="container-wide">
      <div style="background:linear-gradient(165deg,#eef4fc,#e7f0fa);border:1px solid #dbe7f5;border-radius:12px;padding:24px 30px;display:flex;align-items:center;gap:20px;">
        <span style="width:46px;height:46px;border-radius:50%;background:var(--color-brand-primary);display:flex;align-items:center;justify-content:center;color:var(--color-brand-accent-soft);flex:0 0 auto;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
        </span>
        <p style="font-size:14px;color:#4f6076;line-height:1.6;">Financing is provided by LendCare and is subject to credit approval. Terms, conditions, and rates vary based on individual qualifications. Please review all financing documents carefully before accepting any financing offer.</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* FAQ accordion */
  .lc-faq {
    border: 1px solid #e3ebf3;
    border-radius: 10px;
    background: #fff;
    overflow: hidden;
    transition: box-shadow .2s ease, border-color .2s ease;
  }
  .lc-faq[open] {
    box-shadow: 0 16px 38px rgba(20,54,95,.08);
    border-color: #d6e2ef;
  }
  .lc-faq--first[open] {
    background: linear-gradient(180deg,#f6f9fd,#fbfcfe);
  }
  .lc-faq summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 22px 26px;
    font-family: var(--font-display, 'Playfair Display', Georgia, serif);
    font-weight: 700;
    color: var(--color-brand-primary);
    font-size: 18px;
  }
  .lc-faq summary::-webkit-details-marker { display: none; }
  .lc-q { flex: 1; }
  .lc-chev {
    width: 20px;
    height: 20px;
    color: #6c7886;
    flex: 0 0 auto;
    transition: transform .22s ease;
  }
  .lc-faq[open] .lc-chev { transform: rotate(180deg); }
  .lc-ans {
    padding: 0 26px 24px 74px;
    color: #586675;
    font-size: 15.5px;
    line-height: 1.75;
    max-width: 920px;
  }
  .lc-ans--bordered {
    border-left: 3px solid var(--color-brand-accent);
    padding-left: 22px;
    margin-left: 52px;
  }
  /* Plus/minus icon */
  .lc-pm {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-brand-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    position: relative;
  }
  .lc-pm::before, .lc-pm::after {
    content: "";
    position: absolute;
    background: #fff;
    border-radius: 2px;
  }
  .lc-pm::before { width: 12px; height: 2px; }
  .lc-pm::after  { width: 2px; height: 12px; transition: transform .22s ease, opacity .22s ease; }
  .lc-faq[open] .lc-pm::after { transform: scaleY(0); opacity: 0; }

  /* Mobile stacking */
  @media (max-width: 960px) {
    .lc-hero-grid  { grid-template-columns: 1fr !important; }
    .lc-help-grid  { grid-template-columns: 1fr !important; }
    .lc-office-grid{ grid-template-columns: 1fr !important; }
    .lc-help-actions { border-left: none !important; padding-left: 0 !important; border-top: 1px solid rgba(200,136,31,.3); padding-top: 24px; }
  }
  @media (max-width: 560px) {
    .lc-hero h1 { font-size: 34px !important; }
  }
</style>
