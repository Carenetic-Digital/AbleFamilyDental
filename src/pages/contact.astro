---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | Wildwood Dental Clinic, Saskatoon, SK"
  description="Call 306.374.7272, email, or visit Wildwood Dental Clinic at 105 - 1526 8th Street East in Saskatoon. Request an appointment or send us a message."
>

  <!-- ============================================================
       HERO BANNER
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <picture>
        <!-- TODO(Projects Team): no patient-consult photo was supplied; using exterior as interim (decorative panel). Swap in a real image. -->
        <source srcset="/images/hero/wildwood-exterior.webp" type="image/webp" />
        <img
          src="/images/hero/wildwood-exterior.png"
          alt=""
          width="1086"
          height="1448"
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover"
        />
      </picture>
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Contact</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Get in Touch</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Contact Wildwood Dental Clinic
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Whether you have a question, want to book an appointment, or need to reach us in an emergency. We're here to help.
      </p>
    </div>
  </section>

  <!-- ============================================================
       CONTACT QUICK-INFO ROW
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Phone card -->
        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Call Us</p>
            <a
              href="tel:+13063747272"
              class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors tabular-nums"
            >
              306.374.7272
            </a>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Mon–Fri, during office hours</p>
          </div>
        </div>

        <!-- Email card -->
        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Email Us</p>
            <a
              href="mailto:reception@wildwooddentalclinic.com"
              class="font-semibold text-sm text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors break-all"
            >
              reception@wildwooddentalclinic.com
            </a>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">We respond within one business day</p>
          </div>
        </div>

        <!-- Location card -->
        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Find Us</p>
            <a
              href="https://maps.app.goo.gl/AnBTQPRQ86JRw9T89"
              target="_blank"
              rel="noopener noreferrer"
              class="font-semibold text-[var(--color-brand-primary)] leading-snug hover:text-[var(--color-brand-accent-hover)] transition-colors"
            >
              105 – 1526 8th Street East<br />Saskatoon, SK
            </a>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Between Preston and Cumberland</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT: FORM + HOURS / MAP
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">

        <!-- LEFT: Contact form -->
        <div class="bg-white rounded-2xl shadow-xl p-8 border border-[var(--color-border-soft)]">
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
            Send Us a Message
          </h2>
          <script type="text/javascript" src="https://form.jotform.com/jsform/202434228778056" is:inline></script>
          <p class="mt-4 text-sm text-[var(--color-text-muted)] leading-relaxed">
            For urgent dental concerns, please call us directly at{' '}
            <a href="tel:+13063747272" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)]">306.374.7272</a>.
          </p>
        </div>

        <!-- RIGHT: Hours + Map -->
        <div class="flex flex-col gap-6">

          <!-- Office Hours card -->
          <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex items-center gap-3 mb-5">
              <svg class="text-[var(--color-brand-primary)] shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <h2 class="font-display font-semibold text-xl text-[var(--color-brand-primary)]">Office Hours</h2>
            </div>

            <dl class="space-y-0">

              <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] py-3">
                <dt class="text-[var(--color-text)] font-medium text-sm">Monday</dt>
                <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">7:30 am – 4:30 pm</dd>
              </div>

              <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] py-3">
                <dt class="text-[var(--color-text)] font-medium text-sm">Tuesday</dt>
                <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">7:30 am – 4:30 pm</dd>
              </div>

              <!-- Wednesday, extended hours highlight -->
              <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] py-3 bg-[var(--color-surface-alt)] -mx-6 px-6 rounded-lg">
                <dt class="flex items-center gap-2 font-medium text-sm text-[var(--color-brand-primary)]">
                  Wednesday
                </dt>
                <dd class="tabular-nums text-sm font-semibold text-[var(--color-brand-primary)]">7:30 am – 8:30 pm</dd>
              </div>

              <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] py-3">
                <dt class="text-[var(--color-text)] font-medium text-sm">Thursday</dt>
                <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">7:30 am – 4:30 pm</dd>
              </div>

              <div class="flex justify-between items-center py-3">
                <dt class="text-[var(--color-text)] font-medium text-sm">Friday</dt>
                <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">7:30 am – 4:00 pm</dd>
              </div>

            </dl>
          </div>

          <!-- Map card -->
          <div class="bg-[#c8d8ea] rounded-2xl overflow-hidden shadow-xl">
            <iframe
              id="map-iframe"
              src="https://www.google.com/maps?q=Wildwood+Dental+Clinic%2C+1526+8th+Street+East%2C+Saskatoon%2C+SK&output=embed"
              width="100%"
              height="250"
              style="border:0;"
              loading="lazy"
              allowfullscreen=""
              title="Wildwood Dental Clinic location on Google Maps"
            ></iframe>
            <div class="p-4 flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-[var(--color-brand-primary)]">105 – 1526 8th Street East</p>
                <p class="text-sm text-[var(--color-text-muted)]">Saskatoon, SK&nbsp; S7H 0T3</p>
              </div>
              <a
                href="https://maps.google.com/?q=105-1526+8th+Street+East+Saskatoon+SK"
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors whitespace-nowrap"
              >
                Get Directions →
              </a>
            </div>
          </div>

        </div>
        <!-- /RIGHT -->

      </div>
    </div>
  </section>

  <!-- ============================================================
       VISIT INFORMATION
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="mb-8">
        <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)]">Visit Information</h2>
        <p class="mt-2 text-[var(--color-text-muted)]">Everything you need to know before your visit.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">

        {[
          {
            label: "Accepting New Patients",
            note: "We welcome new patients and families.",
            positive: true,
            icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>`,
          },
          {
            label: "Direct Billing Available",
            note: "We bill most major insurance carriers directly.",
            positive: true,
            icon: `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`,
          },
          {
            label: "Parking Available",
            note: "On-site parking is available for patients.",
            positive: true,
            icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>`,
          },
          {
            label: "Wheelchair-Accessible Entrance",
            note: "Our entrance is fully accessible.",
            positive: true,
            icon: `<circle cx="12" cy="5" r="1"/><path d="M9 20l1-5h4l1 5"/><path d="M8 15l1-5h6l1 5"/><path d="M6 20a5 5 0 0 1 5-5"/>`,
          },
          {
            label: "Wheelchair-Accessible Parking",
            note: "Designated accessible parking spaces on site.",
            positive: true,
            icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="12" cy="8" r="1"/><path d="M10 14l1-4h2l1 4"/><path d="M9 14h6"/>`,
          },
          {
            label: "Accessible Washroom",
            note: "Our washroom is wheelchair accessible.",
            positive: true,
            icon: `<path d="M12 22V12"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><circle cx="12" cy="5" r="3"/>`,
          },
        ].map(item => (
          <div class="bg-white rounded-2xl p-5 border border-[var(--color-border-soft)] flex items-start gap-4">
            <div class={`w-10 h-10 rounded-full flex items-center justify-center shrink-0 ${item.positive ? 'bg-[var(--color-brand-primary)]' : 'bg-[var(--color-surface-alt)]'}`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={item.positive ? 'white' : 'var(--color-text-muted)'} stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <div>
              <p class="font-semibold text-sm text-[var(--color-brand-primary)]">{item.label}</p>
              <p class="mt-0.5 text-xs text-[var(--color-text-muted)] leading-relaxed">{item.note}</p>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- ============================================================
       EMERGENCY DENTAL NOTE
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-alt)]">
    <div class="container-wide">
      <div class="max-w-2xl mx-auto text-center">

        <div class="w-14 h-14 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mx-auto mb-5">
          <svg width="26" height="26" viewBox="22.5 22.5 30 30" aria-hidden="true">
            <path fill="white" d="M 44.90625 43.402344 C 44.820312 43.097656 44.726562 42.789062 44.621094 42.476562 C 44.621094 42.46875 44.617188 42.460938 44.613281 42.453125 C 44.015625 40.984375 43.800781 39.574219 43.96875 38.265625 C 44.117188 37.402344 44.183594 36.390625 44.15625 35.457031 L 47.261719 32.339844 L 47.691406 32.769531 C 47.898438 32.980469 48.175781 33.085938 48.449219 33.085938 C 48.722656 33.085938 48.996094 32.980469 49.203125 32.769531 C 49.40625 32.570312 49.515625 32.300781 49.515625 32.011719 C 49.515625 31.726562 49.40625 31.457031 49.203125 31.253906 L 48.164062 30.207031 L 50.523438 27.839844 L 50.609375 27.925781 C 50.808594 28.128906 51.078125 28.238281 51.363281 28.238281 C 51.648438 28.238281 51.917969 28.128906 52.121094 27.925781 C 52.320312 27.722656 52.433594 27.453125 52.433594 27.167969 C 52.433594 26.878906 52.320312 26.609375 52.121094 26.40625 L 50.257812 24.539062 C 49.839844 24.121094 49.164062 24.121094 48.746094 24.539062 C 48.546875 24.742188 48.433594 25.011719 48.433594 25.296875 C 48.433594 25.585938 48.546875 25.855469 48.746094 26.054688 L 48.832031 26.140625 L 46.472656 28.511719 L 45.433594 27.464844 C 45.015625 27.046875 44.335938 27.046875 43.917969 27.464844 C 43.503906 27.886719 43.503906 28.566406 43.917969 28.984375 L 44.347656 29.414062 L 42.769531 31 C 42.003906 30.203125 40.949219 29.9375 39.6875 30.226562 C 38.765625 30.4375 38.105469 30.859375 37.523438 31.230469 C 37.027344 31.542969 36.5625 31.839844 35.992188 31.988281 C 35.988281 31.992188 35.984375 31.992188 35.984375 31.992188 C 35.890625 32.015625 35.796875 32.039062 35.699219 32.054688 L 35.699219 27.636719 C 35.699219 26.644531 35.058594 25.808594 34.105469 25.550781 L 23.089844 22.589844 C 22.964844 22.554688 22.832031 22.582031 22.730469 22.660156 C 22.628906 22.738281 22.566406 22.859375 22.566406 22.992188 L 22.566406 29.597656 C 22.566406 29.804688 22.722656 29.984375 22.929688 30.011719 L 30.457031 30.980469 L 31.125 32.640625 C 30.