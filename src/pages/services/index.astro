---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: "Preventive",
    href: "/services/preventive",
    blurb: "Cleanings, exams, and everyday care that keeps small issues small.",
    services: [
      { name: "Cleanings & Check-ups", href: "/services/preventive/cleanings-exams" },
      { name: "Fluoride Treatments", href: "/services/preventive/fluoride" },
      { name: "Dental Sealants", href: "/services/preventive/sealants" },
      { name: "Mouthguards & Sport Guards", href: "/services/preventive/guards" },
      { name: "Patient Comfort Techniques", href: "/services/preventive/comfort" },
    ],
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  },
  {
    title: "Emergency",
    href: "/services/emergency",
    blurb: "Same-day care for toothaches, broken teeth, and dental urgencies.",
    services: [
      { name: "Emergency Appointments", href: "/services/emergency/appointments" },
      { name: "Same-Day Care", href: "/services/emergency/same-day" },
      { name: "Toothache", href: "/services/emergency/toothache" },
      { name: "Broken Tooth", href: "/services/emergency/broken-tooth" },
      { name: "Knocked-Out Tooth", href: "/services/emergency/knocked-out-tooth" },
    ],
    icon: `<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
  },
  {
    title: "Diagnostic",
    href: "/services/diagnostic",
    blurb: "Digital imaging and screening tools that help us see the full picture.",
    services: [
      { name: "Digital X-Rays", href: "/services/diagnostic/x-rays" },
      { name: "Diagnostic Images & Digital X-Rays", href: "/services/diagnostic/diagnostic-images" },
      { name: "Intraoral Cameras", href: "/services/diagnostic/intraoral-cameras" },
    ],
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`,
  },
  {
    title: "Children's Dentistry",
    href: "/services/childrens",
    blurb: "Gentle, age-appropriate dental care for infants, children, and teens.",
    services: [
      { name: "Exams & Cleanings", href: "/services/childrens/exams-cleanings" },
      { name: "Infant Oral Care", href: "/services/childrens/infant-oral-care" },
      { name: "Fluoride", href: "/services/childrens/fluoride" },
      { name: "Sealants", href: "/services/childrens/sealants" },
      { name: "X-Rays", href: "/services/childrens/x-rays" },
      { name: "Space Maintainers", href: "/services/childrens/space-maintainers" },
    ],
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
  {
    title: "Orthodontics",
    href: "/services/orthodontics",
    blurb: "Teeth straightening options for patients of all ages.",
    services: [
      { name: "Invisalign", href: "/services/orthodontics/invisalign" },
      { name: "Invisalign, Retainers & Braces", href: "/services/orthodontics/retainers-braces" },
    ],
    icon: `<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/><path d="M8 12h8M12 8v8"/>`,
  },
  {
    title: "Sedation Dentistry",
    href: "/services/sedation",
    blurb: "Nitrous oxide and oral sedation options for patients with dental anxiety or those undergoing longer procedures.",
    services: [
      { name: "Nitrous Oxide (Laughing Gas)", href: "/services/sedation/nitrous-oxide" },
      { name: "Oral Sedation", href: "/services/sedation/oral-sedation" },
      { name: "IV Sedation", href: "/services/sedation/iv-sedation" },
    ],
    icon: `<path d="M4.5 9.5V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v4.5"/><path d="M4.5 9.5a7.5 7.5 0 0 0 15 0"/><path d="M12 12v7"/><path d="M9 19h6"/>`,
  },
  {
    title: "Restorative",
    href: "/services/restorative",
    blurb: "Repairing and rebuilding teeth back to full function and appearance.",
    services: [
      { name: "Fillings", href: "/services/restorative/fillings" },
      { name: "Crowns & Bridges", href: "/services/restorative/crowns-bridges" },
      { name: "Inlays & Onlays", href: "/services/restorative/inlays-onlays" },
    ],
    icon: `<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>`,
  },
  {
    title: "Prosthodontic Care",
    href: "/services/prosthodontics",
    blurb: "Custom restorations that replace missing or worn teeth, from crowns to full dentures.",
    services: [
      { name: "Crowns & Bridges", href: "/services/prosthodontics/crowns-bridges" },
      { name: "Full & Partial Dentures", href: "/services/prosthodontics/dentures" },
      { name: "Implant-Supported Restorations", href: "/services/prosthodontics/implant-restorations" },
      { name: "Inlays & Onlays", href: "/services/prosthodontics/inlays-onlays" },
      { name: "Replacing Worn Dental Work", href: "/services/prosthodontics/replacement" },
    ],
    icon: `<path d="M2 4l3 12h14l3-12-6 7-4-7-4 7-6-7z"/>`,
  },
  {
    title: "Oral Surgery",
    href: "/services/oral-surgery",
    blurb: "Extractions, implants, and surgical care performed in-office.",
    services: [
      { name: "Tooth Extractions", href: "/services/oral-surgery/extractions" },
      { name: "Wisdom Teeth", href: "/services/oral-surgery/wisdom-teeth" },
      { name: "Dental Implants", href: "/services/oral-surgery/implants" },
    ],
    icon: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.93 12 19.79 19.79 0 0 1 1.87 3.42 2 2 0 0 1 3.84 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>`,
  },
  {
    title: "Periodontal",
    href: "/services/periodontal",
    blurb: "Diagnosis and treatment of gum disease and supporting bone health.",
    services: [
      { name: "Scaling & Root Planing", href: "/services/periodontal/scaling-root-planing" },
    ],
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
  {
    title: "Endodontics",
    href: "/services/endodontics",
    blurb: "Root canal treatment and care for the inner structures of your teeth.",
    services: [
      { name: "Root Canal Treatment", href: "/services/endodontics/root-canal" },
      { name: "Traumatic Injuries", href: "/services/endodontics/traumatic-injuries" },
      { name: "Cracked Tooth", href: "/services/endodontics/cracked-tooth" },
      { name: "Internal Bleaching", href: "/services/endodontics/internal-bleaching" },
    ],
    icon: `<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/>`,
  },
  {
    title: "Cosmetic",
    href: "/services/cosmetic",
    blurb: "Improving the look of your smile with safe, effective treatments.",
    services: [
      { name: "Teeth Whitening", href: "/services/cosmetic/whitening" },
      { name: "Porcelain Veneers", href: "/services/cosmetic/veneers" },
      { name: "Smile Makeovers", href: "/services/cosmetic/smile-makeovers" },
      { name: "Dental Bonding", href: "/services/cosmetic/bonding" },
    ],
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  },
  {
    title: "TMJ & Jaw",
    href: "/services/tmj",
    blurb: "Assessment and management of jaw pain, bite problems, and sleep issues.",
    services: [
      { name: "TMJ Diagnosis", href: "/services/tmj/diagnosis" },
      { name: "Botulinum Toxin for Jaw Pain", href: "/services/tmj/botox" },
      { name: "Night Guards", href: "/services/tmj/night-guards" },
      { name: "Bite Correction", href: "/services/tmj/bite-correction" },
    ],
    icon: `<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/>`,
  },
  {
    title: "IV Sedation (IVS)",
    href: "/services/ivs",
    blurb: "Deeper sedation support for anxious patients, sensitive gag reflexes, or longer procedures.",
    services: [
      { name: "Relaxation for Nervous Patients", href: "/services/ivs/relaxation" },
      { name: "Sensitive Teeth or Gag Reflex", href: "/services/ivs/sensitive-teeth" },
      { name: "Stress-Free Visits", href: "/services/ivs/stress-free" },
      { name: "Monitoring & Safe Sedation Care", href: "/services/ivs/monitoring" },
    ],
    icon: `<path d="M4.5 9.5V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v4.5"/><circle cx="12" cy="16" r="4"/><path d="M12 12v-2"/>`,
  },
];
---

<BaseLayout
  title="Dental Services | Able Family Dental Lethbridge"
  description="Comprehensive dental care in Lethbridge, including preventive, emergency, restorative, cosmetic, orthodontic, periodontal, and oral surgery services."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-16 lg:py-20">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Services</span>
      </nav>
      <p class="eyebrow text-white">Comprehensive Dental Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Our Dental Services
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        From routine checkups to full-mouth restorations, Able Family Dental offers care for the whole family, all under one roof on 5th Street South in Lethbridge.
      </p>
    </div>
  </section>

  <!-- ============================================================
       SERVICE CATEGORY CARDS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">
        {categories.map(cat => (
          <div class="bg-white rounded-2xl shadow-sm p-7 border border-[var(--color-border-soft)] flex flex-col hover:shadow-md transition-shadow">
            <!-- Icon + Title -->
            <div class="flex items-center gap-3 mb-3">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={cat.icon} />
              </div>
              <h2 class="font-display font-semibold text-[length:var(--text-xl)] text-[var(--color-brand-primary)]">
                {cat.title}
              </h2>
            </div>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed mb-4">{cat.blurb}</p>
            <!-- Service links -->
            <ul class="space-y-1.5 mb-5 flex-1">
              {cat.services.map(svc => (
                <li>
                  <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text)] hover:text-[var(--color-brand-accent)] transition-colors group">
                    <span class="w-1 h-1 rounded-full bg-[var(--color-brand-accent)] shrink-0 group-hover:scale-125 transition-transform" aria-hidden="true"></span>
                    {svc.name}
                  </a>
                </li>
              ))}
            </ul>
            <!-- Explore link -->
            <a href={cat.href} class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors mt-auto">
              Explore {cat.title}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       EMERGENCY CALLOUT
       ============================================================ -->
  <section class="bg-[var(--color-surface-alt)] py-14">
    <div class="container-wide">
      <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-10">
        <div class="w-16 h-16 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
            <line x1="12" y1="9" x2="12" y2="13"/>
            <line x1="12" y1="17" x2="12.01" y2="17"/>
          </svg>
        </div>
        <div class="text-center sm:text-left flex-1">
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
            Dental Emergency?
          </h2>
          <p class="mt-2 text-[var(--color-text-muted)] leading-relaxed">
            Call us immediately at <a href="tel:+14033277202" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent)] transition-colors">403.327.7202</a>, we will do our best to see you the same day.
          </p>
        </div>
        <div class="shrink-0">
          <a href="tel:+14033277202" class="btn btn-primary btn-lg whitespace-nowrap">Call Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to get started?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
