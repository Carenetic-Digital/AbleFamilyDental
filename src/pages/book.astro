---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Book an Appointment | Wildwood Dental Clinic — Saskatoon"
  description="Schedule your dental appointment at Wildwood Dental Clinic on 8th Street East in Saskatoon. New and existing patients welcome. Call 306.374.7272 or request online."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-14 lg:py-18">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Book an Appointment</span>
      </nav>
      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
        <div>
          <p class="eyebrow text-[var(--color-brand-accent-soft)]">Wildwood Dental Clinic</p>
          <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white">
            Book an Appointment
          </h1>
          <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
            Request your dental visit online. We'll confirm your appointment by phone or email within one business day.
          </p>
        </div>
        <a
          href="tel:+13063747272"
          class="hidden lg:inline-flex items-center gap-3 bg-white/10 hover:bg-white/20 transition-colors rounded-xl px-6 py-4 text-white shrink-0"
        >
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div>
            <p class="text-xs text-[var(--color-text-on-dark-muted)]">Prefer to call?</p>
            <p class="font-semibold tabular-nums text-lg leading-tight">306.374.7272</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       MAIN: FORM + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_340px] gap-10 items-start">

        <!-- =====================================================
             LEFT: BOOKING FORM
             ===================================================== -->
        <div class="bg-white rounded-2xl shadow-xl border border-[var(--color-border-soft)] overflow-hidden">

          <!-- Form header -->
          <div class="bg-[var(--color-brand-primary)] px-8 py-5 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-white/15 flex items-center justify-center shrink-0">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div>
              <h2 class="font-display font-semibold text-white text-lg leading-tight">Appointment Request</h2>
              <p class="text-xs text-[var(--color-text-on-dark-muted)]">We'll confirm your preferred time within one business day</p>
            </div>
          </div>

          <form method="post" action="#" class="p-8 space-y-8" novalidate>

            <!-- STEP 1: Patient Type -->
            <fieldset>
              <legend class="font-display font-semibold text-[var(--color-brand-primary)] text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white text-xs font-bold flex items-center justify-center shrink-0">1</span>
                Are you a new or existing patient?
              </legend>
              <div class="grid sm:grid-cols-2 gap-3">
                <label class="relative flex items-start gap-3 p-4 rounded-xl border-2 border-[var(--color-border)] cursor-pointer hover:border-[var(--color-brand-accent)] transition-colors has-[:checked]:border-[var(--color-brand-accent)] has-[:checked]:bg-[var(--color-surface-alt)]">
                  <input type="radio" name="patient_type" value="new" class="mt-0.5 accent-[var(--color-brand-accent)] shrink-0" required />
                  <div>
                    <span class="font-semibold text-sm text-[var(--color-brand-primary)] block">New Patient</span>
                    <span class="text-xs text-[var(--color-text-muted)]">First visit to Wildwood Dental Clinic</span>
                  </div>
                </label>
                <label class="relative flex items-start gap-3 p-4 rounded-xl border-2 border-[var(--color-border)] cursor-pointer hover:border-[var(--color-brand-accent)] transition-colors has-[:checked]:border-[var(--color-brand-accent)] has-[:checked]:bg-[var(--color-surface-alt)]">
                  <input type="radio" name="patient_type" value="existing" class="mt-0.5 accent-[var(--color-brand-accent)] shrink-0" />
                  <div>
                    <span class="font-semibold text-sm text-[var(--color-brand-primary)] block">Existing Patient</span>
                    <span class="text-xs text-[var(--color-text-muted)]">I've been seen here before</span>
                  </div>
                </label>
              </div>
            </fieldset>

            <div class="h-px bg-[var(--color-border-soft)]"></div>

            <!-- STEP 2: Appointment Type -->
            <fieldset>
              <legend class="font-display font-semibold text-[var(--color-brand-primary)] text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white text-xs font-bold flex items-center justify-center shrink-0">2</span>
                What type of appointment do you need?
              </legend>
              <div class="grid sm:grid-cols-2 gap-3">
                {[
                  { value: "checkup-cleaning", label: "Routine Checkup & Cleaning", desc: "Exam, x-rays if due, professional cleaning" },
                  { value: "new-patient-exam", label: "New Patient Exam", desc: "Comprehensive first visit assessment" },
                  { value: "emergency", label: "Dental Emergency", desc: "Tooth pain, broken tooth, or swelling" },
                  { value: "cosmetic-consult", label: "Cosmetic Consultation", desc: "Whitening, veneers, Invisalign, bonding" },
                  { value: "specific-treatment", label: "Specific Treatment", desc: "Follow-up or previously discussed treatment" },
                  { value: "children", label: "Children's Appointment", desc: "Exam and cleaning for a child" },
                ].map(opt => (
                  <label class="relative flex items-start gap-3 p-4 rounded-xl border-2 border-[var(--color-border)] cursor-pointer hover:border-[var(--color-brand-accent)] transition-colors has-[:checked]:border-[var(--color-brand-accent)] has-[:checked]:bg-[var(--color-surface-alt)]">
                    <input type="radio" name="appointment_type" value={opt.value} class="mt-0.5 accent-[var(--color-brand-accent)] shrink-0" required />
                    <div>
                      <span class="font-semibold text-sm text-[var(--color-brand-primary)] block leading-snug">{opt.label}</span>
                      <span class="text-xs text-[var(--color-text-muted)]">{opt.desc}</span>
                    </div>
                  </label>
                ))}
              </div>
            </fieldset>

            <div class="h-px bg-[var(--color-border-soft)]"></div>

            <!-- STEP 3: Your Information -->
            <fieldset>
              <legend class="font-display font-semibold text-[var(--color-brand-primary)] text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white text-xs font-bold flex items-center justify-center shrink-0">3</span>
                Your information
              </legend>
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="first_name" class="block text-sm font-medium text-[var(--color-text)] mb-1">First Name <span class="text-[var(--color-error)]" aria-hidden="true">*</span></label>
                  <input type="text" id="first_name" name="first_name" autocomplete="given-name" required
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)]" />
                </div>
                <div>
                  <label for="last_name" class="block text-sm font-medium text-[var(--color-text)] mb-1">Last Name <span class="text-[var(--color-error)]" aria-hidden="true">*</span></label>
                  <input type="text" id="last_name" name="last_name" autocomplete="family-name" required
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)]" />
                </div>
                <div>
                  <label for="dob" class="block text-sm font-medium text-[var(--color-text)] mb-1">Date of Birth <span class="text-[var(--color-error)]" aria-hidden="true">*</span></label>
                  <input type="date" id="dob" name="dob" autocomplete="bday" required
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)]" />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-medium text-[var(--color-text)] mb-1">Phone Number <span class="text-[var(--color-error)]" aria-hidden="true">*</span></label>
                  <input type="tel" id="phone" name="phone" autocomplete="tel" required
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)]" />
                </div>
                <div class="sm:col-span-2">
                  <label for="email" class="block text-sm font-medium text-[var(--color-text)] mb-1">Email Address <span class="text-[var(--color-error)]" aria-hidden="true">*</span></label>
                  <input type="email" id="email" name="email" autocomplete="email" required
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)]" />
                </div>
              </div>
            </fieldset>

            <div class="h-px bg-[var(--color-border-soft)]"></div>

            <!-- STEP 4: Preferred Timing -->
            <fieldset>
              <legend class="font-display font-semibold text-[var(--color-brand-primary)] text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white text-xs font-bold flex items-center justify-center shrink-0">4</span>
                When works for you?
              </legend>
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="preferred_date" class="block text-sm font-medium text-[var(--color-text)] mb-1">Preferred Date</label>
                  <input type="date" id="preferred_date" name="preferred_date"
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)]" />
                </div>
                <div>
                  <label for="alternate_date" class="block text-sm font-medium text-[var(--color-text)] mb-1">Alternate Date</label>
                  <input type="date" id="alternate_date" name="alternate_date"
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)]" />
                </div>
                <div class="sm:col-span-2">
                  <label class="block text-sm font-medium text-[var(--color-text)] mb-2">Preferred Time of Day</label>
                  <div class="flex flex-wrap gap-2">
                    {[
                      { value: "morning", label: "Morning", sub: "7:30 am – 12:00 pm" },
                      { value: "afternoon", label: "Afternoon", sub: "12:00 – 5:00 pm" },
                      { value: "evening", label: "Evening", sub: "Wed until 8:30 pm" },
                      { value: "no_pref", label: "No Preference", sub: "Any available time" },
                    ].map(t => (
                      <label class="flex items-center gap-2 px-4 py-2.5 rounded-lg border-2 border-[var(--color-border)] cursor-pointer hover:border-[var(--color-brand-accent)] transition-colors has-[:checked]:border-[var(--color-brand-accent)] has-[:checked]:bg-[var(--color-surface-alt)]">
                        <input type="radio" name="preferred_time" value={t.value} class="accent-[var(--color-brand-accent)]" />
                        <div>
                          <span class="text-sm font-semibold text-[var(--color-brand-primary)] block leading-tight">{t.label}</span>
                          <span class="text-xs text-[var(--color-text-muted)]">{t.sub}</span>
                        </div>
                      </label>
                    ))}
                  </div>
                </div>
              </div>
            </fieldset>

            <div class="h-px bg-[var(--color-border-soft)]"></div>

            <!-- STEP 5: Insurance & Notes -->
            <fieldset>
              <legend class="font-display font-semibold text-[var(--color-brand-primary)] text-base mb-4 flex items-center gap-2">
                <span class="w-6 h-6 rounded-full bg-[var(--color-brand-accent)] text-white text-xs font-bold flex items-center justify-center shrink-0">5</span>
                Insurance & additional information
              </legend>
              <div class="space-y-4">
                <div>
                  <label for="insurance" class="block text-sm font-medium text-[var(--color-text)] mb-1">Coverage Type</label>
                  <select id="insurance" name="insurance"
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)] bg-white">
                    <option value="">Select your coverage</option>
                    <option value="private">Private dental insurance</option>
                    <option value="cdcp">Canadian Dental Care Plan (CDCP)</option>
                    <option value="both">Both private insurance and CDCP</option>
                    <option value="none">No insurance / self-pay</option>
                    <option value="unsure">Not sure</option>
                  </select>
                </div>
                <div>
                  <label for="concerns" class="block text-sm font-medium text-[var(--color-text)] mb-1">Concerns or Notes <span class="text-[var(--color-text-muted)] font-normal">(optional)</span></label>
                  <textarea id="concerns" name="concerns" rows="3" placeholder="Describe any tooth pain, symptoms, or questions you'd like us to know about…"
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)] resize-none"></textarea>
                </div>
                <div>
                  <label for="referral" class="block text-sm font-medium text-[var(--color-text)] mb-1">How did you hear about us? <span class="text-[var(--color-text-muted)] font-normal">(optional)</span></label>
                  <select id="referral" name="referral"
                    class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 focus:border-[var(--color-brand-accent)] bg-white">
                    <option value="">Select an option</option>
                    <option value="google">Google search</option>
                    <option value="maps">Google Maps</option>
                    <option value="referral">Referred by a friend or family member</option>
                    <option value="facebook">Facebook</option>
                    <option value="instagram">Instagram</option>
                    <option value="passing_by">Drove or walked by</option>
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>
            </fieldset>

            <!-- Submit -->
            <div class="pt-2">
              <button type="submit"
                class="w-full btn btn-primary btn-lg flex items-center justify-center gap-2">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Submit Appointment Request
              </button>
              <p class="mt-3 text-xs text-[var(--color-text-muted)] text-center leading-relaxed">
                This is an appointment <strong>request</strong> — not a confirmed booking. We'll contact you within one business day to confirm your time.
                For urgent dental concerns, call us directly at <a href="tel:+13063747272" class="text-[var(--color-brand-primary)] font-semibold hover:text-[var(--color-brand-accent)]">306.374.7272</a>.
              </p>
            </div>

          </form>
        </div>

        <!-- =====================================================
             RIGHT: SIDEBAR
             ===================================================== -->
        <aside class="space-y-5 lg:sticky lg:top-24">

          <!-- Plan Your Visit -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <div class="flex items-center gap-2 mb-4">
              <svg class="text-[var(--color-brand-accent)] shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <h2 class="font-display font-semibold text-base text-white">Plan Your Visit</h2>
            </div>
            <div class="space-y-2 text-sm text-[var(--color-text-on-dark-muted)]">
              <p class="font-semibold text-white">Wildwood Dental Clinic</p>
              <p>105 – 1526 8th Street East<br/>Saskatoon, SK&nbsp; S7H 0T3</p>
            </div>
            <a
              href="https://maps.google.com/?q=105-1526+8th+Street+East+Saskatoon+SK"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-soft)] transition-colors"
            >
              Get Directions
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
            <div class="mt-5 pt-5 border-t border-white/10">
              <a href="tel:+13063747272" class="flex items-center gap-3 text-white hover:text-[var(--color-brand-accent-soft)] transition-colors">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <span class="font-semibold tabular-nums">306.374.7272</span>
              </a>
            </div>
          </div>

          <!-- Office Hours -->
          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <div class="flex items-center gap-2 mb-4">
              <svg class="text-[var(--color-brand-primary)] shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <h2 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Office Hours</h2>
            </div>
            <dl class="space-y-2 text-sm">
              {[
                { day: "Monday", hours: "7:30 am – 4:30 pm" },
                { day: "Tuesday", hours: "7:30 am – 5:30 pm" },
                { day: "Wednesday", hours: "7:30 am – 8:30 pm", extended: true },
                { day: "Thursday", hours: "7:30 am – 6:30 pm" },
                { day: "Friday", hours: "7:30 am – 4:00 pm" },
              ].map(row => (
                <div class={`flex justify-between items-center py-1.5 border-b border-[var(--color-border-soft)] last:border-0 ${row.extended ? 'bg-[var(--color-surface-alt)] -mx-2 px-2 rounded-lg' : ''}`}>
                  <dt class={`font-medium ${row.extended ? 'text-[var(--color-brand-primary)]' : 'text-[var(--color-text)]'}`}>{row.day}</dt>
                  <dd class="tabular-nums text-[var(--color-text-muted)] flex items-center gap-1.5">
                    {row.hours}
                    {row.extended && <span class="text-xs font-semibold text-[var(--color-brand-accent)] bg-[var(--color-brand-accent)]/10 px-1.5 py-0.5 rounded">Extended</span>}
                  </dd>
                </div>
              ))}
            </dl>
          </div>

          <!-- Arrival Tips -->
          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-base text-[var(--color-brand-primary)] mb-4">Arrival Tips</h2>
            <ul class="space-y-3">
              {[
                { icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`, text: "Arrive 10 minutes early for your first appointment to complete any remaining paperwork." },
                { icon: `<rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>`, text: "Bring your insurance card and a piece of photo ID." },
                { icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`, text: "New patients can complete forms online in advance via the Patients page." },
                { icon: `<circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"/>`, text: "Free parking available on-site — no hunting for a spot before your visit." },
              ].map(tip => (
                <li class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-[var(--color-surface-cool)] flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={tip.icon} />
                  </div>
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{tip.text}</p>
                </li>
              ))}
            </ul>
          </div>

          <!-- Accessibility -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-sm text-[var(--color-brand-primary)] mb-3">Accessibility</h2>
            <ul class="space-y-1.5 text-sm text-[var(--color-text-muted)]">
              <li class="flex items-center gap-2">
