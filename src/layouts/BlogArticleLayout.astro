---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  category: string;
  categoryStyle: 'green' | 'blue' | 'amber';
  headline: string;
  readTime: string;
  date: string;
  dateIso: string;
  heroImage: string;
  heroImageAlt: string;
  currentSlug: string;
}

const {
  title,
  description,
  category,
  categoryStyle,
  headline,
  readTime,
  date,
  dateIso,
  heroImage,
  heroImageAlt,
  currentSlug,
} = Astro.props;

const allPosts = [
  {
    slug: 'what-to-expect-at-your-teeth-cleaning',
    category: 'Preventive Care',
    categoryStyle: 'green',
    title: 'What to Expect at Your Teeth Cleaning',
    readTime: '5 min read',
    href: '/blog/what-to-expect-at-your-teeth-cleaning',
    image: '/images/services/preventive-hygiene.jpg',
    imageAlt: 'Dental hygienist performing a professional cleaning',
  },
  {
    slug: 'tips-for-choosing-the-right-family-dental-clinic',
    category: 'Family Dentistry',
    categoryStyle: 'blue',
    title: 'Tips for Choosing the Right Family Dental Clinic',
    readTime: '4 min read',
    href: '/blog/tips-for-choosing-the-right-family-dental-clinic',
    image: '/images/services/clinic-patient.jpg',
    imageAlt: 'Patient at a family dental clinic',
  },
  {
    slug: 'why-restore-a-broken-tooth',
    category: 'Restorative Dentistry',
    categoryStyle: 'amber',
    title: 'Why Restore a Broken Tooth?',
    readTime: '5 min read',
    href: '/blog/why-restore-a-broken-tooth',
    image: '/images/services/hero-restorative.jpg',
    imageAlt: 'Restorative dental care',
  },
];

const keepReading = allPosts.filter(p => p.slug !== currentSlug);
---

<BaseLayout title={title} description={description}>

  <!-- ==================== HERO ==================== -->
  <section class="article-hero" aria-label="Article header">

    <div class="article-hero__photo" aria-hidden="true">
      <img
        src={heroImage}
        alt=""
        width="900"
        height="700"
        loading="eager"
        decoding="async"
      />
    </div>

    <div class="article-hero__curve" aria-hidden="true">
      <svg viewBox="0 0 170 600" preserveAspectRatio="none" fill="none">
        <path d="M0,0 H80 C168,180 168,420 80,600 H0 Z" fill="currentColor"/>
      </svg>
    </div>

    <div class="container-wide article-hero__inner">
      <div class="article-hero__copy">

        <nav aria-label="Breadcrumb" class="article-hero__crumbs">
          <a href="/">Home</a>
          <span aria-hidden="true">/</span>
          <a href="/blog">Blog</a>
          <span aria-hidden="true">/</span>
          <span aria-current="page">{category}</span>
        </nav>

        <span class="eyebrow">{category}</span>

        <h1 class="article-hero__title">{headline}</h1>

        <div class="article-hero__meta">
          <span class="article-hero__mitem">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
            </svg>
            {readTime}
          </span>
          <span class="article-hero__divider" aria-hidden="true"></span>
          <time datetime={dateIso}>{date}</time>
        </div>

      </div>
    </div>

    <svg class="article-hero__wave" viewBox="0 0 1440 140" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,60 C280,44 520,86 760,92 C1000,98 1180,74 1440,52 L1440,140 L0,140 Z" fill="#c2d4ea"/>
      <path d="M0,36 C240,80 470,118 760,114 C1000,110 1200,56 1440,16 L1440,140 L0,140 Z" fill="rgba(208,225,243,0.82)"/>
      <path d="M0,98 C260,88 500,122 760,124 C1020,126 1220,98 1440,72 L1440,140 L0,140 Z" fill="#ffffff"/>
    </svg>

  </section>

  <!-- ==================== ARTICLE BODY ==================== -->
  <section class="section-y" aria-label="Article content">
    <div class="container-wide">
      <article class="article-prose">
        <slot />
        <div class="article-prose__back">
          <a href="/blog">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
            </svg>
            Back to Blog
          </a>
        </div>
      </article>
    </div>
  </section>

  <!-- Divider -->
  <div class="container-wide" aria-hidden="true">
    <hr class="article-divider" />
  </div>

  <!-- ==================== KEEP READING ==================== -->
  <section class="section-y keep-reading" aria-labelledby="keep-reading-heading">
    <div class="container-wide">

      <div class="keep-reading__head">
        <div>
          <h2 id="keep-reading-heading" class="keep-reading__title">Keep Reading</h2>
          <span class="keep-reading__rule" aria-hidden="true"></span>
        </div>
        <div class="keep-reading__arrows" aria-label="Scroll articles">
          <button class="kr-arrow kr-arrow--muted" aria-label="Previous articles" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M19 12H5M11 18l-6-6 6-6"/>
            </svg>
          </button>
          <button class="kr-arrow" aria-label="Next articles" type="button">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </button>
        </div>
      </div>

      <div class="kr-cards">
        {keepReading.map((post) => (
          <article class="kr-card">
            <div class="kr-card__image">
              <img
                src={post.image}
                alt={post.imageAlt}
                width="600"
                height="240"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="kr-card__body">
              <span class={`kr-tag kr-tag--${post.categoryStyle}`}>{post.category}</span>
              <h3 class="kr-card__title">{post.title}</h3>
            </div>
            <div class="kr-card__foot">
              <span class="kr-readtime">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>
                </svg>
                {post.readTime}
              </span>
              <a href={post.href} class="kr-readlink">
                Read Article
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <!-- ==================== CTA BAND ==================== -->
  <section class="article-cta-sec" aria-labelledby="cta-heading">
    <div class="container-wide">
      <div class="article-cta-band">

        <div class="article-cta-band__leaf" aria-hidden="true">
          <svg viewBox="0 0 200 300" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M120 285 C96 235 84 180 92 122 C98 78 118 40 150 12"/>
            <path d="M96 232 C70 224 50 206 42 178 C70 178 92 192 104 216"/>
            <path d="M90 196 C112 188 132 192 148 208 C124 220 102 218 86 204"/>
            <path d="M92 162 C66 156 48 138 42 110 C68 112 88 128 98 152"/>
            <path d="M96 132 C116 122 138 124 154 140 C132 154 108 152 92 138"/>
            <path d="M104 98 C82 90 66 72 62 46 C86 50 104 66 112 90"/>
            <path d="M110 74 C128 62 150 62 168 76 C148 92 124 90 108 76"/>
            <path d="M122 44 C104 34 92 16 90 -6 C112 0 126 16 130 38"/>
          </svg>
        </div>

        <div class="article-cta-band__text">
          <h2 id="cta-heading">Questions About Your Oral Health?</h2>
          <div class="article-cta-band__rule" aria-hidden="true"></div>
          <p>Our dentists and hygienists are here to help you and your family achieve healthy, confident smiles.</p>
        </div>

        <div class="article-cta-band__actions">
          <a href="/book" class="btn btn-secondary btn-lg">
            Request Appointment
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
          <a href="/contact" class="btn btn-outline btn-lg">
            Contact Us
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ==================== HERO ==================== */
  .article-hero {
    position: relative;
    background-color: var(--color-brand-primary-deep);
    overflow: hidden;
  }

  .article-hero__photo {
    position: absolute;
    top: 0; right: 0;
    height: 100%; width: 50%;
    z-index: 0;
  }
  .article-hero__photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-hero__curve {
    position: absolute;
    top: 0;
    left: 50%;
    margin-left: -166px;
    height: 100%;
    width: 170px;
    color: var(--color-brand-primary-deep);
    pointer-events: none;
    z-index: 1;
  }
  .article-hero__curve svg {
    height: 100%; width: 100%; display: block;
  }

  .article-hero__inner {
    position: relative;
    z-index: 2;
  }

  .article-hero__copy {
    padding: 3.75rem 0 6rem;
    max-width: 640px;
  }

  .article-hero__crumbs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: #aebfd4;
    margin-bottom: 1.75rem;
  }
  .article-hero__crumbs a {
    color: #aebfd4;
    text-decoration: none;
    transition: color 150ms ease;
  }
  .article-hero__crumbs a:hover { color: #fff; }
  .article-hero__crumbs span[aria-current="page"] {
    color: #fff;
    font-weight: 600;
  }
  .article-hero__crumbs span[aria-hidden="true"] {
    color: #5e7193;
    font-size: 0.8rem;
  }

  .article-hero__copy :global(.eyebrow) {
    display: block;
    margin-bottom: 1rem;
  }

  .article-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 1.4rem + 3vw, 3.25rem);
    font-weight: 800;
    letter-spacing: -0.01em;
    color: #fff;
    line-height: 1.1;
    text-wrap: balance;
    margin-top: 0.5rem;
  }

  .article-hero__meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 2rem;
    color: #dbe5f1;
    font-size: 0.9375rem;
    font-weight: 600;
  }
  .article-hero__mitem {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .article-hero__mitem svg { color: #9fb3cd; }
  .article-hero__divider {
    width: 1px; height: 20px;
    background: rgba(255,255,255,0.28);
  }

  .article-hero__wave {
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    width: 100%;
    z-index: 3;
    display: block;
  }

  /* ==================== ARTICLE PROSE ==================== */
  .article-prose {
    width: 80%;
  }

  .article-prose__back {
    margin-top: 2.5rem;
  }
  .article-prose__back a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-brand-primary);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .article-prose__back a:hover { color: var(--color-brand-accent); }

  .article-divider {
    border: none;
    border-top: 1px solid var(--color-border-soft);
    margin: 0;
  }

  /* ==================== KEEP READING ==================== */
  .keep-reading__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  .keep-reading__title {
    font-size: clamp(1.625rem, 1.4rem + 1.2vw, 2.25rem);
    margin-bottom: 0;
  }

  .keep-reading__rule {
    display: block;
    width: 4rem;
    height: 3px;
    background: var(--color-brand-accent);
    border-radius: 2px;
    margin-top: 1rem;
  }

  .keep-reading__arrows {
    display: flex;
    gap: 0.875rem;
  }

  .kr-arrow {
    width: 48px; height: 48px;
    border-radius: 50%;
    border: 1px solid #d6dfe9;
    background: #fff;
    display: flex; align-items: center; justify-content: center;
    color: var(--color-brand-primary);
    cursor: pointer;
    transition: border-color 180ms ease, background 180ms ease, color 180ms ease, transform 180ms ease;
  }
  .kr-arrow:hover {
    border-color: var(--color-brand-primary);
    background: var(--color-brand-primary-deep);
    color: #fff;
    transform: translateY(-2px);
  }
  .kr-arrow--muted {
    color: #b3c0ce;
    border-color: #e3e9f0;
  }
  .kr-arrow--muted:hover {
    background: #fff;
    color: #7d8a98;
    border-color: #d6dfe9;
    transform: none;
  }

  .kr-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.625rem;
  }

  .kr-card {
    background: #fff;
    border: 1px solid var(--color-border-soft);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 12px 30px rgba(20,54,95,0.07);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }
  .kr-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 44px rgba(20,54,95,0.13);
  }

  .kr-card__image {
    width: 100%;
    height: 240px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .kr-card__image img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 300ms ease;
  }
  .kr-card:hover .kr-card__image img {
    transform: scale(1.04);
  }

  .kr-card__body {
    padding: 1.25rem 1.375rem 0;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .kr-card__title {
    font-size: 1.25rem;
    color: var(--color-brand-primary);
    margin-top: 0.9375rem;
    line-height: 1.24;
    font-weight: 600;
  }

  .kr-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding: 1.125rem 1.375rem;
    border-top: 1px solid var(--color-border-soft);
  }

  .kr-tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    align-self: flex-start;
  }
  .kr-tag--green { background: #dcebe1; color: #3c6b51; }
  .kr-tag--blue  { background: #d9ecfb; color: #1f3a63; }
  .kr-tag--amber { background: #fef3c7; color: #92400e; }

  .kr-readtime {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #7a8696;
    font-size: 0.84375rem;
    font-weight: 600;
  }
  .kr-readtime svg { color: #9aa6b4; }

  .kr-readlink {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-brand-accent);
    font-weight: 700;
    font-size: 0.84375rem;
    text-decoration: none;
    transition: gap 180ms ease, color 150ms ease;
  }
  .kr-readlink:hover {
    gap: 0.75rem;
    color: var(--color-brand-accent-hover);
  }

  /* ==================== CTA BAND ==================== */
  .article-cta-sec {
    padding-top: 3rem;
    padding-bottom: 4.75rem;
  }

  .article-cta-band {
    position: relative;
    overflow: hidden;
    background: linear-gradient(150deg, #eef3f9 0%, #e7eef7 100%);
    border: 1px solid #dde6f1;
    border-radius: var(--radius-2xl);
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 3.125rem 3.5rem;
  }

  .article-cta-band__leaf {
    position: absolute;
    left: -10px; top: -18px;
    height: 150%; width: 200px;
    color: var(--color-brand-primary);
    opacity: 0.16;
    pointer-events: none;
  }
  .article-cta-band__leaf svg { height: 100%; width: 100%; }

  .article-cta-band__text {
    flex: 1;
    position: relative;
    z-index: 1;
    padding-left: 8rem;
  }

  .article-cta-band__text h2 {
    font-size: clamp(1.5rem, 1.25rem + 1.4vw, 2rem);
    color: var(--color-brand-primary);
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .article-cta-band__rule {
    width: 4rem;
    height: 3px;
    background: var(--color-brand-accent);
    border-radius: 2px;
    margin-bottom: 1.25rem;
  }

  .article-cta-band__text p {
    font-size: 1.03125rem;
    color: var(--color-text);
    line-height: 1.6;
    max-width: 430px;
  }

  .article-cta-band__actions {
    display: flex;
    gap: 1rem;
    position: relative;
    z-index: 1;
    flex: 0 0 auto;
  }

  /* ==================== RESPONSIVE ==================== */
  @media (max-width: 960px) {
    .article-hero__photo {
      position: relative;
      width: 100%; height: 280px;
    }
    .article-hero__curve { display: none; }
    .article-hero__copy { padding: 2.875rem 0 4.375rem; max-width: none; }
    .article-hero__title { font-size: 2.625rem; }

    .article-prose { width: 100%; }

    .article-cta-band {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.75rem;
    }
    .article-cta-band__text { padding-left: 0; }
    .article-cta-band__leaf { display: none; }
  }

  @media (max-width: 640px) {
    .kr-cards { grid-template-columns: 1fr; }
    .article-cta-band__actions {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }
  }
</style>
