---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const invisalignBenefits = [
  "Nearly invisible appearance",
  "Removable for eating and brushing",
  "Comfortable smooth aligners",
  "Fewer emergency appointments",
  "Great for many mild to moderate orthodontic concerns",
];

const bracesBenefits = [
  "Excellent for simple and complex cases",
  "Precise tooth movement",
  "No need to remember to wear aligners",
  "Proven long-term results",
  "Suitable for children, teens, and adults",
];

const orthodonticsHelps = [
  "Crooked teeth",
  "Crowded teeth",
  "Gaps between teeth",
  "Overbite",
  "Underbite",
  "Crossbite",
  "Open bite",
  "Bite alignment",
];

const invisalignCompare = [
  "Nearly invisible",
  "Removable",
  "Easy brushing & flossing",
  "Popular with adults",
  "Requires patient compliance",
];

const bracesCompare = [
  "Fixed in place",
  "Excellent for complex cases",
  "Always working 24/7",
  "Proven long-term results",
  "Great for children, teens, and adults",
];

const expectSteps = [
  {
    title: "Consultation",
    body: "We'll examine your smile, discuss your goals, and determine whether Invisalign® or braces is the best option.",
  },
  {
    title: "Personalized Treatment Plan",
    body: "We'll explain your treatment options, expected timeline, and answer any questions.",
  },
  {
    title: "Active Treatment",
    body: "Your smile gradually transforms through scheduled progress visits.",
  },
  {
    title: "Retention",
    body: "Once treatment is complete, retainers help protect your new smile.",
  },
];

const faqs = [
  {
    q: "Am I a candidate for Invisalign®?",
    a: "Many teens and adults qualify. We'll determine if it's right during your consultation.",
  },
  {
    q: "Are braces only for children?",
    a: "No. Many adults choose orthodontic treatment every year.",
  },
  {
    q: "How long does treatment take?",
    a: "Many patients complete treatment within 12–24 months, depending on their needs.",
  },
  {
    q: "Does orthodontic treatment hurt?",
    a: "You may experience mild soreness after adjustments or switching aligners, but it typically resolves within a few days.",
  },
];
---

<BaseLayout
  title="Orthodontics | Invisalign® & Traditional Braces | Able Family Dental Lethbridge"
  description="Orthodontic treatment at Able Family Dental in Lethbridge, including Invisalign® clear aligners and traditional metal braces for children, teens, and adults."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/orthodontics-hero.jpg"
        alt=""
        width="1024"
        height="682"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover object-[68%_center]"
      />
      <div class="absolute inset-y-0 left-0 w-2/5" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Orthodontics</span>
      </nav>
      <p class="eyebrow text-white">Orthodontics at Able Family Dental</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Straighter Smiles with Invisalign® &amp; Traditional Braces
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Whether you're looking for the nearly invisible convenience of Invisalign® or the proven effectiveness of traditional metal braces, our team can help you achieve a healthier, more confident smile.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/book/" class="btn btn-primary">Book a Consultation</a>
        <a href="tel:+14033277202" class="btn border border-white/30 text-white hover:bg-white/10 transition-colors">403.327.7202</a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       TREATMENT OPTIONS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <p class="eyebrow">Treatment Options</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Orthodontic Treatment Options at Able Family Dental
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Every smile is unique. During your consultation, we'll evaluate your bite, discuss your goals, and recommend the orthodontic solution that best fits your lifestyle and needs.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Invisalign -->
        <article class="bg-white rounded-2xl p-8 border border-[var(--color-border-soft)] shadow-md flex flex-col">
          <h3 class="font-display font-semibold text-2xl text-[var(--color-brand-primary)]">
            Invisalign® Clear Aligners
          </h3>
          <p class="mt-4 text-[var(--color-text)] leading-relaxed">
            Nearly invisible removable aligners designed to gradually move your teeth into their ideal position.
          </p>
          <p class="mt-3 text-[var(--color-text-muted)] leading-relaxed">
            Perfect for many teens and adults who want a discreet orthodontic option while maintaining their normal lifestyle.
          </p>
          <p class="mt-6 text-sm font-semibold uppercase tracking-[0.12em] text-[var(--color-brand-primary)]">Benefits</p>
          <ul class="mt-3 space-y-2.5 flex-1">
            {invisalignBenefits.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/services/orthodontics/invisalign/" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
            Learn More About Invisalign®
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </article>

        <!-- Traditional Braces -->
        <article class="bg-white rounded-2xl p-8 border border-[var(--color-border-soft)] shadow-md flex flex-col">
          <h3 class="font-display font-semibold text-2xl text-[var(--color-brand-primary)]">
            Traditional Metal Braces
          </h3>
          <p class="mt-4 text-[var(--color-text)] leading-relaxed">
            Traditional braces remain one of the most reliable and effective ways to correct a wide range of orthodontic concerns.
          </p>
          <p class="mt-3 text-[var(--color-text-muted)] leading-relaxed">
            Today's braces are smaller, more comfortable, and more efficient than ever before.
          </p>
          <p class="mt-6 text-sm font-semibold uppercase tracking-[0.12em] text-[var(--color-brand-primary)]">Benefits</p>
          <ul class="mt-3 space-y-2.5 flex-1">
            {bracesBenefits.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/services/orthodontics/retainers-braces/" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
            Learn More About Braces
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ============================================================
       WHY CONSIDER + COMPARISON
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">
        <div class="space-y-14">

          <!-- Specialty disclaimer -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Orthodontic services at Able Family Dental are provided by our general dentist team. Our dentists are not licensed specialists in orthodontics.
              </p>
            </div>
          </div>

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Why Consider Orthodontic Treatment?
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>Straightening your teeth isn't just about appearance.</p>
              <p>
                Orthodontic treatment can improve the way your teeth fit together, make brushing and flossing easier, reduce excessive wear on teeth, and create a healthier bite.
              </p>
            </div>
            <p class="mt-6 font-semibold text-[var(--color-brand-primary)]">Orthodontics can help with:</p>
            <ul class="mt-4 grid sm:grid-cols-2 gap-2.5">
              {orthodonticsHelps.map((item) => (
                <li class="flex items-center gap-2.5 text-[var(--color-text-muted)]">
                  <svg class="shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Invisalign® or Traditional Braces?
            </h2>
            <p class="text-[var(--color-text)] leading-relaxed mb-8">
              Both treatments can produce outstanding results—the right choice depends on your smile, lifestyle, and treatment goals.
            </p>
            <div class="grid sm:grid-cols-2 gap-6">
              <div class="rounded-2xl border border-[var(--color-border-soft)] bg-[var(--color-surface-cool)] p-6">
                <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)]">Invisalign®</h3>
                <ul class="mt-4 space-y-2.5">
                  {invisalignCompare.map((item) => (
                    <li class="flex items-start gap-2.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                      <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="rounded-2xl border border-[var(--color-border-soft)] bg-[var(--color-surface-cool)] p-6">
                <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)]">Traditional Braces</h3>
                <ul class="mt-4 space-y-2.5">
                  {bracesCompare.map((item) => (
                    <li class="flex items-start gap-2.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                      <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
            <p class="mt-6 text-[var(--color-text)] leading-relaxed">
              During your consultation, we'll explain both options and help you decide which treatment is best for you.
            </p>
          </div>

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Orthodontic Treatment for Every Age
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>Orthodontic treatment isn't just for teenagers.</p>
              <p>
                We provide orthodontic solutions for children, teens, and adults. Whether you're starting treatment for the first time or returning to improve your smile later in life, we're here to help.
              </p>
            </div>
          </div>

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
              What to Expect
            </h2>
            <ol class="space-y-5">
              {expectSteps.map((step, i) => (
                <li class="flex gap-4 items-start">
                  <span class="w-9 h-9 rounded-full bg-[var(--color-brand-primary)] text-white font-semibold text-sm flex items-center justify-center shrink-0">{i + 1}</span>
                  <div>
                    <h3 class="font-semibold text-[var(--color-brand-primary)]">{step.title}</h3>
                    <p class="mt-1 text-[var(--color-text-muted)] leading-relaxed">{step.body}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
              Frequently Asked Questions
            </h2>
            <div class="space-y-3">
              {faqs.map((item) => (
                <details class="group border border-[var(--color-border-soft)] rounded-xl bg-[var(--color-surface-cool)] overflow-hidden">
                  <summary class="cursor-pointer list-none flex items-center justify-between gap-4 px-5 py-4 font-semibold text-[var(--color-brand-primary)]">
                    <span>{item.q}</span>
                    <span class="w-6 h-6 rounded-full border border-[var(--color-border-soft)] bg-white flex items-center justify-center shrink-0 group-open:bg-[var(--color-brand-primary)] group-open:border-[var(--color-brand-primary)]" aria-hidden="true">
                      <svg class="w-3 h-3 text-[var(--color-brand-accent)] group-open:text-white" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="2" y1="6" x2="10" y2="6" />
                        <line x1="6" y1="2" x2="6" y2="10" class="group-open:hidden" />
                      </svg>
                    </span>
                  </summary>
                  <div class="px-5 pb-4 text-[var(--color-text-muted)] leading-relaxed">
                    {item.a}
                  </div>
                </details>
              ))}
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <aside class="space-y-6 lg:sticky lg:top-28 self-start">
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Book a Consultation</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Discover which treatment is right for you.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Orthodontic Services</h3>
            <ul class="space-y-2">
              <li>
                <a href="/services/orthodontics/invisalign/" class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                  Invisalign® Clear Aligners
                </a>
              </li>
              <li>
                <a href="/services/orthodontics/retainers-braces/" class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                  Traditional Metal Braces
                </a>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CLOSING CTA
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide max-w-3xl mx-auto">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to Transform Your Smile?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg leading-relaxed">
        Whether you're considering Invisalign® or traditional braces, our team is here to help you choose the treatment that's right for you.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book a Consultation</a>
        <a href="tel:+14033277202" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">403.327.7202</a>
      </div>
    </div>
  </section>

</BaseLayout>
