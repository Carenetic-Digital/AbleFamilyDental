<style>
  .svc-track {
    display: flex;
    gap: 1rem;
    will-change: transform;
    transition: transform 380ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .svc-card {
    flex-shrink: 0;
    padding: 1.25rem;
    box-shadow: 0 2px 4px 0 rgb(0 0 0 / 0.06), 0 8px 20px 0 rgb(0 0 0 / 0.14), 0 16px 32px -4px rgb(0 0 0 / 0.10);
  }
  .svc-dot {
    flex-shrink: 0;
    height: 0.5rem;
    width: 0.5rem;
    border-radius: 9999px;
    background-color: var(--color-brand-secondary);
    border: none;
    cursor: pointer;
    transition: width 200ms ease, background-color 200ms ease;
    padding: 0;
  }
  .svc-dot[aria-current="true"] {
    width: 1.5rem;
    background-color: var(--color-brand-accent);
  }
  .svc-dot:focus-visible {
    outline: 2px solid var(--color-brand-accent);
    outline-offset: 2px;
  }
</style>

<script is:inline>
  (function () {
    var viewport = document.getElementById('svc-viewport');
    var track    = document.getElementById('svc-track');
    var dotsEl   = document.getElementById('svc-dots');
    var prevBtn  = document.getElementById('svc-prev');
    var nextBtn  = document.getElementById('svc-next');
    if (!viewport || !track || !dotsEl || !prevBtn || !nextBtn) return;

    var cards  = Array.from(track.querySelectorAll('[data-svc-card]'));
    var count  = cards.length;
    var GAP    = 16; // 1rem in px — matches gap: 1rem in CSS
    var current = 0;

    function perPage() {
      var w = viewport.offsetWidth;
      if (w >= 600) return 4;
      if (w >= 380) return 2;
      return 1;
    }

    function cardWidth() {
      var pp = perPage();
      return (viewport.offsetWidth - (pp - 1) * GAP) / pp;
    }

    function maxIndex() {
      return Math.max(0, count - perPage());
    }

    function applyWidths() {
      var w = cardWidth();
      cards.forEach(function (c) { c.style.width = w + 'px'; });
    }

    function render() {
      var w      = cardWidth();
      var offset = current * (w + GAP);
      track.style.transform = 'translateX(-' + offset + 'px)';
      prevBtn.disabled = current <= 0;
      nextBtn.disabled = current >= maxIndex();
      dotEls.forEach(function (d, i) {
        d.setAttribute('aria-current', String(i === current));
      });
    }

    // Build dots
    var dotEls = cards.map(function (_, i) {
      var btn = document.createElement('button');
      btn.className = 'svc-dot';
      btn.setAttribute('role', 'tab');
      btn.setAttribute('aria-label', 'Go to service ' + (i + 1));
      btn.setAttribute('aria-current', i === 0 ? 'true' : 'false');
      dotsEl.appendChild(btn);
      btn.addEventListener('click', function () {
        current = Math.min(i, maxIndex());
        render();
      });
      return btn;
    });

    prevBtn.addEventListener('click', function () {
      if (current > 0) { current--; render(); }
    });

    nextBtn.addEventListener('click', function () {
      if (current < maxIndex()) { current++; render(); }
    });

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        current = Math.min(current, maxIndex());
        applyWidths();
        render();
      }, 80);
    });

    applyWidths();
    render();
  })();
</script>
