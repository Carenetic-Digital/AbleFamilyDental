---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const benefits = [
  {
    title: "Full Dentures",
    description: "Complete dentures replace an entire arch of missing teeth. They rest on the gums and are held in place by suction and the natural contours of your mouth.",
    icon: `<rect x="3" y="4" width="18" height="16" rx="3"/><path d="M7 10h10"/><path d="M7 14h10"/>`,
  },
  {
    title: "Partial Dentures",
    description: "When some natural teeth remain, a partial denture fills the gaps and clasps gently to the remaining teeth, preventing them from shifting out of position.",
    icon: `<path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 4v16"/><path d="M15 4v16"/>`,
  },
  {
    title: "Custom-Fitted Comfort",
    description: "Impressions of your mouth are taken to create dentures that fit your unique ridge shape, minimising sore spots and improving day-to-day comfort.",
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
  {
    title: "Restored Chewing Ability",
    description: "Well-fitted dentures allow you to enjoy a varied diet again. We work to achieve a balanced bite so chewing is comfortable on both sides.",
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    title: "Natural Appearance",
    description: "Modern denture teeth and gum-coloured bases are selected to complement your facial features, creating a natural-looking smile that suits your age and complexion.",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  },
  {
    title: "Ongoing Adjustments",
    description: "Gum and bone tissue changes over time. We offer relining and adjustments to keep your dentures fitting well and prevent discomfort as your mouth changes.",
    icon: `<circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41"/><path d="M5.34 18.66l-1.41 1.41"/><path d="M14 12l7-7"/><path d="M3 21l7-7"/>`,
  },
];
---

<BaseLayout
  title="Dentures Lethbridge | Able Family Dental"
  description="Custom full and partial dentures in Lethbridge at Able Family Dental. Comfortable, natural-looking removable appliances fitted to your unique smile."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-dentures.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/prosthodontics/" class="text-white/80 hover:text-white transition-colors">Prosthodontics</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Full &amp; Partial Dentures</span>
      </nav>
      <p class="eyebrow text-white">Prosthodontic Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Full &amp; Partial Dentures
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Losing teeth affects more than your smile, it changes how you eat, speak, and feel. Custom-fitted dentures restore all of that, comfortably and confidently.
      </p>
    </div>
  </section>

  <!-- ============================================================
       CONTENT SECTION
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="eyebrow">Removable restorations</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Personalised dentures for Lethbridge patients
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Dentures have come a long way. Today's custom-made appliances are lighter, more comfortable, and more lifelike than ever before. At Able Family Dental, we take careful impressions and work closely with dental labs to craft dentures that fit securely and look natural. Whether you need to replace a full arch or just a few missing teeth, we'll help you find the right solution and guide you through the adjustment period so you feel confident from day one.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map(item => (
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)] shadow-md flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-4 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
            </div>
            <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{item.description}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to restore your smile?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
