---
const year = new Date().getFullYear();
const footerServices = [
  { label: "Emergency Services", href: "/services/emergency" },
  { label: "Family Dentistry", href: "/services/preventive" },
  { label: "Cosmetic Dentistry", href: "/services/cosmetic" },
  { label: "Children's Dentistry", href: "/services/childrens" },
];
const footerQuickLinks = [
  { label: "About Us", href: "/about" },
  { label: "New Patients", href: "/new-patients" },
  { label: "Patient Forms", href: "/new-patients/forms" },
  { label: "Insurance & Payment", href: "/new-patients/insurance-payment" },
  { label: "Contact Us", href: "/contact" },
];
const footerResources = [
  { label: "Careers", href: "/about/careers" },
  { label: "FAQs", href: "/new-patients" },
  { label: "Blog", href: "/blog" },
];
---

<footer class="bg-[var(--color-brand-primary)] text-[var(--color-text-on-dark)]">
  <div class="container-wide pt-16 pb-8">

    <!-- Top: 4 columns -->
    <div class="grid grid-cols-2 md:grid-cols-4 pb-12 border-b border-white/10 divide-x divide-white/10">

      <!-- Col 1: Services -->
      <div class="pr-8">
        <h3 class="font-body text-sm font-semibold tracking-[0.16em] uppercase text-white mb-2">Services</h3>
        <div class="w-8 h-0.5 bg-[var(--color-brand-accent)] mb-5"></div>
        <ul class="space-y-2">
          {footerServices.map(link => (
            <li>
              <a href={link.href} class="inline-flex items-center gap-1.5 text-[var(--color-text-on-dark-muted)] hover:text-white text-sm leading-loose transition-colors">
                <span aria-hidden="true" class="text-[var(--color-brand-accent)]">›</span>
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/services" class="inline-flex items-center gap-1.5 text-[var(--color-brand-accent)] hover:text-white text-sm font-semibold leading-loose transition-colors mt-1">
              All Services →
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 2: Quick Links -->
      <div class="px-8">
        <h3 class="font-body text-sm font-semibold tracking-[0.16em] uppercase text-white mb-2">Quick Links</h3>
        <div class="w-8 h-0.5 bg-[var(--color-brand-accent)] mb-5"></div>
        <ul class="space-y-2">
          {footerQuickLinks.map(link => (
            <li>
              <a href={link.href} class="text-[var(--color-text-on-dark-muted)] hover:text-white text-sm leading-loose transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Resources -->
      <div class="px-8">
        <h3 class="font-body text-sm font-semibold tracking-[0.16em] uppercase text-white mb-2">Resources</h3>
        <div class="w-8 h-0.5 bg-[var(--color-brand-accent)] mb-5"></div>
        <ul class="space-y-2">
          {footerResources.map(link => (
            <li>
              <a href={link.href} class="text-[var(--color-text-on-dark-muted)] hover:text-white text-sm leading-loose transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 4: Connect With Us + WDC logo (same row) -->
      <div class="pl-10 overflow-visible">
        <div class="mb-2">
          <h3 class="font-body text-sm font-semibold tracking-[0.16em] uppercase text-white">Connect With Us</h3>
        </div>
        <div class="w-8 h-0.5 bg-[var(--color-brand-accent)] mb-5"></div>

        <!-- Social icons -->
        <div class="flex items-center gap-3 mb-5">
          <!-- Facebook -->
          <a
            href="https://www.facebook.com/WildwoodDentalClinic"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Wildwood Dental Clinic on Facebook"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a
            href="https://www.instagram.com/wildwooddentalclinic"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Wildwood Dental Clinic on Instagram"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>

          <!-- Google -->
          <a
            href="https://share.google/tBUCH3KsjPqnNPytZ"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Wildwood Dental Clinic on Google Reviews"
            class="w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="none">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
          </a>
        </div>

        <p class="text-xs text-[var(--color-text-on-dark-muted)] leading-relaxed mb-3">
          Read our Google reviews and see why patients choose Wildwood Dental Clinic for their family's dental care.
        </p>

        <a href="/" aria-label="Wildwood Dental Clinic home" class="inline-block">
          <img
            src="/images/logos/WDC-logo-remastered-white.svg"
            alt="Wildwood Dental Clinic"
            width="250"
            height="92"
            loading="lazy"
            decoding="async"
            class="h-14 w-auto block"
          />
        </a>
      </div>

    </div>

    <!-- Bottom bar: centered with dividers -->
    <div class="pt-6 flex flex-wrap items-center justify-center gap-2 text-xs text-[var(--color-text-on-dark-muted)]">
      <span>© {year} Wildwood Dental Clinic. All Rights Reserved.</span>
      <span aria-hidden="true" class="text-white/20">|</span>
      <a href="/privacy" class="text-white hover:text-[var(--color-brand-accent)] transition-colors">Privacy Policy</a>
      <span aria-hidden="true" class="text-white/20">|</span>
      <a href="/terms" class="text-white hover:text-[var(--color-brand-accent)] transition-colors">Terms of Use</a>
    </div>

  </div>
</footer>
