---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const benefits = [
  {
    title: "Conservative by Design",
    description: "Unlike a full crown, an inlay or onlay requires removing only the damaged portion of the tooth, preserving as much healthy tooth structure as possible.",
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    title: "Inlays, Within the Cusps",
    description: "An inlay fits within the cusps of a back tooth, restoring the chewing surface of a tooth with moderate decay or damage that is too large for a standard filling.",
    icon: `<rect x="3" y="3" width="18" height="18" rx="3"/>`,
  },
  {
    title: "Onlays, Over the Cusps",
    description: "An onlay extends over one or more cusps of the tooth. It's sometimes called a partial crown and is used when damage is more extensive but a full crown isn't yet necessary.",
    icon: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`,
  },
  {
    title: "Durable Materials",
    description: "Inlays and onlays are crafted from porcelain or composite resin in a dental lab, making them stronger and longer-lasting than a direct filling of the same size.",
    icon: `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
  },
  {
    title: "Precise Fit",
    description: "Because inlays and onlays are fabricated to exact specifications from impressions of your tooth, they fit accurately and seal the margins tightly against future decay.",
    icon: `<path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M12 8v4l3 3"/>`,
  },
  {
    title: "Natural-Looking Results",
    description: "Tooth-coloured porcelain inlays and onlays blend seamlessly with surrounding enamel, making them an aesthetically superior alternative to old metal fillings.",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  },
];
---

<BaseLayout
  title="Inlays & Onlays Lethbridge | Able Family Dental"
  description="Porcelain inlays and onlays in Lethbridge at Able Family Dental. Conservative, precise indirect restorations for moderately damaged teeth."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-inlays-onlays.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/5" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/prosthodontics/" class="text-white/80 hover:text-white transition-colors">Prosthodontics</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Inlays &amp; Onlays</span>
      </nav>
      <p class="eyebrow text-white">Prosthodontic Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Inlays &amp; Onlays
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        When a tooth is too damaged for a simple filling but doesn't yet need a full crown, an inlay or onlay offers a precise, conservative, and long-lasting middle ground.
      </p>
    </div>
  </section>

  <!-- ============================================================
       CONTENT SECTION
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="eyebrow">Indirect restorations</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Precision restorations that protect your natural tooth
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Inlays and onlays sit between a filling and a crown on the spectrum of dental restorations. They are made outside the mouth in a dental lab, fabricated from impressions taken at your appointment, and then bonded permanently into place. At Able Family Dental, we recommend them when a direct filling won't hold up under biting forces but removing enough tooth structure for a full crown would be unnecessarily destructive. The result is a strong, well-fitted restoration that preserves more of what nature gave you.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map(item => (
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)] shadow-md flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-4 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
            </div>
            <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{item.description}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to restore your smile?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
