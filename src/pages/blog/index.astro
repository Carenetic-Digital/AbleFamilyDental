---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// "Featured News" is the clinic news item (not a blog post), so it stays a
// literal pointer at /news/.
const featuredNews = {
  tag: { label: "Clinic News", color: "blue" },
  title: "We've Launched a New Website to Better Serve Our Patients",
  desc: "Able Family Dental has launched a new website to make it easier for patients to find service information, request appointments, and connect with our team from any device.",
  readTime: "3 min read",
  href: "/news/new-website-launch",
  image: "/images/blog/new-website-launch.png",
  imageAlt: "Person browsing the new Able Family Dental website on a laptop",
};

// Article cards are sourced from the CMS blog collection. Newest first;
// drafts excluded.
const articles = (await getCollection('blog', (post) => !post.data.draft))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map((post) => ({
    tag: { label: post.data.category ?? '', color: post.data.categoryStyle ?? 'blue' },
    title: post.data.headline || post.data.title,
    desc: post.data.description ?? '',
    readTime: post.data.readTime ?? '',
    href: `/blog/${post.id}`,
    image: post.data.featuredImage?.src ?? '',
    imageAlt: post.data.featuredImage?.alt ?? '',
  }));
---

<BaseLayout
  title="Blog | Able Family Dental | Lethbridge"
  description="Helpful advice, treatment information, and oral health tips from the Able Family Dental team in Lethbridge."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="blog-hero relative overflow-hidden">
    <!-- Right photo panel -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[52%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-cleaning.jpg"
        alt=""
        width="900"
        height="700"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="hero-fade absolute top-0 left-0 bottom-0" style="width:170px;"></div>
    </div>

    <div class="container-wide relative z-10">
      <div class="hero-copy">
        <nav class="flex items-center gap-2 mb-6" aria-label="Breadcrumb">
          <a href="/" class="text-[#aebfd4] hover:text-white transition-colors text-sm">Home</a>
          <span class="text-[#5e7193] text-sm" aria-hidden="true">/</span>
          <span class="text-white text-sm">Blog</span>
        </nav>
        <p class="eyebrow">Patient Education &amp; Resources</p>
        <h1 class="mt-3 font-display font-bold text-white" style="font-size:60px;letter-spacing:-.01em;line-height:1.08;">
          Learn About Your<br/>Dental Health
        </h1>
        <p class="hero-lead">Helpful advice, treatment information, and oral health tips from the Able Family Dental team.</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURED NEWS
       ============================================================ -->
  <section class="py-16">
    <div class="container-wide">
      <div class="feat-section-head">
        <span class="kicker">Featured News</span>
      </div>
      <article class="featured-card">
        <!-- Image -->
        <div class="feat-img-wrap">
          <img
            src={featuredNews.image}
            alt={featuredNews.imageAlt}
            width="600"
            height="420"
            loading="lazy"
            decoding="async"
          />
        </div>
        <!-- Body -->
        <div class="feat-body">
          <span class={`pill pill-${featuredNews.tag.color}`}>{featuredNews.tag.label}</span>
          <h2 class="font-display font-bold" style="font-size:38px;margin-top:20px;line-height:1.16;color: var(--color-brand-primary);">
            {featuredNews.title}
          </h2>
          <p class="feat-desc">{featuredNews.desc}</p>
          <div class="feat-foot">
            <span class="readtime">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              {featuredNews.readTime}
            </span>
            <a href={featuredNews.href} class="readlink">
              Read Article
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ============================================================
       LATEST ARTICLES
       ============================================================ -->
  <section style="padding-bottom:64px;">
    <div class="container-wide">
      <div class="latest-head">
        <span class="kicker">Latest Articles</span>
        <a href="/blog/" class="readlink">
          View All Articles
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
      <div class="cards-grid">
        {articles.map(article => (
          <article class="blog-card">
            <div class="card-img-wrap">
              <img
                src={article.image}
                alt={article.imageAlt}
                width="400"
                height="188"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="card-body">
              <span class={`pill pill-${article.tag.color}`}>{article.tag.label}</span>
              <h3 class="font-display font-bold" style="font-size:22px;margin-top:16px;line-height:1.2;color: var(--color-brand-primary);">{article.title}</h3>
              <p class="card-desc">{article.desc}</p>
              <div class="card-foot">
                <span class="readtime">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                  {article.readTime}
                </span>
                <a href={article.href} class="readlink">
                  Read Article
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       INSTAGRAM
       ============================================================ -->
  <section style="padding-bottom:64px;">
    <div class="container-wide">
      <div class="ig-band">
        <div class="ig-left">
          <div class="ig-mark" aria-hidden="true">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="white" stroke="none"/></svg>
          </div>
          <div class="ig-text">
            <h3 class="font-display font-bold" style="font-size:26px;color: var(--color-brand-primary);">Follow Us on Instagram</h3>
            <p>Daily tips, patient stories, and oral health advice from our team.</p>
            <a href="https://www.instagram.com/ablefamilydental/" target="_blank" rel="noopener noreferrer" class="ig-btn">
              Follow Us on Instagram
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
        </div>
        <div class="ig-grid">
          {[
            { src: "/images/blog/IG 1.png" },
            { src: "/images/blog/IG 2.png" },
            { src: "/images/blog/IG 3.png" },
            { src: "/images/blog/Ig 4.png" },
          ].map(photo => (
            <div class="ig-photo">
              <img src={photo.src} alt="" width="200" height="150" loading="lazy" decoding="async" aria-hidden="true" />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">
        Ready to book your next visit?
      </h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto leading-relaxed">
        Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or book online — new patients are always welcome.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* ===== HERO ===== */
  .blog-hero {
    position: relative;
    background: #0e2742;
    overflow: hidden;
  }
  .hero-fade {
    background: linear-gradient(90deg, #0e2742 0%, rgba(14,39,66,.55) 45%, transparent 100%);
    pointer-events: none;
  }
  .hero-copy {
    position: relative;
    z-index: 2;
    padding: 62px 0 78px;
    max-width: 540px;
  }
  .hero-lead {
    margin-top: 24px;
    max-width: 430px;
    font-size: 17px;
    color: #c7d4e6;
    line-height: 1.6;
  }
  .searchbar {
    display: flex;
    gap: 14px;
    max-width: 500px;
  }
  .search-field {
    flex: 1;
  }
  .btn-search {
    border: 0;
    cursor: pointer;
    background: linear-gradient(180deg, #ecae46, #dd8a22);
    color: #fff;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 16px;
    padding: 0 30px;
    border-radius: 10px;
    box-shadow: 0 12px 26px rgba(200,136,31,.34);
    transition: filter .18s ease, transform .18s ease;
    white-space: nowrap;
  }
  .btn-search:hover { filter: brightness(1.05); transform: translateY(-1px); }

  /* ===== SHARED ===== */
  .pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-weight: 900;
    font-size: 11.5px;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 7px 15px;
    border-radius: 999px;
    align-self: flex-start;
  }
  .pill-blue  { background: #d9ecfb; color: #1f3a63; }
  .pill-green { background: #dcebe1; color: #3c6b51; }
  .pill-amber { background: #fef3c7; color: #92400e; }

  .readtime {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: #7a8696;
    font-size: 14.5px;
    font-weight: 700;
  }
  .readtime svg { color: #9aa6b4; }

  .readlink {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--color-brand-accent);
    font-weight: 900;
    font-size: 15px;
    text-decoration: none;
    transition: gap .18s ease;
  }
  .readlink:hover { gap: 14px; color: var(--color-brand-accent); }

  /* ===== FEATURED NEWS ===== */
  .feat-section-head {
    margin-bottom: 24px;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    background: #f2f4f8;
    border: 1px solid #e6ecf3;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 18px 44px rgba(20,54,95,.07);
  }
  .feat-img-wrap {
    position: relative;
    min-height: 340px;
    overflow: hidden;
  }
  .feat-img-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .feat-body {
    padding: 48px 52px;
    display: flex;
    flex-direction: column;
  }
  .feat-desc {
    margin-top: 20px;
    font-size: 16.5px;
    color: #54627a;
    line-height: 1.62;
    max-width: 430px;
  }
  .feat-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: auto;
    padding-top: 42px;
  }

  /* ===== LATEST ARTICLES ===== */
  .latest-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
  }
  .kicker {
    font-family: var(--font-body);
    font-weight: 900;
    font-size: 18px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--color-brand-primary);
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  .blog-card {
    background: #fff;
    border: 1px solid #e6ecf3;
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 12px 32px rgba(20,54,95,.07);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .blog-card:hover { transform: translateY(-4px); box-shadow: 0 22px 46px rgba(20,54,95,.13); }
  .card-img-wrap {
    height: 188px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-body {
    padding: 22px 26px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-desc {
    margin-top: 13px;
    font-size: 15px;
    color: #5d6b7a;
    line-height: 1.55;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-top: auto;
    padding-top: 22px;
  }

  /* ===== INSTAGRAM ===== */
  .ig-band {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    align-items: center;
    gap: 40px;
    background: #f7f9fc;
    border: 1px solid #e6ecf3;
    border-radius: 16px;
    padding: 34px 40px;
  }
  .ig-left {
    display: flex;
    align-items: flex-start;
    gap: 22px;
  }
  .ig-mark {
    width: 62px;
    height: 62px;
    border-radius: 16px;
    flex: 0 0 auto;
    background: linear-gradient(45deg, #feda75, #fa7e1e 28%, #d62976 58%, #962fbf 78%, #4f5bd5);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 20px rgba(214,41,118,.28);
  }
  .ig-text p {
    margin: 8px 0 18px;
    font-size: 15.5px;
    color: #5d6b7a;
    max-width: 330px;
    line-height: 1.55;
  }
  .ig-btn {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    background: #0e2742;
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    padding: 14px 24px;
    border-radius: 9px;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(14,39,66,.2);
    transition: transform .18s ease, box-shadow .18s ease;
  }
  .ig-btn:hover { transform: translateY(-2px); box-shadow: 0 14px 30px rgba(14,39,66,.28); color: #fff; }
  .ig-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .ig-photo {
    height: 150px;
    border-radius: 10px;
    overflow: hidden;
  }
  .ig-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 960px) {
    .hero-copy { padding: 48px 0 56px; max-width: none; }
    .blog-hero h1 { font-size: 44px !important; }
    .featured-card { grid-template-columns: 1fr; }
    .feat-img-wrap { min-height: 260px; position: relative; }
    .cards-grid { grid-template-columns: 1fr; }
    .ig-band { grid-template-columns: 1fr; }
    .ig-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
