---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Orthodontics | Clear Aligner Therapy | Wildwood Dental Clinic Saskatoon"
  description="Orthodontic treatment at Wildwood Dental Clinic in Saskatoon. We offer clear aligner therapy for patients looking to improve alignment."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-16 lg:py-20">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Orthodontics</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Wildwood Dental Clinic</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Orthodontics
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Orthodontic treatment focuses on correcting tooth alignment and bite. At Wildwood, we offer clear aligner therapy for patients who are considering orthodontic options.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Specialty disclaimer -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Orthodontic services at Wildwood Dental Clinic are provided by our general dentist team. Our dentists are not licensed specialists in orthodontics.
              </p>
            </div>
          </div>

          <!-- What orthodontics addresses -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What orthodontics addresses
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Orthodontic treatment focuses on the position of teeth and how the upper and lower teeth come together when biting. Misaligned teeth can make thorough cleaning more difficult, affect chewing function, and cause some patients aesthetic concerns. Bite problems — where the upper and lower teeth do not meet as they should — can also contribute to uneven wear over time.
              </p>
              <p>
                Not all alignment concerns require treatment, and not all alignment concerns are appropriate for every type of orthodontic option. A consultation is the best way to determine what, if anything, makes sense for your situation.
              </p>
            </div>
          </div>

          <!-- What we offer -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What we offer at Wildwood
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                At Wildwood Dental Clinic, we offer <strong class="text-[var(--color-brand-primary)]">clear aligner therapy</strong> — a series of removable, transparent aligners worn over the teeth that gradually guide them into a more aligned position. Each set of aligners is worn for a period of time before progressing to the next in the series.
              </p>
              <p>
                Clear aligners are a discreet option for patients who want to address alignment concerns without the appearance of traditional braces. They are removable, which makes eating and oral hygiene easier to manage during treatment.
              </p>
              <a href="/services/orthodontics/invisalign" class="inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors mt-2">
                Learn more about Invisalign &amp; Clear Aligners
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </div>
          </div>

          <!-- Who orthodontic treatment is for -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Who orthodontic treatment is for
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Orthodontic treatment is not only for teenagers. Adults make up a significant portion of orthodontic patients, and many people pursue alignment treatment at various stages of life.
              </p>
              <p>
                Clear aligner therapy may be appropriate for mild to moderate alignment concerns. More significant bite or crowding issues may require a referral to an orthodontist — a dental specialist — for an assessment and discussion of options. We will let you know honestly at your consultation what we can address and when a referral may serve you better.
              </p>
            </div>
          </div>

          <!-- Consultation -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-4">
              Starting with a consultation
            </h2>
            <div class="space-y-3 text-[var(--color-text)] leading-relaxed">
              <p>
                If you are curious about whether clear aligner therapy is appropriate for you, the first step is an examination and consultation. We review your current alignment, take any needed records, and discuss your goals so you have a clear picture of your options and what treatment would involve.
              </p>
              <p>
                Not every alignment concern requires treatment, and we will give you a straightforward assessment of what we find.
              </p>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or book online — new patients welcome.</p>
            <a href="/book" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="tel:+13063747272" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">306.374.7272</a>
          </div>

          <!-- Sub-services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Orthodontic Services</h3>
            <ul class="space-y-2">
              <li>
                <a href="/services/orthodontics/invisalign" class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                  Invisalign &amp; Clear Aligners
                </a>
              </li>
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Interested in orthodontic options?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> or book a consultation online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book" class="btn btn-primary btn-lg">Book an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
