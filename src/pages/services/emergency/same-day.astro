---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "Emergency Dental Care", href: "/services/emergency" },
  { name: "Toothache & Dental Pain", href: "/services/emergency/toothache" },
  { name: "Broken or Chipped Tooth", href: "/services/emergency/broken-tooth" },
  { name: "Knocked-Out Tooth", href: "/services/emergency/knocked-out-tooth" },
  { name: "Urgent Appointments", href: "/services/emergency/appointments" },
];
---

<BaseLayout
  title="Same-Day & Urgent Dental Care | Wildwood Dental Clinic Saskatoon"
  description="Wildwood Dental Clinic in Saskatoon makes every effort to accommodate urgent dental appointments. Call 306.374.7272 to discuss your situation."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/bugherd/Wildwood_Dental_Clinic_Patient_Doc.png"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/emergency" class="hover:text-white transition-colors">Emergency</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Same-Day Care</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Emergency Dental Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Urgent &amp; Same-Day Dental Care
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Wildwood Dental makes every effort to accommodate patients with urgent dental needs. Call <a href="tel:+13063747272" class="text-white font-semibold">306.374.7272</a> and let us know what is happening. We'll work with you.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- What same-day actually means -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What "same-day" actually means in a dental context
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                We set aside time in our schedule for patients who contact us with urgent dental needs. This means that when you call and explain your situation, we can often find a way to see you the same day, but it is not guaranteed, and it depends on the day, our schedule, and the nature of your concern.
              </p>
              <p>
                Calling early in the day gives the best chance of a same-day appointment. If you call in the afternoon, same-day availability may be more limited, though we will always do our best to accommodate you or advise you clearly on what to do in the meantime.
              </p>
              <p>
                We are honest about this because we think it matters. We would rather set realistic expectations than have you arrive without a confirmed time, or wait longer than you expected.
              </p>
            </div>
          </div>

          <!-- Image break -->
          <div class="rounded-2xl overflow-hidden max-h-[700px]">
            <img
              src="/images/bugherd/Same_Day_Appointments.png"
              alt="Same-day dental appointments at Wildwood Dental Clinic"
              width="800"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full h-auto"
            />
          </div>


          <!-- Call first -->
          <div class="bg-[var(--color-surface-alt)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.57 3.38 2 2 0 0 1 3.54 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Always call before coming in</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  Please call <a href="tel:+13063747272" class="text-[var(--color-brand-primary)] font-semibold hover:text-[var(--color-brand-accent)] transition-colors">306.374.7272</a> before arriving at the clinic for an unscheduled appointment. Our team can advise on the urgency of your situation, give you a time to come in, and prepare for your arrival, which helps both you and other patients in the office.
                </p>
              </div>
            </div>
          </div>

          <!-- What we can typically address same-day -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What we can typically address same-day
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                When urgent time becomes available, we focus it on situations where prompt care makes a real difference:
              </p>
              <ul class="space-y-3 mt-3">
                {[
                  "Severe or unmanaged dental pain",
                  "Dental abscess or signs of infection (swelling, fever, throbbing pain)",
                  "Knocked-out or partially displaced tooth, these are always treated as high priority",
                  "Significant tooth fracture with exposed nerve or sharp edge causing injury to soft tissue",
                  "Lost crown or filling with significant pain or sensitivity",
                  "Dental trauma following an accident",
                ].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                    <span class="text-[var(--color-text)] leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- What may need scheduling -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What may need to be scheduled
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Some situations, while worth addressing, do not require emergency access to urgent time and can be scheduled within a few days or at your next available appointment:
              </p>
              <ul class="space-y-3 mt-3">
                {[
                  "Minor chip or crack with no pain, sensitivity, or sharp edge",
                  "Cosmetic concerns",
                  "Routine follow-up after recently completed treatment",
                  "Lost filling with no sensitivity or pain",
                ].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-1 shrink-0 text-[var(--color-text-muted)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                    <span class="text-[var(--color-text)] leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
              <p class="mt-4">
                If you are not sure which category your situation falls into, call us. We will help you sort it out.
              </p>
            </div>
          </div>

          <!-- What to expect when you call -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What to expect when you call
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                When you call and explain that your situation is urgent, our team will ask you a few questions about your symptoms to understand the nature and severity of your concern. Based on that conversation, we will:
              </p>
              <ul class="space-y-3 mt-3">
                {[
                  "Advise you on whether to come in same-day, schedule you for the next available appropriate time, or in serious cases, direct you to a hospital emergency department",
                  "Give you any first-aid guidance relevant to your situation while you wait",
                  "Confirm a time for you to arrive, so we are ready when you get here",
                ].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                    <span class="text-[var(--color-text)] leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg">Need to Be Seen Today?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us directly. We'll do our best to find a time for you.</p>
            <a href="/book" class="mt-4 btn btn-primary w-full block text-center">Request Appointment</a>
            <a href="tel:+13063747272" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">306.374.7272</a>
          </div>

          <!-- Sibling services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Emergency Services</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Have an urgent dental concern?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a>, we make every effort to accommodate urgent patients.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
