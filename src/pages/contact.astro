---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | Wildwood Dental Clinic — Saskatoon, SK"
  description="Contact Wildwood Dental Clinic in Saskatoon, SK. Call 306.374.7272, email reception@wildwooddentalclinic.com, or visit us at 105 – 1526 8th Street East. Book an appointment or send us a message today."
>

  <!-- ============================================================
       HERO BANNER
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-16 lg:py-20">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Contact</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Get in Touch</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Contact Wildwood Dental Clinic
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Whether you have a question, want to book an appointment, or need to reach us in an emergency — we're here to help.
      </p>
    </div>
  </section>

  <!-- ============================================================
       CONTACT QUICK-INFO ROW
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Phone card -->
        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Call Us</p>
            <a
              href="tel:+13063747272"
              class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors tabular-nums"
            >
              306.374.7272
            </a>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Mon–Fri, during office hours</p>
          </div>
        </div>

        <!-- Email card -->
        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Email Us</p>
            <a
              href="mailto:reception@wildwooddentalclinic.com"
              class="font-semibold text-sm text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors break-all"
            >
              reception@wildwooddentalclinic.com
            </a>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">We respond within one business day</p>
          </div>
        </div>

        <!-- Location card -->
        <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)] flex flex-col gap-3">
          <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-muted)] mb-1">Find Us</p>
            <p class="font-semibold text-[var(--color-brand-primary)] leading-snug">
              105 – 1526 8th Street East<br />Saskatoon, SK
            </p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Between Preston and Cumberland</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT: FORM + HOURS / MAP
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">

        <!-- LEFT: Contact form -->
        <div class="bg-white rounded-2xl shadow-xl p-8 border border-[var(--color-border-soft)]">
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
            Send Us a Message
          </h2>

          <form action="#" method="post" novalidate>

            <div class="mb-4">
              <label for="contact-name" class="block text-sm font-medium text-[var(--color-text)] mb-1">
                Full Name
              </label>
              <input
                type="text"
                id="contact-name"
                name="full_name"
                autocomplete="name"
                required
                placeholder="Jane Smith"
                class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 bg-white"
              />
            </div>

            <div class="mb-4">
              <label for="contact-phone" class="block text-sm font-medium text-[var(--color-text)] mb-1">
                Phone
              </label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                autocomplete="tel"
                placeholder="306-555-0100"
                class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 bg-white"
              />
            </div>

            <div class="mb-4">
              <label for="contact-email" class="block text-sm font-medium text-[var(--color-text)] mb-1">
                Email
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                autocomplete="email"
                required
                placeholder="jane@example.com"
                class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 bg-white"
              />
            </div>

            <div class="mb-4">
              <label for="contact-reason" class="block text-sm font-medium text-[var(--color-text)] mb-1">
                Reason for Contact
              </label>
              <select
                id="contact-reason"
                name="reason"
                required
                class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 bg-white"
              >
                <option value="" disabled selected>Select a reason…</option>
                <option value="general">General Inquiry</option>
                <option value="book">Book an Appointment</option>
                <option value="existing">Existing Patient Question</option>
                <option value="insurance">Insurance Question</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="mb-6">
              <label for="contact-message" class="block text-sm font-medium text-[var(--color-text)] mb-1">
                Message
              </label>
              <textarea
                id="contact-message"
                name="message"
                rows="4"
                required
                placeholder="How can we help you?"
                class="w-full border border-[var(--color-border)] rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-brand-accent)]/30 bg-white resize-y"
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary w-full">
              Send Message
            </button>

          </form>

          <p class="mt-4 text-sm text-[var(--color-text-muted)] leading-relaxed">
            For urgent dental concerns, please call us directly at{' '}
            <a href="tel:+13063747272" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)]">306.374.7272</a>.
          </p>
        </div>

        <!-- RIGHT: Hours + Map -->
        <div class="flex flex-col gap-6">

          <!-- Office Hours card -->
          <div class="bg-white rounded-2xl shadow-xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex items-center gap-3 mb-5">
              <svg class="text-[var(--color-brand-primary)] shrink-0" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <h2 class="font-display font-semibold text-xl text-[var(--color-brand-primary)]">Office Hours</h2>
            </div>

            <dl class="space-y-0">

              <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] py-3">
                <dt class="text-[var(--color-text)] font-medium text-sm">Monday</dt>
                <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">7:30 am – 4:30 pm</dd>
              </div>

              <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] py-3">
                <dt class="text-[var(--color-text)] font-medium text-sm">Tuesday</dt>
                <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">7:30 am – 5:30 pm</dd>
              </div>

              <!-- Wednesday — extended hours highlight -->
              <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] py-3 bg-[var(--color-surface-alt)] -mx-6 px-6 rounded-lg">
                <dt class="flex items-center gap-2 font-medium text-sm text-[var(--color-brand-primary)]">
                  Wednesday
                  <span class="inline-block text-[10px] font-semibold uppercase tracking-wide bg-[var(--color-brand-accent)] text-white px-2 py-0.5 rounded-full leading-none">
                    Extended Hours
                  </span>
                </dt>
                <dd class="tabular-nums text-sm font-semibold text-[var(--color-brand-primary)]">7:30 am – 8:30 pm</dd>
              </div>

              <div class="flex justify-between items-center border-b border-[var(--color-border-soft)] py-3">
                <dt class="text-[var(--color-text)] font-medium text-sm">Thursday</dt>
                <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">7:30 am – 6:30 pm</dd>
              </div>

              <div class="flex justify-between items-center py-3">
                <dt class="text-[var(--color-text)] font-medium text-sm">Friday</dt>
                <dd class="tabular-nums text-sm text-[var(--color-text-muted)]">7:30 am – 4:00 pm</dd>
              </div>

            </dl>
          </div>

          <!-- Map card -->
          <div class="bg-[#c8d8ea] rounded-2xl overflow-hidden shadow-xl">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2449.5!2d-106.6235!3d52.1132!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x5304f6847f12345%3A0x12345!2sWildwood+Dental+Clinic!5e0!3m2!1sen!2sca!4v1"
              width="100%"
              height="250"
              style="border:0; display:block;"
              allowfullscreen=""
              loading="lazy"
              title="Wildwood Dental Clinic location on Google Maps"
            ></iframe>
            <div class="p-4 flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-semibold text-[var(--color-brand-primary)]">105 – 1526 8th Street East</p>
                <p class="text-sm text-[var(--color-text-muted)]">Saskatoon, SK&nbsp; S7H 0T3</p>
              </div>
              <a
                href="https://maps.google.com/?q=105-1526+8th+Street+East+Saskatoon+SK"
                target="_blank"
                rel="noopener noreferrer"
                class="shrink-0 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors whitespace-nowrap"
              >
                Get Directions →
              </a>
            </div>
          </div>

        </div>
        <!-- /RIGHT -->

      </div>
    </div>
  </section>

  <!-- ============================================================
       EMERGENCY DENTAL NOTE
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-alt)]">
    <div class="container-wide">
      <div class="max-w-2xl mx-auto text-center">

        <div class="w-14 h-14 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mx-auto mb-5">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
          </svg>
        </div>

        <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-[var(--color-brand-primary)] leading-tight">
          Dental Emergency?
        </h2>

        <p class="mt-4 text-lg text-[var(--color-text)] leading-relaxed">
          If you're experiencing severe tooth pain, a knocked-out tooth, a broken tooth, or significant swelling, call us immediately at <a href="tel:+13063747272" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)]">306.374.7272</a>. We will do our best to see you the same day.
        </p>

        <a
          href="tel:+13063747272"
          class="mt-8 btn btn-primary btn-lg"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Call Now — 306.374.7272
        </a>

      </div>
    </div>
  </section>

  <!-- ============================================================
       SOCIAL / CONNECT
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-14">
    <div class="container-wide">
      <div class="text-center">

        <p class="text-sm text-[var(--color-text-on-dark-muted)] mb-5">
          Follow us for clinic updates and oral health tips.
        </p>

        <div class="flex items-center justify-center gap-4">

          <!-- Facebook -->
          <a
            href="https://www.facebook.com/WildwoodDentalClinic"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Wildwood Dental Clinic on Facebook"
            class="w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a
            href="https://www.instagram.com/wildwooddentalclinic"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Wildwood Dental Clinic on Instagram"
            class="w-12 h-12 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>

        </div>

        <div class="mt-6 flex items-center justify-center gap-4">
          <div class="w-14 h-px bg-[var(--color-brand-accent)]/50"></div>
          <a href="/patients/book" class="btn btn-primary">Book an Appointment</a>
          <div class="w-14 h-px bg-[var(--color-brand-accent)]/50"></div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
