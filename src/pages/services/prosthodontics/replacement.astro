---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const benefits = [
  {
    title: "Failing Fillings",
    description: "Old amalgam or composite fillings can crack, leak, or wear down over time. We replace them before decay can develop underneath and compromise the tooth.",
    icon: `<polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>`,
  },
  {
    title: "Worn or Cracked Crowns",
    description: "Crowns typically last 10-15 years. When they show signs of wear, chipping, or a poor fit, replacing them early prevents damage to the underlying tooth structure.",
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    title: "Loose or Broken Bridges",
    description: "A bridge that has come loose or broken can no longer protect the gap it spans. Prompt replacement prevents shifting of adjacent teeth and further bone loss.",
    icon: `<path d="M4 9h16"/><path d="M4 15h16"/><path d="M7 4v16"/><path d="M17 4v16"/>`,
  },
  {
    title: "Poorly Fitting Dentures",
    description: "As the jawbone and gums change over time, existing dentures can become ill-fitting and uncomfortable. We assess whether a reline or full replacement is the better option.",
    icon: `<rect x="3" y="4" width="18" height="16" rx="3"/><path d="M7 14h10"/>`,
  },
  {
    title: "Decay Under Existing Work",
    description: "Decay can develop beneath an older restoration without causing obvious symptoms. Regular exams allow us to catch and address this early, before the tooth is at risk.",
    icon: `<circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>`,
  },
  {
    title: "Upgraded Materials",
    description: "Older metal restorations can be replaced with modern tooth-coloured alternatives that are stronger, better-fitting, and far more aesthetically pleasing.",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  },
];
---

<BaseLayout
  title="Replacing Worn Dental Work Lethbridge | Able Family Dental"
  description="Replace old, worn, or failing fillings, crowns, and bridges in Lethbridge at Able Family Dental. Protect your teeth before small problems become bigger ones."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-replacement.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/5" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/prosthodontics/" class="text-white/80 hover:text-white transition-colors">Prosthodontics</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Replacing Worn Dental Work</span>
      </nav>
      <p class="eyebrow text-white">Prosthodontic Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Replacing Worn or Failing Dental Work
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        All dental restorations have a lifespan. When old fillings, crowns, or bridges start to fail, replacing them promptly protects the underlying tooth and avoids more extensive treatment later.
      </p>
    </div>
  </section>

  <!-- ============================================================
       CONTENT SECTION
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="eyebrow">Proactive care</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Keeping existing restorations working for you
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Dental restorations don't last forever, and that's completely normal. At each check-up, our team at Able Family Dental evaluates the condition of your existing fillings, crowns, bridges, and dentures. When we spot signs of wear, cracking, leakage, or decay underneath, we discuss your options and plan timely replacement before the situation escalates. Addressing failing dental work early is almost always simpler, less expensive, and better for the long-term health of the tooth than waiting until a crisis occurs.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map(item => (
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)] shadow-md flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-4 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
            </div>
            <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{item.description}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to restore your smile?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
