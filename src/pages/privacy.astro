---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy | Wildwood Dental Clinic"
  description="Wildwood Dental Clinic's privacy policy explains how we collect, use, and protect your information."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16">
    <div class="container-wide">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Privacy Policy</span>
      </nav>
      <h1 class="font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white">
        We Respect Your Privacy
      </h1>
      <p class="mt-3 text-sm text-[var(--color-text-on-dark-muted)]">Last Updated: March 16, 2026</p>
    </div>
  </section>

  <!-- ============================================================
       CONTENT
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="max-w-3xl space-y-10 text-[var(--color-text)] leading-relaxed">

        <!-- Introduction -->
        <div>
          <p>
            Wildwood Dental Clinic maintains a commitment to safeguarding your privacy. This policy outlines our information collection, usage, disclosure, and protection practices for website visitors and those interacting with our clinic.
          </p>
        </div>

        <!-- Information We Collect -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
            Information We Collect
          </h2>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">Personal Information</h3>
          <p class="mb-3">When contacting the clinic via website, phone, or email, you may voluntarily provide:</p>
          <ul class="space-y-2 mb-6">
            {[
              "Full name",
              "Phone number",
              "Email address",
              "Mailing address",
              "Additional information of your choosing",
            ].map(item => (
              <li class="flex items-start gap-3">
                <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">Automatically Collected Information</h3>
          <p class="mb-3">Website visits may result in automatic collection of:</p>
          <ul class="space-y-2">
            {[
              "IP address",
              "Browser type",
              "Operating system",
              "Referring URLs",
              "Pages viewed",
              "Date and time of visit",
            ].map(item => (
              <li class="flex items-start gap-3">
                <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- How We Use Your Information -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
            How We Use Your Information
          </h2>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">To Communicate With You</h3>
          <p class="mb-6">
            Contact information facilitates responses to inquiries, appointment scheduling, dental service delivery, administrative communications, appointment reminders, and service updates.
          </p>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">Service Delivery</h3>
          <p class="mb-6">
            Information is used to manage patient records, coordinate care, and provide the services you have requested.
          </p>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">Legal Compliance</h3>
          <p>
            Information may be used or disclosed to satisfy applicable laws, regulations, professional obligations, or legal processes.
          </p>
        </div>

        <!-- Information Sharing and Disclosure -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
            Information Sharing and Disclosure
          </h2>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">SMS Consent</h3>
          <p class="mb-3">
            No mobile information will be shared with third parties or affiliates for marketing or promotional purposes.
          </p>
          <p class="mb-6">
            Wildwood Dental Clinic does not sell, rent, release, or transfer your personal information or SMS consent to third parties for marketing purposes.
          </p>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">Service Providers</h3>
          <p class="mb-6">
            Trusted service providers who receive information on our behalf are required to safeguard it and use it solely for clinic-related services, including website hosting, appointment systems, and technical support.
          </p>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">Legal Requirements</h3>
          <p>
            Disclosure may occur when required by law, court order, or to protect the rights, property, patients, or others associated with Wildwood Dental Clinic.
          </p>
        </div>

        <!-- Data Security -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
            Data Security
          </h2>
          <p>
            Wildwood Dental Clinic implements reasonable administrative, technical, and physical safeguards to protect your information from unauthorized access. However, no method of electronic storage guarantees complete security, and we cannot warrant absolute protection of your information.
          </p>
        </div>

        <!-- Your Rights and Choices -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
            Your Rights and Choices
          </h2>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">Opting Out</h3>
          <p class="mb-6">
            You may opt out of marketing communications by following the instructions in any message you receive, or by contacting the clinic directly. Non-promotional messages such as appointment reminders will continue regardless.
          </p>

          <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-3">Access and Update Information</h3>
          <p>
            You may request access to, an update of, or a correction to your personal information by contacting the clinic directly.
          </p>
        </div>

        <!-- Third-Party Websites -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
            Third-Party Websites
          </h2>
          <p>
            Our website may contain links to external websites. Wildwood Dental Clinic is not responsible for the privacy practices of those sites. We encourage you to review the privacy policies of any third-party websites you visit independently.
          </p>
        </div>

        <!-- Children's Privacy -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
            Children's Privacy
          </h2>
          <p>
            This website is not intended for children under the age of 13. We do not knowingly collect personal information from children under 13 without verifiable parental consent. If we become aware that such information has been collected, we will take steps to delete it promptly.
          </p>
        </div>

        <!-- Changes to This Policy -->
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
            Changes to This Privacy Policy
          </h2>
          <p>
            We may update this privacy policy from time to time. Any changes will be posted on this page with a revised date. We encourage you to review this policy periodically.
          </p>
        </div>

        <!-- Contact Us -->
        <div class="bg-[var(--color-surface-cool)] rounded-2xl p-7 border border-[var(--color-border-soft)]">
          <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-4">
            Contact Us
          </h2>
          <p class="mb-5">If you have questions about this privacy policy or our data practices, please contact us:</p>
          <div class="space-y-1 text-[var(--color-text)]">
            <p class="font-semibold">Wildwood Dental Clinic</p>
            <p>105 – 1526 8th Street E</p>
            <p>Saskatoon, SK&nbsp; S7H 0T3</p>
            <p class="mt-3">
              <span class="text-[var(--color-text-muted)]">Email: </span>
              <a href="mailto:reception@wildwooddentalclinic.com" class="text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">reception@wildwooddentalclinic.com</a>
            </p>
            <p>
              <span class="text-[var(--color-text-muted)]">Phone: </span>
              <a href="tel:+13063747272" class="text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">306.374.7272</a>
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
