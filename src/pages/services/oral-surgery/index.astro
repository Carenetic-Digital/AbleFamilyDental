---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    title: "Tooth Extractions",
    href: "/services/oral-surgery/extractions",
    description: "When a tooth cannot be saved, extraction is performed carefully to preserve surrounding bone and tissue. Comfort measures are discussed and provided throughout the procedure.",
    icon: `<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>`,
  },
  {
    title: "Wisdom Tooth Extraction",
    href: "/services/oral-surgery/wisdom-teeth",
    description: "When wisdom teeth are impacted, crowded, or difficult to keep clean, extraction may be recommended. We offer both routine and surgical removal.",
    icon: `<path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/>`,
  },
  {
    title: "Dental Implants",
    href: "/services/oral-surgery/implants",
    description: "Dental implants replace missing tooth roots with a titanium post, providing a stable foundation for a crown, bridge, or denture.",
    icon: `<line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
  },
];
---

<BaseLayout
  title="Oral Surgery & Other Services | Wildwood Dental Clinic Saskatoon"
  description="Oral surgery services at Wildwood Dental Clinic in Saskatoon — tooth extractions, wisdom tooth removal, and dental implants."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
      <svg class="w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice">
        <path d="M0 280 C 200 265, 400 285, 600 275 C 700 270, 750 278, 800 273 L800 300 L0 300 Z" fill="white"/>
      </svg>
    </div>
    <div class="container-wide relative py-16 lg:py-20">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Oral Surgery &amp; Other</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Oral Surgery &amp; Other Services</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Surgical Care, Delivered with Comfort
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        When a tooth cannot be saved, or when wisdom teeth cause problems, our team provides careful, comfortable surgical care. We also place dental implants to replace missing teeth with a lasting, natural-feeling result.
      </p>
    </div>
  </section>

  <!-- ============================================================
       SERVICE CARDS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <div class="max-w-2xl mb-12">
        <p class="text-[var(--color-text)] text-lg leading-relaxed">
          Beyond cleanings, fillings, and cosmetic work, Wildwood Dental provides a broader range of care — from paediatric visits and dental emergencies to oral appliances, surgical extractions, and sedation. These services are delivered by the same team in a familiar environment, so care stays coordinated and accessible.
        </p>
        <div class="mt-6 bg-[var(--color-surface-alt)] rounded-2xl p-5 border border-[var(--color-border-soft)] flex gap-4 items-start">
          <svg class="shrink-0 mt-0.5 text-[var(--color-brand-primary)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Oral surgery procedures at Wildwood Dental Clinic are performed by our general dentist team. Our dentists are not licensed specialists in oral and maxillofacial surgery.</p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(svc => (
          <div class="bg-white rounded-2xl p-7 shadow-md border border-[var(--color-border-soft)] flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-5 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon} />
            </div>
            <h3 class="font-display font-semibold text-[length:var(--text-xl)] text-[var(--color-brand-primary)] leading-snug">
              {svc.title}
            </h3>
            <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">
              {svc.description}
            </p>
            <a href={svc.href} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
              Learn More
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       EMERGENCY NOTICE
       ============================================================ -->
  <section class="bg-[var(--color-surface-alt)] py-14">
    <div class="container-wide">
      <div class="max-w-2xl mx-auto text-center">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-[var(--color-brand-primary)] mb-6">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
          Dental Emergency?
        </h2>
        <p class="mt-4 text-[var(--color-text)] text-lg leading-relaxed">
          Call <a href="tel:+13063747272" class="text-[var(--color-brand-primary)] font-semibold hover:text-[var(--color-brand-accent)] transition-colors">306.374.7272</a> — we'll do our best to see you the same day.
        </p>
        <a href="/services/emergency" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
          Learn what to do in a dental emergency
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white">Have questions about your treatment?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> or book an appointment.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book" class="btn btn-primary btn-lg">Book an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
