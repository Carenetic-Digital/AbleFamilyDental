            </svg>
            <span class="flex-1 h-px bg-[var(--color-brand-secondary)]"></span>
          </div>

          <!-- FAQ groups -->
          <div class="space-y-2">
            {faqGroups.map((group) => (
              <div id={group.id} class="scroll-mt-28 space-y-2">
                  {group.questions.map((item, i) => (
                    <details class="faq-item group border border-[var(--color-brand-secondary)] rounded-xl bg-white overflow-hidden" open={i === 0 && group.id === "new-patients"}>
                      <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none font-semibold text-[15.5px] text-[var(--color-brand-primary)] select-none hover:bg-[var(--color-surface-cool)] transition-colors">
                        <span>{item.q}</span>
                        <!-- Plus/minus toggle -->
                        <span class="faq-pm flex-shrink-0 w-6 h-6 rounded-full border border-[var(--color-brand-secondary)] bg-[var(--color-surface-cool)] flex items-center justify-center transition-colors group-open:bg-[var(--color-brand-primary)] group-open:border-[var(--color-brand-primary)]" aria-hidden="true">
                          <svg class="w-3 h-3 text-[var(--color-brand-accent)] group-open:text-white transition-colors" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                            <line x1="6" y1="2" x2="6" y2="10" class="faq-minus-line"/>
                            <line x1="2" y1="6" x2="10" y2="6"/>
                          </svg>
                        </span>
                      </summary>
                      <div class="px-5 pb-5 pt-1 text-[var(--color-text)] leading-relaxed text-[15px]">
                        {item.a}
                      </div>
                    </details>
                  ))}
              </div>
            ))}
          </div>

        </div>

      </div>
    </div>
  </section>


  <!-- ============================================================
       STILL HAVE QUESTIONS — CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-12">
    <div class="container-wide">
      <div class="flex flex-col sm:flex-row items-center gap-6 sm:gap-8">

        <span class="flex-shrink-0 w-12 h-12 rounded-full bg-white/10 flex items-center justify-center" aria-hidden="true">
          <svg class="w-6 h-6 text-[var(--color-brand-accent-soft)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/>
          </svg>
        </span>

        <div class="text-center sm:text-left flex-1">
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-white">Still Have Questions?</h2>
          <p class="mt-1 text-[var(--color-text-on-dark-muted)]">Our friendly team is always happy to help. Reach out and we'll be glad to assist you.</p>
        </div>

        <span class="hidden sm:block w-px h-12 bg-white/20 flex-shrink-0" aria-hidden="true"></span>

        <a href="/book" class="btn btn-primary flex-shrink-0">
          Request Appointment
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>

      </div>
    </div>
  </section>


  <!-- ============================================================
       FEATURE ROW — WHY WILDWOOD
       ============================================================ -->
  <section class="pt-[var(--spacing-section)] pb-8 bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((feat) => (
          <div class="flex items-start gap-4 bg-white rounded-2xl border border-[var(--color-brand-secondary)] px-5 py-5 shadow-sm">
            <span class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-surface-cool)] border border-[var(--color-brand-secondary)] flex items-center justify-center mt-0.5" aria-hidden="true">
              <svg class="w-5 h-5 text-[var(--color-brand-accent)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={feat.icon} />
              </svg>
            </span>
            <div>
              <p class="font-semibold text-[var(--color-brand-primary)] text-[15px] leading-snug">{feat.title}</p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">{feat.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hide the vertical bar on the + when details is open */
  details[open] .faq-minus-line {
    display: none;
  }
</style>
