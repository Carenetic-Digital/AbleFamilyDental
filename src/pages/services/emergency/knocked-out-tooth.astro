---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "Emergency Dental Care", href: "/services/emergency" },
  { name: "Toothache & Dental Pain", href: "/services/emergency/toothache" },
  { name: "Broken or Chipped Tooth", href: "/services/emergency/broken-tooth" },
  { name: "Knocked-Out Tooth", href: "/services/emergency/knocked-out-tooth", current: true },
  { name: "Urgent Appointments", href: "/services/emergency/appointments" },
];
---

<BaseLayout
  title="Knocked-Out Tooth | Emergency Dental Care | Wildwood Dental Clinic"
  description="Knocked out a tooth in Saskatoon? Call Wildwood Dental Clinic immediately at 306.374.7272. Time is critical, act quickly and call us right away."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/bugherd/KnockedOutTooth.png"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/emergency" class="hover:text-white transition-colors">Emergency</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Knocked-Out Tooth</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent-soft)]">Emergency Dental Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Knocked-Out Tooth
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        A knocked-out tooth is one of the most time-sensitive dental emergencies. Call us immediately at <a href="tel:+13063747272" class="text-white font-semibold">306.374.7272</a>, acting quickly matters.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Urgent callout -->
          <div class="bg-[var(--color-surface-alt)] rounded-2xl p-6 border-l-4 border-[var(--color-brand-accent)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.57 3.38 2 2 0 0 1 3.54 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.83a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">Call us immediately, time matters</h3>
                <p class="mt-1.5 text-[var(--color-text-muted)] leading-relaxed">
                  A knocked-out adult tooth may be able to be replanted if it is handled correctly and we see you quickly. While there are no guarantees, the sooner the tooth is assessed, the better the possibility of replantation being a viable option. Do not delay, call <a href="tel:+13063747272" class="text-[var(--color-brand-primary)] font-semibold hover:text-[var(--color-brand-accent)] transition-colors">306.374.7272</a> right now while you follow the steps below.
                </p>
              </div>
            </div>
          </div>

          <!-- Image break -->
          <div class="rounded-2xl overflow-hidden">
            <img
              src="/images/bugherd/Dr_M_and_Child.png"
              alt="Dr. M and child patient at Wildwood Dental Clinic"
              width="800"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full h-56 sm:h-72 object-cover"
            />
          </div>


          <!-- What to do right now -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What to do right now
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                How you handle the tooth in the next few minutes can affect whether replantation is possible. Follow these steps carefully:
              </p>
              <ol class="space-y-4 mt-2">
                {[
                  {
                    step: "Pick up the tooth by the crown",
                    detail: "Handle the tooth by the white part (the crown), not the root. The root surface contains delicate cells that are important for replantation. Touching the root can damage these cells."
                  },
                  {
                    step: "Rinse gently if it is dirty",
                    detail: "If the tooth is visibly dirty, rinse it very gently with clean water for no more than a few seconds. Do not scrub the tooth, use soap, or remove any tissue that may still be attached to the root."
                  },
                  {
                    step: "Keep the tooth moist",
                    detail: "The tooth must not dry out. The options, from most to least preferable, are: gently re-inserting it into the socket (if the patient is calm and old enough to hold it safely), placing it between the patient's cheek and gum, or storing it in a container of cold milk. Plain water and letting the tooth dry out in open air are not suitable."
                  },
                  {
                    step: "Come in immediately",
                    detail: "Get to our clinic as quickly as possible. Call ahead so we can be ready for you when you arrive."
                  },
                ].map((item, i) => (
                  <li class="flex gap-4">
                    <div class="w-8 h-8 rounded-full bg-[var(--color-brand-primary)] text-white flex items-center justify-center font-semibold text-sm shrink-0 mt-0.5">{i + 1}</div>
                    <div>
                      <p class="font-semibold text-[var(--color-brand-primary)]">{item.step}</p>
                      <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">{item.detail}</p>
                    </div>
                  </li>
                ))}
              </ol>
            </div>
          </div>

          <!-- Why speed matters -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Why acting quickly matters
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                When a tooth is knocked out, the ligament fibres that attach the root to the bone are torn. These cells can remain viable for a period of time if the tooth is kept moist, but they begin to deteriorate as time passes and if the tooth dries out.
              </p>
              <p>
                The sooner the tooth is replanted, either by the patient, a parent, or a dental professional, the more likely those cells are to be in a condition that can support healing. There is no specific window that applies to every situation, as tooth condition, storage medium, and individual factors all play a role. What is clear is that prompt action gives the best chance.
              </p>
              <p>
                Even if replantation is not possible, coming in quickly allows us to assess the socket, manage any trauma to the surrounding tissue, and discuss replacement options.
              </p>
            </div>
          </div>

          <!-- Baby teeth note -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-accent)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">A note about baby teeth</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  If a baby (primary) tooth has been knocked out, do not attempt to replant it yourself. Replanting a baby tooth is generally not recommended, as it can interfere with the developing permanent tooth below. Bring the child in and we will assess the area, check for any injury to the surrounding tissues, and advise on next steps.
                </p>
              </div>
            </div>
          </div>

          <!-- Sports note -->
          <div class="bg-[var(--color-surface-alt)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">If the injury involved a fall or sports collision</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  If the tooth was knocked out as part of a fall, collision, or sports injury that involved the head or neck, ensure there is no concern about concussion or spinal injury before moving the person. If there is any uncertainty, call 911 or proceed to the nearest hospital emergency department first.
                </p>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Call Us Immediately</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">A knocked-out tooth is time-sensitive. Call now.</p>
            <a href="/book" class="mt-4 btn btn-primary w-full block text-center">Request Appointment</a>
            <a href="tel:+13063747272" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">306.374.7272</a>
          </div>

          <!-- Sibling services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Emergency Services</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Tooth knocked out? Call us right now.</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+13063747272" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">306.374.7272</a> immediately, every minute counts.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a href="/contact" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
