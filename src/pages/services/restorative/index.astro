---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    title: "Tooth-Colored Fillings",
    href: "/services/restorative/fillings",
    description: "Tooth-coloured fillings are used to restore areas of decay or minor damage. Treatment is based on the condition of the tooth and clinical assessment.",
    bullets: [
      "Material selected to match surrounding tooth structure",
      "Used for small to moderate areas of damage",
      "Placed during a clinical visit",
      "Ongoing care discussed as part of treatment",
    ],
    icon: `<path d="M12 2C9 2 7 4 7 7c0 1.5.5 2.5 1 3.5.5 1 1 2 1 3.5 0 2 .5 4 3 4 1 0 1.5-1 2-1.5.5.5 1 1.5 2 1.5 2.5 0 3-2 3-4 0-1.5.5-2.5 1-3.5.5-1 1-2 1-3.5 0-3-2-5-5-5z"/>`,
  },
  {
    title: "Crowns & Bridges",
    href: "/services/restorative/crowns-bridges",
    description: "Crowns and bridges are used to restore damaged teeth or replace missing teeth as part of restorative treatment planning.",
    bullets: [
      "Crown placed over a prepared tooth",
      "Bridge used to replace one or more missing teeth",
      "May involve more than one appointment",
      "Treatment planned based on individual needs",
    ],
    icon: `<path d="M2 4l3 12h14l3-12-6 7-4-7-4 7-6-7z"/>`,
  },
  {
    title: "Inlays & Onlays",
    href: "/services/restorative/inlays-onlays",
    description: "Inlays and onlays are custom restorations used when a tooth requires more coverage than a filling but less than a full crown.",
    bullets: [
      "Used for moderate tooth damage",
      "Custom-made based on the treated tooth",
      "Placed after preparation of the affected area",
      "Follow-up care discussed as part of treatment",
    ],
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/>`,
  },
];

const faqs = [
  {
    q: "When is restorative dental treatment recommended?",
    a: "Restorative treatment may be recommended when teeth are affected by decay, damage, or tooth loss, based on clinical assessment.",
  },
  {
    q: "What is the difference between fillings, crowns, and inlays/onlays?",
    a: "These treatments differ based on how much of the tooth is affected. Fillings are typically used for smaller areas of damage, while crowns and inlays/onlays are used when more of the tooth structure requires restoration.",
  },
];
---

<BaseLayout
  title="Restorative Dentistry | Able Family Dental Lethbridge"
  description="Restorative dentistry at Able Family Dental in Lethbridge, fillings, crowns, bridges, and inlays/onlays planned based on your individual needs and clinical assessment."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-restorative-pexels.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Restorative</span>
      </nav>
      <p class="eyebrow text-white">Restorative Dentistry</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Restorative Dentistry in Lethbridge
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Restorative dentistry focuses on repairing and replacing teeth to support oral function and overall oral health. At Able Family Dental in Lethbridge, treatment is planned based on your individual needs and clinical assessment.
      </p>
    </div>
  </section>

  <!-- ============================================================
       VALUE BLOCK
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
            Restorative Dentistry Services
          </h2>
          <p class="mt-4 text-[var(--color-text)] leading-relaxed">
            Restorative treatments vary depending on the extent of damage to a tooth. Minor concerns may be addressed with fillings, while more extensive damage or tooth loss may require crowns, bridges, or custom restorations.
          </p>
          <ul class="mt-6 space-y-3">
            {["Tooth-Coloured Fillings", "Crowns & Bridges", "Inlays & Onlays"].map(item => (
              <li class="flex items-center gap-3 text-[var(--color-text)]">
                <span class="w-5 h-5 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
          <a href="/book/" class="mt-8 btn btn-primary inline-flex">Book Appointment</a>
          <a href="/refer/" class="mt-8 btn btn-outline inline-flex">Refer Patient</a>>
        </div>

        <div class="bg-[var(--color-surface-cool)] rounded-2xl p-8 border border-[var(--color-border-soft)]">
          <svg class="text-[var(--color-brand-primary)] mb-4" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2C9 2 7 4 7 7c0 1.5.5 2.5 1 3.5.5 1 1 2 1 3.5 0 2 .5 4 3 4 1 0 1.5-1 2-1.5.5.5 1 1.5 2 1.5 2.5 0 3-2 3-4 0-1.5.5-2.5 1-3.5.5-1 1-2 1-3.5 0-3-2-5-5-5z"/>
          </svg>
          <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">A conservative approach</h3>
          <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
            Our team at Able Family Dental works to preserve as much natural tooth structure as possible. Treatment options are discussed openly so you can make informed decisions about your care.
          </p>
          <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
            If you have questions about a specific restorative treatment, our team is happy to walk you through what to expect before any work begins.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================================
       SERVICE CARDS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(svc => (
          <div class="bg-white rounded-2xl p-7 shadow-md border border-[var(--color-border-soft)] flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-5 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon} />
            </div>
            <h3 class="font-display font-semibold text-[length:var(--text-xl)] text-[var(--color-brand-primary)] leading-snug">
              {svc.title}
            </h3>
            <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
              {svc.description}
            </p>
            <ul class="mt-4 space-y-2 flex-1">
              {svc.bullets.map(b => (
                <li class="flex items-start gap-2 text-xs text-[var(--color-text-muted)]">
                  <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent)]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                  {b}
                </li>
              ))}
            </ul>
            <a href={svc.href} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
              Learn More
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       MINI FAQ
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide max-w-3xl">
      <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-8">
        Common Questions
      </h2>
      <div class="space-y-6">
        {faqs.map(faq => (
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">{faq.q}</h3>
            <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to restore your smile?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
