---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import StructuredData from '../components/StructuredData.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PreFooter from '../components/PreFooter.astro';
interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  showMobileBar?: boolean;
  showPreFooter?: boolean;
}

const {
  title,
  description = 'Able Family Dental offers family dentistry and implants in Lethbridge, AB. We welcome new patients of all ages — call 403.327.7202 to book.',
  image = '/images/og-default.jpg',
  noindex = false,
  showMobileBar = true,
  showPreFooter = true,
} = Astro.props;

const siteURL = Astro.site ?? new URL('https://ablefamilydental.com/');
const siteRoot = new URL('/', siteURL).href;
const organizationId = 'https://ablefamilydental.com/#organization';
const websiteId = 'https://ablefamilydental.com/#website';
const logoURL = new URL('/images/logos/able-family-dental-logo.png', siteURL).href;
const ogImageURL = new URL('/images/og-default.jpg', siteURL).href;

const businessData = {
  "@id": "https://ablefamilydental.com/#dentist",
  name: "Able Family Dental",
  url: siteRoot,
  telephone: "+1-403-327-7202",
  email: "reception@ablefamilydental.com",
  image: ogImageURL,
  logo: logoURL,
  parentOrganization: { "@id": organizationId },
  address: {
    "@type": "PostalAddress",
    streetAddress: "511 5th Street South",
    addressLocality: "Lethbridge",
    addressRegion: "AB",
    addressCountry: "CA",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 49.6922,
    longitude: -112.8422,
  },
  openingHoursSpecification: [
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Monday", "Friday"], opens: "08:00", closes: "17:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: ["Tuesday", "Thursday"], opens: "08:00", closes: "18:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: "Wednesday", opens: "07:00", closes: "17:00" },
    { "@type": "OpeningHoursSpecification", dayOfWeek: "Saturday", opens: "09:00", closes: "14:00" },
  ],
  areaServed: { "@type": "City", name: "Lethbridge" },
};

const organizationData = {
  "@id": organizationId,
  name: "Able Family Dental",
  url: siteRoot,
  logo: logoURL,
  image: ogImageURL,
  telephone: "+1-403-327-7202",
  email: "reception@ablefamilydental.com",
  sameAs: [
    "https://www.facebook.com/ablefamilydental",
    "https://www.instagram.com/ablefamilydental/",
    "https://maps.app.goo.gl/pAJAeiNddySjEkKc8",
  ],
};

const websiteData = {
  "@id": websiteId,
  name: "Able Family Dental",
  url: siteRoot,
  publisher: { "@id": organizationId },
  inLanguage: "en-CA",
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-WQKBTTT');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <meta name="theme-color" content="#008080" />

    <SEOHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
    />

    <StructuredData type="Organization" data={organizationData} />
    <StructuredData type="WebSite" data={websiteData} />
    <StructuredData type="LocalBusiness" data={businessData} />


  </head>
  <body class="font-body text-[var(--color-text)] bg-[var(--color-surface)] antialiased overflow-x-hidden">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WQKBTTT"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <a href="#main" class="skip-link">Skip to main content</a>

    <Header />

    <main id="main">
      <slot />
    </main>

    {showPreFooter && <PreFooter />}

    <Footer />

    {showMobileBar && (
      <div class="md:hidden fixed bottom-0 inset-x-0 z-40 grid grid-cols-2 border-t border-[var(--color-border)] bg-white shadow-[0_-4px_16px_rgba(30,51,82,0.10)]" aria-label="Quick contact actions">
        <a href="tel:+14033277202" class="flex items-center justify-center gap-2 py-3.5 text-[var(--color-brand-primary)] font-semibold border-r border-[var(--color-border)]">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Call
        </a>
        <a href="/book/" class="flex items-center justify-center gap-2 py-3.5 bg-[var(--color-brand-accent-btn)] text-white font-semibold">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Request
        </a>
      </div>
      <div class="md:hidden h-16" aria-hidden="true"></div>
    )}

  </body>
</html>
