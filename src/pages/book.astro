---
import BaseLayout from '../layouts/BaseLayout.astro';

const bookingFormUrl =
  'https://can3.recallmax.com/rsm/request/public/bookOnline/patient/layout.html?a=t4ttSwyQ0NkQv9DLpa1kYRBbE_cNvZb54X';
const directionsUrl = 'https://maps.app.goo.gl/pAJAeiNddySjEkKc8';
const mapEmbedUrl =
  'https://www.google.com/maps?q=Able+Family+Dental%2C+511+5th+Street+South%2C+Lethbridge%2C+AB&output=embed';
---

<BaseLayout
  title="Book an Appointment | Able Family Dental, Lethbridge"
  description="Schedule your dental appointment online at Able Family Dental on 5th Street South in Lethbridge. New and existing patients welcome. Call 403.327.7202."
>

  <section class="section-y bg-white">
    <div class="container-wide">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-muted)] mb-8" aria-label="Breadcrumb">
        <a href="/" class="inline-flex items-center gap-1.5 text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Home
        </a>
        <span aria-hidden="true">›</span>
        <span class="text-[var(--color-text)]">Book an Appointment</span>
      </nav>

      <div class="grid lg:grid-cols-[minmax(0,1fr)_340px] gap-10 items-start">

        <!-- LEFT: Heading + booking form -->
        <div>
          <h1 class="font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-[var(--color-brand-primary)]">
            Book an Appointment
          </h1>
          <p class="mt-3 text-lg text-[var(--color-text-muted)] leading-relaxed">
            Schedule your dental visit online. It’s quick and easy!
          </p>

          <div class="mt-8 bg-white rounded-2xl border border-[var(--color-border-soft)] shadow-sm overflow-hidden">
            <iframe
              id="RecallMaxBooking"
              title="Book an Appointment"
              src={bookingFormUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full border-0 block"
              style="min-height: 920px; height: 920px;"
            ></iframe>
          </div>
        </div>

        <!-- RIGHT: Plan Your Visit + map -->
        <aside class="space-y-5 lg:sticky lg:top-24">
          <div class="bg-white rounded-2xl border border-[var(--color-border-soft)] p-6 shadow-sm">
            <h2 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] mb-5">
              Plan Your Visit
            </h2>

            <div class="flex items-start gap-3">
              <svg class="shrink-0 mt-0.5 text-[var(--color-text-muted)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <p class="font-semibold text-[var(--color-text)]">Able Family Dental</p>
                <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  511 5th Street South<br />
                  Lethbridge, Alberta
                </p>
              </div>
            </div>

            <a
              href="/contact/"
              class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              View clinic details &amp; hours
            </a>

            <div class="mt-5 pt-5 border-t border-[var(--color-border-soft)]">
              <a
                href={directionsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-start gap-3 group"
              >
                <svg class="shrink-0 mt-0.5 text-[var(--color-brand-primary)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
                <span>
                  <span class="block font-semibold text-[var(--color-brand-primary)] group-hover:text-[var(--color-brand-accent-hover)] transition-colors">
                    Get Directions
                  </span>
                  <span class="block mt-1 text-sm text-[var(--color-text-muted)]">
                    Street parking available nearby
                  </span>
                </span>
              </a>
            </div>
          </div>

          <div class="rounded-2xl overflow-hidden border border-[var(--color-border-soft)] shadow-sm bg-[var(--color-surface-cool)]">
            <iframe
              src={mapEmbedUrl}
              width="100%"
              height="240"
              style="border:0;"
              loading="lazy"
              allowfullscreen=""
              referrerpolicy="no-referrer-when-downgrade"
              title="Able Family Dental location on Google Maps"
            ></iframe>
          </div>
        </aside>
      </div>

      <!-- Bottom visit info: Parking, Arrive Early, Accessibility, Transit -->
      <div class="mt-12 rounded-2xl bg-[var(--color-surface-cool)] border border-[var(--color-border-soft)] p-6 sm:p-8">
        <div class="grid sm:grid-cols-2 gap-8 lg:gap-10">

          <div>
            <div class="flex items-center gap-3 mb-3">
              <svg class="text-[var(--color-brand-primary)] shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>
              <h2 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">Parking</h2>
            </div>
            <ul class="space-y-2 text-sm text-[var(--color-text-muted)] leading-relaxed list-disc pl-5">
              <li>Street parking is available on 5th Street South and surrounding streets</li>
              <li>On-site parking is not available at our location</li>
              <li>If you have specific parking or access needs, please contact our office</li>
            </ul>
            <p class="mt-3 text-xs text-[var(--color-text-muted)]">* Please allow a few extra minutes for parking during busy times.</p>
          </div>

          <div>
            <div class="flex items-center gap-3 mb-3">
              <svg class="text-[var(--color-brand-primary)] shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <h2 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">Arrive Early for Your Appointment</h2>
            </div>
            <ul class="space-y-2 text-sm text-[var(--color-text-muted)] leading-relaxed list-disc pl-5">
              <li>Arrive 10 minutes early for your first appointment</li>
              <li>Bring a piece of photo ID and your insurance card (if applicable)</li>
              <li>New patients can complete forms online in advance via the <a href="/existing-patients/" class="text-[var(--color-brand-primary)] font-medium hover:text-[var(--color-brand-accent-hover)]">Patients</a> page</li>
            </ul>
          </div>

          <div>
            <div class="flex items-center gap-3 mb-3">
              <img
                src="/images/icons/accessibility-wheelchair.png"
                alt=""
                width="22"
                height="22"
                class="shrink-0 w-[22px] h-[22px]"
                aria-hidden="true"
              />
              <h2 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">Accessibility</h2>
            </div>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Step-free, wheelchair-accessible entry is available at the rear of the clinic.
            </p>
          </div>

          <div>
            <div class="flex items-center gap-3 mb-3">
              <svg class="text-[var(--color-brand-primary)] shrink-0" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 6v6"/><path d="M15 6v6"/><path d="M2 12h19.6"/><path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4c-1.1 0-2.1.8-2.4 1.8l-1.4 5c-.1.4-.2.8-.2 1.2 0 .4.1.8.2 1.2.3 1.1.8 2.8.8 2.8h3"/><circle cx="7" cy="18" r="2"/><circle cx="15" cy="18" r="2"/></svg>
              <h2 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">Public Transit</h2>
            </div>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
              Lethbridge Transit routes are located nearby our 5th Street South location.
            </p>
          </div>

        </div>
      </div>

    </div>
  </section>

</BaseLayout>
