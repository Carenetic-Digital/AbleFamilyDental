---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clinic } from '../data/clinic';

const bookingFormUrl =
  'https://can3.recallmax.com/rsm/request/public/bookOnline/patient/layout.html?a=t4ttSwyQ0NkQv9DLpa1kYRBbE_cNvZb54X';
const directionsUrl = 'https://maps.app.goo.gl/pAJAeiNddySjEkKc8';

const highlights = [
  'Accepting New Patients',
  'Request Online',
  'Family Dentistry',
  'Proudly Accepting Eligible CDCP Patients',
];

const services = [
  {
    title: 'General Dentistry',
    body: 'Preventive care, cleanings, examinations, and ongoing dental care to help keep your smile healthy.',
    href: '/services/preventive/',
  },
  {
    title: 'Cosmetic Dentistry',
    body: 'Enhance the appearance of your smile with treatment options tailored to your individual goals.',
    href: '/services/cosmetic/',
  },
  {
    title: 'Restorative Dentistry',
    body: 'Restore the health, function, and appearance of your smile with personalized restorative care.',
    href: '/services/restorative/',
  },
  {
    title: 'Orthodontic Care',
    body: 'If appropriate for your oral health needs, we\'ll discuss orthodontic treatment options, including Invisalign® clear aligners.',
    href: '/services/orthodontics/',
  },
];

const steps = [
  {
    number: 1,
    title: 'Warm Welcome',
    body: 'Our friendly team will welcome you and help you feel comfortable from the moment you arrive.',
  },
  {
    number: 2,
    title: 'Comprehensive Examination',
    body: 'Your dentist will perform a comprehensive examination and discuss any concerns or questions you may have.',
  },
  {
    number: 3,
    title: 'Digital X-Rays (if required)',
    body: 'If clinically appropriate, digital X-rays may be taken to help evaluate your oral health.',
  },
  {
    number: 4,
    title: 'Discuss Your Goals',
    body: 'We\'ll take the time to understand your oral health concerns, priorities, and what you\'d like to achieve.',
  },
  {
    number: 5,
    title: 'Personalized Treatment Options',
    body: 'If treatment is recommended, we\'ll review the options that may be appropriate for your needs and answer any questions you have.',
  },
  {
    number: 6,
    title: 'Next Steps',
    body: 'Together, we\'ll develop a personalized care plan and schedule any future appointments as needed.',
  },
];
---

<BaseLayout
  title="Dental Care That Feels Like Home | Able Family Dental Lethbridge"
  description={`Able Family Dental in Lethbridge is welcoming new patients and families. Unhurried care, clear guidance, and a team ready for you. Call ${clinic.phoneDisplay} or request an appointment online.`}
  showHeader={false}
  showFooter={false}
  showPreFooter={false}
  showMobileBar={true}
  mobileRequestHref="#request"
>

  <!-- Slim landing header -->
  <header class="bg-white border-b border-[var(--color-border-soft)] sticky top-0 z-50">
    <div class="container-wide flex items-center justify-between gap-4 py-3">
      <a href="/" class="inline-flex items-center shrink-0" aria-label="Able Family Dental home">
        <img
          src="/images/logos/able-family-dental-logo-vertical.png"
          alt="Able Family Dental"
          width="340"
          height="214"
          class="h-12 sm:h-14 w-auto"
          loading="eager"
          decoding="async"
        />
      </a>
      <div class="flex items-center gap-2 sm:gap-4">
        <a
          href="/"
          class="hidden sm:inline-flex text-sm font-medium text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent-hover)] transition-colors"
        >
          Visit Main Site
        </a>
        <a
          href={`tel:${clinic.phoneTel}`}
          class="hidden md:inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-primary)] tabular-nums hover:text-[var(--color-brand-accent-hover)] transition-colors"
        >
          {clinic.phoneDisplay}
        </a>
        <a href="#request" class="btn btn-primary text-sm px-4 py-2.5">Request Appointment</a>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[46%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/about/able-family-dental-exterior.png"
        alt=""
        width="1449"
        height="1086"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover object-[55%_center]"
      />
      <div class="absolute inset-y-0 left-0 w-2/5" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[58%]">
      <p class="eyebrow text-white">Now welcoming new patients</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Dental care that feels like home&nbsp;— from day&nbsp;one
      </h1>
      <p class="mt-4 text-xl sm:text-2xl font-display font-semibold text-[var(--color-brand-accent-soft)] leading-snug">
        Able Family Dental is ready for you.
      </p>
      <p class="mt-5 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Finding the right dental team makes all the difference. We take the time to understand your needs and deliver personalized care in a comfortable, welcoming environment — for kids, parents, and everyone in between.
      </p>
      <ul class="mt-8 grid sm:grid-cols-2 gap-3 max-w-xl">
        {highlights.map((item) => (
          <li class="flex items-start gap-2.5 text-sm text-white">
            <svg class="shrink-0 mt-0.5 text-[var(--color-brand-accent-soft)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
            {item}
          </li>
        ))}
      </ul>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href="#request" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a href="/cdcp/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Learn About CDCP</a>
      </div>
    </div>
  </section>

  <!-- Request an Appointment -->
  <section id="request" class="section-y bg-white scroll-mt-24">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[minmax(0,1fr)_340px] gap-10 items-start">
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
            Request an Appointment
          </h2>
          <p class="mt-3 text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
            We'd love to welcome you to Able Family Dental. Complete the form below and a member of our team will contact you to help schedule your visit.
          </p>
          <div class="mt-8 bg-white rounded-2xl border border-[var(--color-border-soft)] shadow-sm overflow-hidden">
            <iframe
              id="RecallMaxBooking"
              title="Request an Appointment"
              src={bookingFormUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full border-0 block"
              style="min-height: 920px; height: 920px;"
            ></iframe>
          </div>
        </div>

        <aside class="space-y-5 lg:sticky lg:top-28">
          <div class="rounded-2xl overflow-hidden border border-[var(--color-border-soft)] shadow-sm">
            <img
              src="/images/about/able-family-dental-exterior.png"
              alt="Able Family Dental clinic entrance in Lethbridge"
              width="1449"
              height="1086"
              loading="lazy"
              decoding="async"
              class="w-full aspect-[4/3] object-cover"
            />
          </div>
          <div class="bg-[var(--color-surface-cool)] rounded-2xl border border-[var(--color-border-soft)] p-6">
            <p class="font-semibold text-[var(--color-brand-primary)]">{clinic.name}</p>
            <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">
              {clinic.streetAddress}<br />
              {clinic.city}, {clinic.regionAbbr}
            </p>
            <p class="mt-3 text-sm text-[var(--color-text-muted)]">
              Street parking available nearby
            </p>
            <div class="mt-5 flex flex-col gap-2">
              <a
                href={directionsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-primary w-full text-center"
              >
                Get Directions
              </a>
              <a href="/contact/" class="btn btn-outline w-full text-center">
                Contact &amp; Hours
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Comprehensive Dental Care -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">
      <div class="max-w-2xl">
        <h2 class="font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Comprehensive Dental Care
        </h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 gap-6">
        {services.map((svc) => (
          <a
            href={svc.href}
            class="group bg-white rounded-2xl border border-[var(--color-border-soft)] p-7 shadow-sm hover:shadow-md hover:border-[var(--color-brand-secondary)] transition-all"
          >
            <h3 class="font-display font-semibold text-xl text-[var(--color-brand-primary)] group-hover:text-[var(--color-brand-accent-hover)] transition-colors">
              {svc.title}
            </h3>
            <p class="mt-3 text-sm text-[var(--color-text-muted)] leading-relaxed">
              {svc.body}
            </p>
          </a>
        ))}
      </div>
      <p class="mt-8 text-[var(--color-text-muted)] leading-relaxed max-w-3xl">
        Every treatment recommendation is based on your individual oral health needs, goals, and clinical assessment.
      </p>
      <a href="/services/" class="mt-6 inline-flex items-center gap-2 font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
        View All Services
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_0.9fr] gap-12 items-start">
        <div>
          <h2 class="font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
            What to Expect at Your First Visit
          </h2>
          <ol class="mt-10 space-y-6">
            {steps.map((step) => (
              <li class="flex gap-4">
                <span class="shrink-0 w-10 h-10 rounded-full bg-[var(--color-brand-primary)] text-white font-display font-semibold flex items-center justify-center tabular-nums">
                  {step.number}
                </span>
                <div>
                  <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)]">{step.title}</h3>
                  <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">{step.body}</p>
                </div>
              </li>
            ))}
          </ol>
          <div class="mt-10 flex flex-wrap gap-3">
            <a href="/new-patients/what-to-expect/" class="btn btn-outline">New Patient Guide</a>
            <a href="/new-patients/forms/" class="btn btn-outline">Patient Forms</a>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-xl border border-[var(--color-border-soft)] lg:sticky lg:top-28">
          <img
            src="/images/marketing/first-visit-doctor.jpg"
            alt="Dr. Dan Anderson with a young patient and parent at Able Family Dental"
            width="1024"
            height="1536"
            loading="lazy"
            decoding="async"
            class="w-full aspect-[3/4] object-cover object-[center_25%]"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center relative overflow-hidden">
    <div class="container-wide relative">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">
        Ready to get started?
      </h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto leading-relaxed">
        Request an appointment online or call us. We are welcoming new patients and families in Lethbridge.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="#request" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a
          href={`tel:${clinic.phoneTel}`}
          class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors tabular-nums"
        >
          {clinic.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- Minimal footer -->
  <footer class="bg-[var(--color-brand-primary-deep)] py-8">
    <div class="container-wide flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
      <p class="text-sm text-[var(--color-text-on-dark-muted)]">
        Learn more about us at
        <a href="/" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors underline-offset-2 hover:underline">
          ablefamilydental.com
        </a>
      </p>
      <p class="text-xs text-[var(--color-text-on-dark-muted)]">
        © {new Date().getFullYear()} Able Family Dental. All Rights Reserved.
      </p>
    </div>
  </footer>

</BaseLayout>
