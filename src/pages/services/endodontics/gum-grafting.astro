---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "Root Canal Treatment", href: "/services/endodontics/root-canal" },
  { name: "Traumatic Dental Injuries", href: "/services/endodontics/traumatic-injuries" },
  { name: "Cracked Tooth", href: "/services/endodontics/cracked-tooth" },
  { name: "Internal Bleaching", href: "/services/endodontics/internal-bleaching" },
  { name: "Gum Grafting", href: "/services/endodontics/gum-grafting", current: true },
];
---

<BaseLayout
  title="Gum Grafting | Periodontal Services | Able Family Dental Lethbridge"
  description="Gum grafting at Able Family Dental in Lethbridge. Restore receded gum tissue, protect exposed tooth roots, reduce sensitivity, and improve the appearance of your gum line."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/AI%20Enhanced%20images/Gum%20Crafting.png"
        alt="Gum grafting procedure at Able Family Dental"
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/endodontics/" class="text-white/80 hover:text-white transition-colors">Endodontic Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Gum Grafting</span>
      </nav>
      <p class="eyebrow text-white">Periodontal Services</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Gum Grafting
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Protecting exposed tooth roots, reducing sensitivity, and restoring a healthier gum line.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Specialty disclaimer -->
          <div class="bg-[var(--color-surface-alt)] rounded-2xl p-5 border border-[var(--color-border-soft)] flex gap-4 items-start">
            <svg class="shrink-0 mt-0.5 text-[var(--color-brand-primary)]" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Periodontal services at Able Family Dental are provided by our general dentist team. Our dentists are not licensed specialists in periodontics.</p>
          </div>

          <!-- What is gum grafting -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
              What Is Gum Grafting?
            </h2>
            <div class="mt-4 space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Gum grafting is a periodontal procedure used to restore gum tissue that has receded from around the teeth. When gums pull away from the teeth, more of the tooth root becomes exposed, which can lead to sensitivity, an increased risk of decay, and changes in the appearance of your smile.
              </p>
              <p>
                During a gum grafting procedure, healthy tissue is used to cover exposed root surfaces and rebuild areas affected by gum recession. The goal is to help protect vulnerable tooth roots, improve comfort, and support the long-term health of your teeth and gums.
              </p>
            </div>
          </div>

          <!-- How we treat gum recession -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-7 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] leading-tight">
              How We Treat Gum Recession at Able Family Dental
            </h2>
            <div class="mt-4 space-y-3 text-[var(--color-text)] leading-relaxed">
              <p>
                At Able Family Dental, we begin with a thorough assessment of your gum health to determine the cause and extent of the recession. We then develop a personalized treatment plan tailored to your needs and goals.
              </p>
              <p>
                When appropriate, gum grafting may help reduce tooth sensitivity, protect exposed roots, and improve the appearance of the gum line while supporting overall gum health. Our team is committed to providing gentle, patient-focused care and will guide you through every step of treatment to ensure you feel comfortable, informed, and confident in your care.
              </p>
            </div>
          </div>

          <!-- FAQ -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] leading-tight">
              Frequently Asked Questions
            </h2>
            <div class="mt-6 space-y-6">

              <div class="border-l-4 border-[var(--color-brand-accent)] pl-5">
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Will a gum graft help with tooth sensitivity?</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text)] leading-relaxed">
                  When gums recede, tooth roots can become exposed, which may lead to sensitivity to hot, cold, sweet, or acidic foods and beverages. Gum grafting is designed to cover exposed root surfaces and may help reduce sensitivity while providing additional protection for the affected teeth.
                </p>
              </div>

              <div class="border-l-4 border-[var(--color-brand-accent)] pl-5">
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">How do I know if I need a gum graft?</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text)] leading-relaxed">
                  A gum graft may be recommended if you have noticeable gum recession, exposed tooth roots, tooth sensitivity, or concerns about the appearance of your gum line. During your examination, our team will evaluate your oral health and discuss whether gum grafting is an appropriate treatment option for your needs.
                </p>
              </div>

            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)] leading-relaxed">Call us or book your appointment online.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Request Appointment</a>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <!-- Sibling services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Endodontic Services</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Concerned about gum recession?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or book a consultation.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
