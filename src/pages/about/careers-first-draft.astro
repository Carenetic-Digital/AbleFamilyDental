---
import BaseLayout from '../../layouts/BaseLayout.astro';

const aboutNav = [
  { name: "About Able Family Dental", href: "/about" },
  { name: "Our Clinic", href: "/about/our-clinic" },
  { name: "Our Team", href: "/about/our-team" },
  { name: "Careers", href: "/about/careers", current: true },
];

const roles = [
  {
    title: "Dentists",
    body: "General dentists who provide comprehensive care across all aspects of clinical dentistry, from preventive and restorative work to cosmetic and surgical procedures.",
    icon: `<path d="M9 2C7 2 5 3.5 5 6C5 7.5 5.5 8.5 6 10C6.5 11.5 7 13 7 15C7 17 7.5 20 10 20C11 20 11.5 19 12 18.5C12.5 19 13 20 14 20C16.5 20 17 17 17 15C17 13 17.5 11.5 18 10C18.5 8.5 19 7.5 19 6C19 3.5 17 2 15 2C14 2 13 2.5 12 3C11 2.5 10 2 9 2Z"/>`,
  },
  {
    title: "Dental Hygienists",
    body: "Registered dental hygienists who perform professional cleanings, periodontal assessments, and patient education, a central part of our preventive care model.",
    icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
  },
  {
    title: "Dental Assistants",
    body: "Clinical support staff who work chairside with our dentists, prepare treatment rooms, manage sterilization protocols, and help ensure each patient visit runs smoothly.",
    icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2"/><circle cx="10" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  },
  {
    title: "Administrative & Reception",
    body: "Front-desk and administrative team members who manage patient scheduling, insurance billing, communications, and the day-to-day operations of the clinic.",
    icon: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
  },
];
---

<BaseLayout
  title="Careers | Join Our Team | Able Family Dental Lethbridge"
  description="Career opportunities at Able Family Dental in Lethbridge. We periodically have openings for dental team members, learn how to get in touch."
  noindex={true}
>

  <!-- ============================================================
       HERO BANNER
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/clinic-consultation-2.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/about/" class="hover:text-white transition-colors">About</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Careers</span>
      </nav>
      <p class="eyebrow text-white">Able Family Dental</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Careers
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Able Family Dental is always interested in hearing from qualified dental professionals who share our commitment to patient-centred care.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Intro -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Working at Able Family Dental
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Able Family Dental is an established family dental practice serving the Lethbridge community. Our team of dentists, hygienists, assistants, and administrative staff work together in a collaborative environment focused on providing consistent, quality care to patients and families across the city.
              </p>
              <p>
                We don't always have specific openings posted publicly, but we welcome inquiries from qualified dental professionals at any time. If you're interested in joining our team, the best approach is to reach out directly. We're always glad to hear from people who are a good fit for our practice.
              </p>
            </div>
          </div>

          <!-- Types of roles -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-6">
              Roles at our clinic
            </h2>
            <div class="grid sm:grid-cols-2 gap-5">
              {roles.map(role => (
                <div class="bg-[var(--color-surface-cool)] rounded-xl p-5 border border-[var(--color-border-soft)] flex gap-4 items-start">
                  <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={role.icon} />
                  </div>
                  <div>
                    <h3 class="font-display font-semibold text-sm text-[var(--color-brand-primary)]">{role.title}</h3>
                    <p class="mt-1 text-sm text-[var(--color-text-muted)] leading-relaxed">{role.body}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- How to apply -->
          <div class="bg-[var(--color-surface-alt)] rounded-2xl p-8 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-5">
              How to get in touch
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                If you're interested in a position at Able Family Dental, whether a current opening or a future opportunity, we invite you to reach out through one of the following options:
              </p>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  </div>
                  <div>
                    <p class="font-semibold text-[var(--color-brand-primary)] text-sm">By email</p>
                    <p class="text-sm text-[var(--color-text-muted)]">
                      Send your resume or CV to <a href="mailto:reception@ablefamilydental.com" class="font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">reception@ablefamilydental.com</a> with a brief note about the type of role you're interested in.
                    </p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 6.9 8 11.7z"/></svg>
                  </div>
                  <div>
                    <p class="font-semibold text-[var(--color-brand-primary)] text-sm">In person</p>
                    <p class="text-sm text-[var(--color-text-muted)]">
                      Drop off a printed resume at the clinic during office hours, 511 – 5th Street South, Lethbridge, AB. Our reception team will ensure it reaches the right person.
                    </p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <div class="w-7 h-7 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0 mt-0.5">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                  </div>
                  <div>
                    <p class="font-semibold text-[var(--color-brand-primary)] text-sm">By phone</p>
                    <p class="text-sm text-[var(--color-text-muted)]">
                      Call us at <a href="tel:+14033277202" class="font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">403.327.7202</a> to speak with our reception team. We can let you know whether there are current openings and how to proceed.
                    </p>
                  </div>
                </li>
              </ul>
            </div>
          </div>

          <!-- Note about openings -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-accent)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Availability varies</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  Specific openings at Able Family Dental vary over time. If there isn't a current opening that matches your background, we may still keep your information on file for future consideration. We appreciate your interest and will follow up if a relevant opportunity arises.
                </p>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Contact CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Contact Us</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Reach our team with questions about careers or current openings.</p>
            <a href="/contact/" class="mt-4 btn btn-primary w-full block text-center">Get in Touch</a>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <!-- About nav -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">About Able Family Dental</h3>
            <ul class="space-y-2">
              {aboutNav.map(item => (
                <li>
                  {item.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {item.name}
                    </span>
                  ) : (
                    <a href={item.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {item.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

          <!-- Email card -->
          <div class="bg-white rounded-2xl p-6 shadow-xl border border-[var(--color-border-soft)]">
            <h3 class="font-display font-semibold text-sm text-[var(--color-brand-primary)] mb-2">Send your resume</h3>
            <p class="text-xs text-[var(--color-text-muted)] mb-3">Email your CV or resume directly to our reception team:</p>
            <a href="mailto:reception@ablefamilydental.com" class="text-xs font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors break-all">
              reception@ablefamilydental.com
            </a>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">
        Interested in joining our team?
      </h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto leading-relaxed">
        Reach us by email or phone, we'd be glad to hear from qualified candidates.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/contact/" class="btn btn-primary btn-lg">Contact Us</a>
        <a href="tel:+14033277202" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">403.327.7202</a>
      </div>
    </div>
  </section>

</BaseLayout>
