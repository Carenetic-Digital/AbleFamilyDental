---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Careers | Join Our Team | Wildwood Dental Clinic Saskatoon"
  description="Career opportunities at Wildwood Dental Clinic in Saskatoon. We periodically have openings for dental team members, learn how to get in touch."
>

<!-- ===================== HERO ===================== -->
<header class="hero">
  <div class="hero-photo">
    <img src="/images/services/clinic-consultation-2.jpg" alt="" width="800" height="600" loading="eager" decoding="async" style="width:100%;height:100%;object-fit:cover;display:block;" />
    <div class="hero-photo-fade"></div>
  </div>
  <div class="wrap">
    <div class="hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Careers at Wildwood Dental Clinic</span>
        <h1>Join Our Team</h1>
        <span class="u-line"></span>
        <p>Wildwood Dental Clinic is excited to connect with passionate, qualified professionals who are committed to delivering exceptional, patient-centred care.</p>
        <p>We welcome individuals who bring positivity, teamwork, and a genuine desire to make every patient feel comfortable, valued, and confident in their smile.</p>
        <div class="hero-cta">
          <a class="btn btn-navy" href="https://www.canadiandentalservices.ca/join-our-team/" target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"></path><path d="M2 13h20"></path></svg>
            View Open Opportunities
          </a>
          <a class="btn btn-ghost" href="mailto:careers@cdscorp.ca">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg>
            Send Your Resume
          </a>
        </div>
      </div>
      <div></div>
    </div>
  </div>
  <svg class="hero-wave" viewBox="0 0 1440 150" preserveAspectRatio="none" fill="none">
    <path d="M0,55 C280,40 520,85 760,92 C1000,98 1180,75 1440,55 L1440,150 L0,150 Z" fill="#c2d4ea"></path>
    <path d="M0,32 C240,78 470,120 760,116 C1000,112 1200,55 1440,10 L1440,150 L0,150 Z" fill="rgba(208,225,243,0.82)"></path>
    <path d="M0,100 C260,88 500,126 760,128 C1020,130 1220,100 1440,72 L1440,150 L0,150 Z" fill="#ffffff"></path>
  </svg>
</header>

<!-- ===================== VALUES ===================== -->
<section class="section">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Working at Wildwood Dental Clinic</span>
      <h2 class="serif">A team. A community. A shared purpose.</h2>
      <p>Wildwood Dental Clinic has been part of the Saskatoon community for over 35 years. Our team works together in a collaborative environment focused on providing consistent, quality care to patients and families across the city.</p>
    </div>
    <div class="values">
      <div class="value">
        <div class="badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg></div>
        <h3 class="serif">Community Focused</h3>
        <span class="u-line"></span>
        <p>Serving Saskatoon families for over 35 years.</p>
      </div>
      <div class="value">
        <div class="badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"></path><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"></path><path d="m21 3 1 11h-2"></path><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"></path><path d="M3 4h8"></path></svg></div>
        <h3 class="serif">Collaborative Team</h3>
        <span class="u-line"></span>
        <p>Work alongside experienced dental professionals.</p>
      </div>
      <div class="value">
        <div class="badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M11 14h2a2 2 0 0 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 16"></path><path d="m7 20 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9"></path><path d="m2 15 6 6"></path><path d="M19.5 8.5c.7-.7 1.5-1.6 1.5-2.7A2.73 2.73 0 0 0 16 4a2.78 2.78 0 0 0-5 1.8c0 1.2.8 2 1.5 2.8L16 12Z"></path></svg></div>
        <h3 class="serif">Patient-Centred Care</h3>
        <span class="u-line"></span>
        <p>Help create positive experiences for every patient.</p>
      </div>
      <div class="value">
        <div class="badge"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5.5c-1.5-1.3-3.2-2-5-2C4 3.5 2 5.7 2 9c0 2.4.9 4.6 1.7 7 .6 1.8 1 4 2.3 4 1.2 0 1.3-2 1.8-3.6.4-1.3.8-2.4 2.2-2.4h0c1.4 0 1.8 1.1 2.2 2.4.5 1.6.6 3.6 1.8 3.6 1.3 0 1.7-2.2 2.3-4 .8-2.4 1.7-4.6 1.7-7 0-3.3-2-5.5-5-5.5-1.8 0-3.5.7-5 2Z"></path></svg></div>
        <h3 class="serif">Established Practice</h3>
        <span class="u-line"></span>
        <p>A trusted clinic with a strong reputation in the community.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===================== ROLES ===================== -->
<section class="section" id="roles" style="padding-top:0;padding-bottom:36px;">
  <div class="wrap">
    <div class="sec-head">
      <span class="eyebrow">Roles at our clinic</span>
      <h2 class="serif" style="font-size:42px;">Find Your Fit</h2>
    </div>
    <div class="roles">
      <article class="role">
        <div class="role-body">
          <div class="role-top">
            <div class="role-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"></path><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4"></path><circle cx="20" cy="10" r="2"></circle></svg></div>
            <div class="role-head">
              <h3 class="serif">Dentists</h3>
              <span class="u-line"></span>
            </div>
          </div>
          <p>General dentists who provide comprehensive care across all aspects of clinical dentistry, from preventive and restorative work to cosmetic and surgical procedures.</p>
        </div>
        <img src="/images/services/clinic-patient.jpg" alt="Dentist with patient" width="400" height="148" loading="lazy" decoding="async" style="width:100%;height:148px;object-fit:cover;display:block;" />
      </article>

      <article class="role">
        <div class="role-body">
          <div class="role-top">
            <div class="role-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76Z"></path></svg></div>
            <div class="role-head">
              <h3 class="serif">Dental Hygienists</h3>
              <span class="u-line"></span>
            </div>
          </div>
          <p>Registered dental hygienists who perform professional cleanings, periodontal assessments, and patient education, a central part of our preventive care model.</p>
        </div>
        <img src="/images/services/preventive-hygiene.jpg" alt="Dental hygienist" width="400" height="148" loading="lazy" decoding="async" style="width:100%;height:148px;object-fit:cover;display:block;" />
      </article>

      <article class="role">
        <div class="role-body">
          <div class="role-top">
            <div class="role-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5.5c-1.5-1.3-3.2-2-5-2C4 3.5 2 5.7 2 9c0 2.4.9 4.6 1.7 7 .6 1.8 1 4 2.3 4 1.2 0 1.3-2 1.8-3.6.4-1.3.8-2.4 2.2-2.4s1.8 1.1 2.2 2.4c.5 1.6.6 3.6 1.8 3.6 1.3 0 1.7-2.2 2.3-4 .8-2.4 1.7-4.6 1.7-7 0-3.3-2-5.5-5-5.5-1.8 0-3.5.7-5 2Z"></path></svg></div>
            <div class="role-head">
              <h3 class="serif">Dental Assistants</h3>
              <span class="u-line"></span>
            </div>
          </div>
          <p>Clinical support staff who work chairside with our dentists, prepare treatment rooms, manage sterilization protocols, and help ensure each patient visit runs smoothly.</p>
        </div>
        <img src="/images/services/preventive-exam.jpg" alt="Dental assistant" width="400" height="148" loading="lazy" decoding="async" style="width:100%;height:148px;object-fit:cover;display:block;" />
      </article>

      <article class="role">
        <div class="role-body">
          <div class="role-top">
            <div class="role-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H4a1 1 0 0 1-1-1v-7a9 9 0 0 1 18 0v7a1 1 0 0 1-1 1h-2a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"></path><path d="M21 16v2a4 4 0 0 1-4 4h-5"></path></svg></div>
            <div class="role-head">
              <h3 class="serif">Administrative &amp; Reception</h3>
              <span class="u-line"></span>
            </div>
          </div>
          <p>Front-desk and administrative team members who manage patient scheduling, insurance billing, communications, and the day-to-day operations of the clinic.</p>
        </div>
        <img src="/images/services/content-consultation.jpg" alt="Reception team" width="400" height="148" loading="lazy" decoding="async" style="width:100%;height:148px;object-fit:cover;display:block;" />
      </article>
    </div>
  </div>
</section>

<!-- ===================== CONTACT PANEL ===================== -->
<section class="section contact-section" style="padding-top:0;">
  <div class="wrap">
    <div class="panel">
      <div class="sec-head">
        <span class="eyebrow">How to get in touch</span>
        <h2 class="serif">We'd love to hear from you</h2>
        <p style="margin-top:20px;">If you're interested in a position at Wildwood Dental Clinic, whether a current opening or a future opportunity, we invite you to reach out through one of the following options:</p>
      </div>
      <div class="contact-grid">
        <div class="contact-col">
          <div class="cc-head">
            <div class="cc-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"></rect><path d="M8 21h8"></path><path d="M12 17v4"></path></svg></div>
            <h4 class="serif">Online &amp; Email</h4>
          </div>
          <div class="cc-line"></div>
          <p>Submit your resume or CV at <a href="https://www.canadiandentalservices.ca/join-our-team/">www.canadiandentalservices.ca/join-our-team/</a> or email <a href="mailto:careers@cdscorp.ca">careers@cdscorp.ca</a> with a brief note about the type of role you're interested in.</p>
        </div>
        <div class="contact-col">
          <div class="cc-head">
            <div class="cc-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg></div>
            <h4 class="serif">In Person</h4>
          </div>
          <div class="cc-line"></div>
          <p>Drop off a printed resume at the clinic during office hours:</p>
          <p style="margin-top:12px;"><strong>105 – 1526 8th Street East<br>Saskatoon, SK</strong></p>
          <p style="margin-top:12px;">Our reception team will ensure it reaches the right person.</p>
        </div>
        <div class="contact-col">
          <div class="cc-head">
            <div class="cc-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"></path></svg></div>
            <h4 class="serif">By Phone</h4>
          </div>
          <div class="cc-line"></div>
          <p>Call us at <strong>306.374.7272</strong> to speak with our reception team.</p>
          <p style="margin-top:12px;">We can let you know whether there are current openings and how to proceed.</p>
        </div>
      </div>
      <p class="contact-note"><em>We appreciate your interest and will follow up if a relevant opportunity arises.</em></p>
    </div>

    <!-- OPENINGS CTA -->
    <div class="openings">
      <div class="openings-copy">
        <h2 class="serif">Looking for Current Openings?</h2>
        <span class="u-line" style="margin-top:18px;"></span>
        <p>Explore available opportunities through Canadian Dental Services.</p>
        <a class="btn btn-gold" href="https://www.canadiandentalservices.ca/careers/#OPEN-OPPORTUNITIES" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
          See All Open Opportunities
        </a>
      </div>
      <div class="openings-img-wrap">
        <img src="/images/sourced/careers-openings.png" alt="" width="600" height="400" loading="lazy" decoding="async" style="width:100%;height:100%;min-height:300px;object-fit:cover;display:block;" />
        <div class="openings-img-fade"></div>
      </div>
    </div>

    <!-- TWO CARDS -->
    <div class="two" id="resume">
      <div class="minicard blue">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"></rect><path d="m22 7-10 6L2 7"></path></svg></div>
        <div class="mc-body">
          <h3 class="serif">Send Your Resume</h3>
          <span class="u-line"></span>
          <p>Email your CV or resume directly to our HR team.</p>
          <a class="pill" href="mailto:careers@cdscorp.ca">careers@cdscorp.ca</a>
        </div>
      </div>
      <div class="minicard gold">
        <div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"></path></svg></div>
        <div class="mc-body">
          <h3 class="serif">Have Questions?</h3>
          <span class="u-line"></span>
          <p>We're happy to answer any questions about careers or future opportunities.</p>
          <a class="pill" href="tel:3063747272">306.374.7272</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===================== OUR OFFICE ===================== -->

</BaseLayout>

<style>
:root {
  --cv2-navy: #163a5f;
  --cv2-navy-2: #0e335c;
  --cv2-navy-deep: #0a2c52;
  --cv2-gold: #e0a23b;
  --cv2-gold-dark: #c8881f;
  --cv2-gold-soft: #f1c873;
  --cv2-blue-soft: #dde8f6;
  --cv2-blue-tint: #eaf2fb;
  --cv2-ink: #52606f;
  --cv2-line: #e3ebf3;
  --cv2-display: var(--font-display);
  --cv2-sans: var(--font-body);
}

.wrap { max-width: 1180px; margin: 0 auto; padding: 0 40px; }

.eyebrow {
  font-family: var(--cv2-sans);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .18em;
  color: var(--cv2-gold);
  font-size: 13px;
}

h1, h2, h3, h4 { font-family: var(--cv2-display); color: var(--cv2-navy); font-weight: 700; line-height: 1.12; }
.serif { font-family: var(--cv2-display); color: var(--cv2-navy); }
.u-line { display: block; width: 64px; height: 3px; background: var(--cv2-gold); border-radius: 2px; }

/* ============ HERO ============ */
.hero {
  position: relative;
  overflow: hidden;
  background: radial-gradient(120% 90% at 12% 18%, #eef5fc 0%, #e3eef9 42%, #d8e7f6 100%);
  isolation: isolate;
}
.hero-grid {
  display: grid;
  grid-template-columns: 1.02fr 1fr;
  align-items: center;
  min-height: 560px;
}
.hero-copy { padding: 76px 0 120px 0; max-width: 560px; }
.hero h1 {
  font-size: 72px;
  font-weight: 800;
  letter-spacing: -.01em;
  margin: 18px 0 0;
  color: #1c3a5e;
}
.hero-copy .u-line { margin-top: 24px; }
.hero p { margin-top: 26px; max-width: 470px; font-size: 16.5px; color: #52606f; }
.hero p + p { margin-top: 18px; }
.hero-cta { display: flex; gap: 16px; margin-top: 38px; flex-wrap: wrap; position: relative; z-index: 3; }

.btn {
  display: inline-flex; align-items: center; gap: 11px;
  font-family: var(--cv2-sans); font-weight: 700; font-size: 15px;
  padding: 15px 24px; border-radius: 7px; cursor: pointer;
  text-decoration: none; border: 1.5px solid transparent;
  transition: transform .18s ease, background .18s ease, box-shadow .18s ease, color .18s ease;
}
.btn svg { width: 19px; height: 19px; }
.btn-navy { background: var(--cv2-navy); color: #fff; box-shadow: 0 10px 24px rgba(14,51,92,.22); }
.btn-navy:hover { background: #0f2f50; transform: translateY(-2px); box-shadow: 0 14px 30px rgba(14,51,92,.3); }
.btn-ghost { background: #fff; color: var(--cv2-navy); border-color: #dfe7ef; box-shadow: 0 8px 20px rgba(20,54,95,.08); }
.btn-ghost svg { color: var(--cv2-gold); }
.btn-ghost:hover { transform: translateY(-2px); box-shadow: 0 12px 26px rgba(20,54,95,.14); border-color: var(--cv2-gold-soft); }
.btn-gold { background: linear-gradient(180deg,#eaad44,#d8901f); color: #fff; box-shadow: 0 10px 24px rgba(200,136,31,.28); }
.btn-gold:hover { transform: translateY(-2px); box-shadow: 0 14px 30px rgba(200,136,31,.38); filter: brightness(1.04); }

.hero-photo { position: absolute; top: 0; right: 0; height: 100%; width: 52%; z-index: 0; }
.hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
.hero-photo-fade {
  position: absolute; top: 0; bottom: 0; left: 0; width: 70%;
  background: linear-gradient(to right, #d8e7f6, transparent);
  pointer-events: none;
}
.hero-wave { position: absolute; left: 0; right: 0; bottom: -1px; width: 100%; z-index: 2; display: block; }

/* ============ VALUES ============ */
.section { padding: 84px 0; }
.sec-head { text-align: center; max-width: 720px; margin: 0 auto; }
.sec-head h2 { font-size: 40px; margin-top: 14px; }
.sec-head p { margin-top: 20px; color: #52606f; font-size: 16.5px; }
.values { display: grid; grid-template-columns: repeat(4, 1fr); gap: 28px; margin-top: 60px; }
.value { text-align: center; position: relative; padding: 0 12px; }
.value:not(:last-child)::after {
  content: ""; position: absolute; top: 18px; right: -14px;
  width: 1px; height: 120px; background: var(--cv2-line);
}
.badge {
  width: 78px; height: 78px; border-radius: 50%;
  background: radial-gradient(120% 120% at 50% 25%, #e7f0fb, #d8e6f6);
  display: flex; align-items: center; justify-content: center; margin: 0 auto 22px;
  color: var(--cv2-navy); box-shadow: inset 0 0 0 1px rgba(20,54,95,.05);
}
.badge svg { width: 34px; height: 34px; }
.value h3 { font-size: 20px; }
.value .u-line { margin: 12px auto 16px; width: 44px; height: 2.5px; }
.value p { font-size: 14.5px; color: #647383; line-height: 1.6; }

/* ============ ROLES ============ */
.roles { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px; margin-top: 34px; align-items: stretch; }
.role {
  background: #fff; border: 1px solid var(--cv2-line); border-radius: 10px; overflow: hidden;
  display: flex; flex-direction: column;
  box-shadow: 0 10px 30px rgba(20,54,95,.13);
  transition: transform .2s ease, box-shadow .2s ease;
}
.role:hover { transform: translateY(-4px); box-shadow: 0 22px 46px rgba(20,54,95,.12); }
.role-body { padding: 16px 22px 14px; flex: 1; }
.role-top { display: flex; align-items: center; gap: 13px; }
.role-ic {
  width: 58px; height: 58px; border-radius: 50%; flex: 0 0 auto;
  background: radial-gradient(120% 120% at 50% 25%, #e7f0fb, #d8e6f6);
  display: flex; align-items: center; justify-content: center; color: var(--cv2-navy);
}
.role-ic svg { width: 30px; height: 30px; }
