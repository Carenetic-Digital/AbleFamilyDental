---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    name: "Appointments",
    href: "/book",
    icon: `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4"/><path d="M8 2v4"/><path d="M3 10h18"/>`,
  },
  {
    name: "New Patients",
    href: "/new-patients",
    icon: `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M19 8v6"/><path d="M22 11h-6"/>`,
  },
  {
    name: "Insurance & Billing",
    href: "/new-patients/insurance-payment",
    icon: `<path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0-2 2c0 1.1.9 2 2 2h4v-4Z"/>`,
  },
  {
    name: "Children's Dentistry",
    href: "/services/childrens",
    icon: `<path d="M9 11V6a3 3 0 0 1 6 0v5"/><path d="M5 11h14l-1.2 8.2a2 2 0 0 1-2 1.8H8.2a2 2 0 0 1-2-1.8L5 11Z"/>`,
  },
  {
    name: "Emergency Care",
    href: "/services/emergency",
    icon: `<path d="M8 2h8"/><path d="M12 2v3"/><path d="M5 11a7 7 0 0 1 14 0v4a7 7 0 0 1-14 0Z"/><path d="M12 9v4"/><path d="M10 11h4"/>`,
  },
  {
    name: "Treatments",
    href: "/services",
    icon: `<path d="M12 5.5c-1.5-1.3-3.2-2-5-2C4 3.5 2 5.7 2 9c0 2.4.9 4.6 1.7 7 .6 1.8 1 4 2.3 4 1.2 0 1.3-2 1.8-3.6.4-1.3.8-2.4 2.2-2.4s1.8 1.1 2.2 2.4c.5 1.6.6 3.6 1.8 3.6 1.3 0 1.7-2.2 2.3-4 .8-2.4 1.7-4.6 1.7-7 0-3.3-2-5.5-5-5.5-1.8 0-3.5.7-5 2Z"/>`,
  },
];

const faqGroups = [
  {
    id: "new-patients",
    questions: [
      {
        q: "Are you accepting new patients?",
        a: "Yes. Wildwood Dental Clinic welcomes new patients and families from Saskatoon and surrounding communities.",
      },
      {
        q: "What should I expect during my first visit?",
        a: "Your first appointment may include a review of your medical and dental history, a comprehensive examination, any necessary X-rays, and a discussion about your oral health goals and treatment options.",
      },
      {
        q: "What should I bring to my first appointment?",
        a: "Please bring your insurance information, a list of medications you are currently taking, and any relevant dental records if available.",
      },
      {
        q: "How often should I visit the dentist?",
        a: "Most patients benefit from regular examinations and hygiene appointments, although the recommended frequency may vary based on individual oral health needs.",
      },
      {
        q: "Can I transfer from another dental office?",
        a: "Yes. If you are changing dental providers, our team can help coordinate the transfer of records when appropriate.",
      },
      {
        q: "Can you request records from my previous dentist?",
        a: "Yes. With your authorization, we can assist in obtaining relevant records from your previous dental office.",
      },
    ],
  },
  {
    id: "childrens-family",
    questions: [
      {
        q: "Do you see children?",
        a: "Yes. Wildwood Dental Clinic welcomes children of all ages and provides dental care for the entire family.",
      },
      {
        q: "When should my child have their first dental visit?",
        a: "The Canadian Dental Association recommends a child's first dental visit within six months of the first tooth erupting or by their first birthday.",
      },
      {
        q: "Can my children and I book appointments on the same day?",
        a: "Whenever possible, we are happy to accommodate family scheduling requests.",
      },
      {
        q: "What if my child is nervous about visiting the dentist?",
        a: "Our team works to create a positive and comfortable experience for children and will take the time to help them feel at ease during their visit.",
      },
      {
        q: "Do you provide preventive care for children?",
        a: "Yes. We offer examinations, hygiene appointments, fluoride treatments, and other preventive services tailored to children's oral health needs.",
      },
    ],
  },
  {
    id: "insurance-financing",
    questions: [
      {
        q: "Do you accept the Canadian Dental Care Plan (CDCP)?",
        a: "Yes. Wildwood Dental Clinic welcomes eligible patients covered under the Canadian Dental Care Plan (CDCP).",
      },
      {
        q: "Does CDCP cover all dental treatment costs?",
        a: "Coverage varies depending on eligibility, treatment needs, and the services covered under the program. Some services may require a co-payment or may not be fully covered.",
      },
      {
        q: "Will I know my costs before treatment begins?",
        a: "Yes. We strive to provide clear information regarding treatment recommendations, fees, insurance coverage, and any potential out-of-pocket expenses.",
      },
      {
        q: "Do you offer direct billing to insurance?",
        a: "We can assist patients with submitting insurance claims and help explain available coverage whenever possible.",
      },
      {
        q: "Do you offer financing options?",
        a: "Yes. Financing may be available through LendCare for eligible patients seeking assistance with treatment costs.",
      },
      {
        q: "What is LendCare?",
        a: "LendCare is a third-party financing provider that offers payment plans designed to help patients manage the cost of dental treatment over time.",
      },
      {
        q: "Can I finance treatment if I don't have dental insurance?",
        a: "Many patients use financing options to help manage treatment costs regardless of whether they have dental insurance coverage.",
      },
      {
        q: "Can I use insurance and financing together?",
        a: "In many cases, patients use both insurance benefits and financing options to help manage treatment costs.",
      },
    ],
  },
  {
    id: "location-access",
    questions: [
      {
        q: "Where is Wildwood Dental Clinic located?",
        a: "We are located at 105 – 1526 8th Street East, Saskatoon, SK S7H 0T3, between Preston and Cumberland Avenues on the south side of 8th Street East.",
      },
      {
        q: "Is parking available?",
        a: "Yes. Free on-site parking is available directly in front of the clinic.",
      },
      {
        q: "Is your office wheelchair accessible?",
        a: "Yes. Our clinic features a wheelchair-accessible entrance and accessible treatment areas.",
      },
      {
        q: "Are accessible parking spaces available?",
        a: "Yes. Accessible parking spaces are located near the clinic entrance.",
      },
      {
        q: "Can I take public transit to your office?",
        a: "Yes. Saskatoon Transit routes are located within one block of the clinic along 8th Street East.",
      },
    ],
  },
  {
    id: "appointments",
    questions: [
      {
        q: "How do I book an appointment?",
        a: "Appointments can be booked by contacting our office directly by phone or through the appointment request options available on our website.",
      },
      {
        q: "Can I book online?",
        a: "Patients may request appointments online through our website.",
      },
      {
        q: "What if I need to reschedule my appointment?",
        a: "If you need to reschedule, please contact our office as soon as possible so we can assist you and make the appointment time available to another patient.",
      },
      {
        q: "How early should I arrive for my appointment?",
        a: "New patients are encouraged to arrive a few minutes early to complete any necessary paperwork and provide insurance information.",
      },
    ],
  },
  {
    id: "emergency-care",
    questions: [
      {
        q: "What is considered a dental emergency?",
        a: "Dental emergencies may include severe tooth pain, swelling, dental infections, broken teeth, knocked-out teeth, or injuries affecting the mouth or jaw.",
      },
      {
        q: "Can I get a same-day emergency appointment?",
        a: "We make every effort to accommodate dental emergencies as quickly as possible. Please contact our office directly for assistance.",
      },
      {
        q: "What should I do if I knock out a tooth?",
        a: "Contact our office immediately. Prompt treatment may improve the chances of saving the tooth.",
      },
      {
        q: "What should I do if I have a severe toothache?",
        a: "Contact our office as soon as possible. A severe toothache may indicate an underlying issue that requires professional evaluation.",
      },
    ],
  },
  {
    id: "dental-treatment",
    questions: [
      {
        q: "What if I haven't been to the dentist in several years?",
        a: "Many patients return to dental care after an extended absence. Our team is committed to providing a welcoming, respectful, and judgment-free experience.",
      },
      {
        q: "Are dental procedures painful?",
        a: "Modern dental techniques and local anesthetics are designed to help patients remain comfortable throughout treatment.",
      },
      {
        q: "I feel nervous about dental treatment. Can you help?",
        a: "Yes. Dental anxiety is common. We will discuss your concerns and review options that may help you feel more comfortable during your visit.",
      },
      {
        q: "How do I know if I need treatment?",
        a: "A comprehensive examination allows your dentist to assess your oral health and discuss any recommended treatment options, including the benefits, risks, and alternatives.",
      },
      {
        q: "Do you provide dental implants?",
        a: "Yes. We offer dental implant consultations and treatment options for eligible patients.",
      },
      {
        q: "Do you provide root canal treatment?",
        a: "Yes. Root canal treatment may be recommended when the inner portion of a tooth becomes infected or damaged.",
      },
      {
        q: "Do you offer teeth whitening?",
        a: "Yes. We provide professional teeth whitening options and can discuss whether treatment is appropriate for your needs.",
      },
      {
        q: "Do you offer treatment for sleep apnea and snoring?",
        a: "Yes. Oral appliance therapy may be an option for some patients experiencing snoring or obstructive sleep apnea.",
      },
    ],
  },
  {
    id: "seniors-cdcp",
    questions: [
      {
        q: "Do you welcome senior patients?",
        a: "Yes. We provide dental care for patients of all ages, including seniors.",
      },
      {
        q: "Can you help me understand my CDCP coverage?",
        a: "Our team can help explain how your coverage may apply to recommended treatment and discuss any potential out-of-pocket expenses.",
      },
      {
        q: "What if I am on a fixed income?",
        a: "We believe patients should understand all available treatment options and associated costs. Our team can discuss insurance coverage, CDCP eligibility, and financing options when appropriate.",
      },
    ],
  },
  {
    id: "patient-safety",
    questions: [
      {
        q: "Are your dentists licensed in Saskatchewan?",
        a: "Yes. All dentists at Wildwood Dental Clinic hold a Doctor of Dental Medicine (DMD) degree and are licensed to practise dentistry in Saskatchewan.",
      },
      {
        q: "What infection prevention procedures do you follow?",
        a: "Wildwood Dental Clinic follows current infection prevention and control protocols designed to support patient and staff safety.",
      },
      {
        q: "What is the Commitment to Clean™ program?",
        a: "As part of the Canadian Dental Services Corporation network, our clinic participates in the Commitment to Clean™ program, which supports standards for cleanliness, instrument sterilization, and infection prevention.",
      },
      {
        q: "How do you support patient safety?",
        a: "Patient safety is a priority at Wildwood Dental Clinic. We follow established clinical protocols, sterilization procedures, and infection prevention practices designed to support safe and effective dental care.",
      },
    ],
  },
];

const features = [
  {
    title: "Patient-Focused Care",
    body: "Your comfort and well-being come first at every visit.",
    icon: `<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>`,
  },
  {
    title: "Experienced Team",
    body: "Skilled clinicians trained at the University of Saskatchewan.",
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/>`,
  },
  {
    title: "Comprehensive Care",
    body: "A full range of dental services for the whole family, under one roof.",
    icon: `<path d="M12 5.5c-1.5-1.3-3.2-2-5-2C4 3.5 2 5.7 2 9c0 2.4.9 4.6 1.7 7 .6 1.8 1 4 2.3 4 1.2 0 1.3-2 1.8-3.6.4-1.3.8-2.4 2.2-2.4s1.8 1.1 2.2 2.4c.5 1.6.6 3.6 1.8 3.6 1.3 0 1.7-2.2 2.3-4 .8-2.4 1.7-4.6 1.7-7 0-3.3-2-5.5-5-5.5-1.8 0-3.5.7-5 2Z"/>`,
  },
  {
    title: "Welcoming Environment",
    body: "A friendly, comfortable place for patients and families of every age.",
    icon: `<path d="M3 10.5 12 3l9 7.5"/><path d="M5 9.5V21h14V9.5"/><path d="M9.5 21v-6h5v6"/>`,
  },
];
---

<BaseLayout
  title="Frequently Asked Questions | Wildwood Dental Clinic, Saskatoon"
  description="Find answers to common questions about appointments, insurance, children's dentistry, emergency care, and more at Wildwood Dental Clinic in Saskatoon, SK."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="relative overflow-hidden" style="background: linear-gradient(180deg, #f2f7fc 0%, #e4edf7 100%);">

    <!-- Right-side photo, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[45%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/sourced/faq-hero.png"
        alt=""
        width="900"
        height="700"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <!-- Soft left fade -->
      <div class="absolute inset-y-0 left-0 w-[55%]" style="background: linear-gradient(to right, #eaf2fb 0%, rgba(234,242,251,0.7) 50%, transparent 100%);"></div>
    </div>

    <!-- Text content -->
    <div class="container-wide relative py-16 lg:py-28 lg:max-w-[58%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-brand-primary)] transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-[var(--color-brand-primary)]">FAQ</span>
      </nav>
      <p class="eyebrow text-[var(--color-brand-accent)]">Patient Information</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-[var(--color-brand-primary)] max-w-xl">
        Frequently Asked<br>Questions
      </h1>
      <div class="mt-4 w-16 h-0.5 bg-[var(--color-brand-accent)] rounded-full"></div>
      <p class="mt-6 text-lg text-[var(--color-text)] leading-relaxed max-w-lg">
        Helpful answers about appointments, insurance, dental visits, and care at Wildwood Dental Clinic.
      </p>
    </div>

    <!-- Bottom wave -->
    <svg class="block w-full" style="margin-top: -2px;" viewBox="0 0 1440 80" preserveAspectRatio="none" fill="none" aria-hidden="true">
      <path d="M0,50 C280,22 520,68 760,72 C1000,76 1220,50 1440,28 L1440,80 L0,80 Z" fill="rgba(194,212,234,0.55)"></path>
      <path d="M0,30 C240,62 480,76 760,74 C1040,72 1220,42 1440,14 L1440,80 L0,80 Z" fill="rgba(215,228,243,0.65)"></path>
      <path d="M0,58 C320,40 600,78 760,78 C920,78 1140,52 1440,36 L1440,80 L0,80 Z" fill="#ffffff"></path>
    </svg>

  </section>


  <!-- ============================================================
       FAQ MAIN
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[280px_1fr] gap-10 lg:gap-16 items-start">

        <!-- ---- SIDEBAR ---- -->
        <aside class="lg:sticky lg:top-40">

          <!-- Category nav -->
          <nav aria-label="FAQ categories">
            <ul class="space-y-2.5">
              {categories.map((cat) => (
                <li>
                  <a
                    href={cat.href}
                    class="faq-cat-link flex items-center gap-3.5 w-full px-4 py-3.5 rounded-xl border border-[var(--color-brand-secondary)] bg-white text-[var(--color-brand-primary)] font-semibold text-[15px] no-underline transition-all duration-150 hover:border-[#cdddee] hover:translate-x-0.5 hover:shadow-md group"
                  >
                    <svg class="w-[18px] h-[18px] flex-shrink-0 text-[var(--color-brand-accent)] transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <Fragment set:html={cat.icon} />
                    </svg>
                    <span class="flex-1">{cat.name}</span>
                    <svg class="w-4 h-4 flex-shrink-0 text-[#aab6c4] transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="m9 18 6-6-6-6"/>
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </nav>

          <!-- Help card -->
          <div class="mt-6 rounded-2xl border border-[var(--color-brand-secondary)] bg-[var(--color-surface-cool)] p-5">
            <div class="flex items-start gap-3 mb-3">
              <span class="flex-shrink-0 w-9 h-9 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center">
                <svg class="w-4.5 h-4.5 text-[var(--color-brand-accent-soft)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/><path d="M9.1 9a3 3 0 0 1 5.8 1c0 2-3 3-3 3"/><path d="M12 17h.01"/>
                </svg>
              </span>
              <h2 class="font-display font-semibold text-[17px] text-[var(--color-brand-primary)] leading-snug pt-1">
                Can't Find What You're Looking For?
              </h2>
            </div>
            <p class="text-sm text-[var(--color-text-muted)] mb-3">We're here to help.</p>
            <a
              href="mailto:reception@wildwooddentalclinic.com"
              class="flex items-start gap-2 text-xs font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors no-underline min-w-0"
            >
              <svg class="w-4 h-4 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/>
              </svg>
              <span class="break-words">reception@wildwooddentalclinic.com</span>
            </a>
            <p class="text-xs text-[var(--color-text-muted)] mt-2.5">We aim to respond within one business day.</p>
          </div>

        </aside>

        <!-- ---- ACCORDION ---- -->
        <div>

          <!-- Decorative rule -->
          <div class="flex items-center gap-4 mb-8" aria-hidden="true">
            <span class="flex-1 h-px bg-[var(--color-brand-secondary)]"></span>
