---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "Relaxation Dentistry for Nervous Patients", href: "/services/ivs/relaxation" },
  { name: "Sedation for Sensitive Teeth or Gag Reflex", href: "/services/ivs/sensitive-teeth" },
  { name: "Stress-Free Visits with IV Sedation", href: "/services/ivs/stress-free" },
  { name: "Monitoring & Safe Sedation Care", href: "/services/ivs/monitoring", current: true },
];
---

<BaseLayout
  title="Safe IV Sedation Monitoring Lethbridge | Able Family Dental"
  description="Continuous vital sign monitoring during IV sedation at Able Family Dental in Lethbridge. Dr. Tyler Snow is certified in moderate conscious IV sedation. Call 403.327.7202."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-iv-sedation.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/ivs/" class="hover:text-white transition-colors">IV Sedation</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Monitoring &amp; Safe Sedation Care</span>
      </nav>
      <p class="eyebrow text-white">IV Sedation Dentistry</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Monitoring &amp; Safe Sedation Care
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Your safety is the foundation of every sedation appointment. Dr. Tyler Snow's certification in moderate conscious IV sedation, combined with continuous monitoring throughout, means you are in capable, experienced hands from start to finish.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Dr. Tyler Snow's sedation certification
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Administering IV sedation in a dental setting requires specific training and certification beyond general dentistry. Dr. Tyler Snow holds certification in <strong class="text-[var(--color-brand-primary)]">moderate conscious IV sedation</strong> — a credential that signifies formal training in the pharmacology of sedation agents, airway management, patient assessment, emergency protocols, and the ongoing monitoring required during sedation procedures.
              </p>
              <p>
                This certification is not a routine part of dental training. It is an additional qualification that equips Dr. Snow to safely administer and manage IV sedation for appropriate patients in a dental office environment.
              </p>
            </div>
          </div>

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Continuous monitoring throughout your procedure
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                From the moment sedation begins to the time you are discharged, your vital signs are monitored continuously. This includes:
              </p>
              <ul class="space-y-3">
                {[
                  { label: "Heart rate and rhythm", note: "Electrocardiographic monitoring tracks cardiac activity throughout the procedure." },
                  { label: "Blood oxygen saturation", note: "Pulse oximetry ensures adequate oxygen levels are maintained at all times." },
                  { label: "Blood pressure", note: "Periodic blood pressure readings throughout the appointment track your cardiovascular status." },
                  { label: "Respiratory rate", note: "Breathing is monitored to confirm the airway remains clear and respiration is normal." },
                  { label: "Level of consciousness", note: "Dr. Snow assesses your responsiveness throughout to ensure sedation remains at an appropriate and safe depth." },
                ].map(item => (
                  <li class="flex gap-4 items-start">
                    <div class="w-2 h-2 rounded-full bg-[var(--color-brand-accent)] shrink-0 mt-2" aria-hidden="true"></div>
                    <div>
                      <p class="font-semibold text-[var(--color-brand-primary)] text-sm">{item.label}</p>
                      <p class="mt-0.5 text-sm text-[var(--color-text-muted)] leading-relaxed">{item.note}</p>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Pre-sedation screening
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Before any sedation appointment, we complete a thorough health and medication review. Certain medical conditions or medications may affect sedation safety or require modification to the approach. This assessment is an essential part of providing safe care — not a formality.
              </p>
              <p>
                If IV sedation is not appropriate for a particular patient, we will discuss alternative options and be clear about the reasons. Our priority is always your wellbeing.
              </p>
            </div>
          </div>

          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Post-procedure recovery
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                After treatment is complete, we continue to monitor you in the recovery area until it is safe for you to leave. You will not be discharged until your vital signs are stable and you can respond clearly. A responsible adult must be present to drive you home.
              </p>
              <p>
                We provide written post-procedure instructions and are available to answer questions if any concerns arise once you are home.
              </p>
            </div>
          </div>

          <!-- Certification callout -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-accent)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-base text-[var(--color-brand-primary)]">Certified, trained, and prepared</h3>
                <p class="mt-1.5 text-sm text-[var(--color-text-muted)] leading-relaxed">
                  Dr. Tyler Snow's certification in moderate conscious IV sedation, along with our team's ongoing training in emergency preparedness, means your sedation appointment is conducted with the rigour and care that the procedure demands. If you have questions about our safety protocols before booking, we encourage you to call and ask.
                </p>
              </div>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or request an appointment online, new patients welcome.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Request Appointment</a>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <!-- Sibling services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">IV Sedation Services</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to book?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Request an Appointment</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
