---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const benefits = [
  {
    title: "Protect Damaged Teeth",
    description: "A crown fully encases a cracked, decayed, or weakened tooth, preventing further breakdown and protecting it from fracture during normal chewing.",
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    title: "Replace Missing Teeth",
    description: "A dental bridge spans the gap left by one or more missing teeth, supported by crowns placed on the healthy teeth on either side of the space.",
    icon: `<path d="M4 9h16"/><path d="M4 15h16"/><path d="M7 4v16"/><path d="M17 4v16"/>`,
  },
  {
    title: "Natural-Looking Results",
    description: "Modern porcelain and ceramic materials are matched to your natural tooth colour, making crowns and bridges virtually indistinguishable from surrounding teeth.",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  },
  {
    title: "Restored Bite Function",
    description: "Properly fitted crowns and bridges distribute chewing forces evenly, reducing strain on remaining teeth and supporting long-term oral health.",
    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
  },
  {
    title: "Durable and Long-Lasting",
    description: "With good oral hygiene and regular check-ups, crowns and bridges can last many years, making them a reliable investment in your smile.",
    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
  },
  {
    title: "Support for Future Restorations",
    description: "Crowns placed over implants or as bridge abutments integrate with other prosthodontic work, allowing for comprehensive treatment planning.",
    icon: `<line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
  },
];
---

<BaseLayout
  title="Dental Crowns & Bridges Lethbridge | Able Family Dental"
  description="Dental crowns and bridges in Lethbridge at Able Family Dental. Protect damaged teeth and replace missing ones with natural-looking, durable restorations."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-crowns-bridges.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/prosthodontics/" class="text-white/80 hover:text-white transition-colors">Prosthodontics</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Crowns &amp; Bridges</span>
      </nav>
      <p class="eyebrow text-white">Prosthodontic Care</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Crowns &amp; Bridges
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Whether a tooth has been damaged by decay or injury, or a gap needs to be closed after a tooth is lost, crowns and bridges offer proven, long-lasting solutions that look and feel natural.
      </p>
    </div>
  </section>

  <!-- ============================================================
       CONTENT SECTION
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="eyebrow">Restorations that last</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Protecting and replacing teeth in Lethbridge
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          A dental crown is a tooth-shaped cap cemented over an existing tooth to restore its shape, strength, and appearance. Bridges use two crowns as anchors, one on each side of a gap, with a false tooth suspended between them. At Able Family Dental, we take precise impressions and work with skilled dental labs to ensure each restoration fits accurately and blends naturally with your smile. Most crown and bridge work is completed over two visits.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map(item => (
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)] shadow-md flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-4 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.icon} />
            </div>
            <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] mb-2">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{item.description}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to restore your smile?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
