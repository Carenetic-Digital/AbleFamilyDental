---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "Exams & Cleanings", href: "/services/childrens/exams-cleanings" },
  { name: "Infant Oral Care", href: "/services/childrens/infant-oral-care" },
  { name: "Fluoride", href: "/services/childrens/fluoride" },
  { name: "Sealants", href: "/services/childrens/sealants" },
  { name: "X-Rays", href: "/services/childrens/x-rays", current: true },
  { name: "Space Maintainers", href: "/services/childrens/space-maintainers" },
  { name: "Comfort & Anxiety", href: "/services/childrens/comfort" },
];
---

<BaseLayout
  title="Dental X-Rays for Children | Able Family Dental Lethbridge"
  description="Dental x-rays for children at Able Family Dental in Lethbridge, how they help, how often, and radiation considerations."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/childrens-checkup.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/childrens/" class="text-white/80 hover:text-white transition-colors">Children's Dentistry</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">X-Rays</span>
      </nav>
      <p class="eyebrow text-white">Children's Dentistry</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Dental X-Rays for Children
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Dental x-rays allow us to see areas that a visual exam cannot reach, between teeth, below the gumline, and around developing permanent teeth. Here is what parents often ask about them.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- Specialty disclaimer -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <div class="flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center shrink-0">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              </div>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Dental services for children at Able Family Dental are provided by our general dentist team. Our dentists are not licensed specialists in pediatric dentistry.
              </p>
            </div>
          </div>

          <!-- Why children need dental x-rays -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Why children need dental x-rays
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                A clinical exam can only show what is visible to the eye. Dental x-rays allow us to detect decay that develops between teeth, areas where visual inspection cannot reach, and to monitor what is happening below the gumline and inside the jawbone.
              </p>
              <p>
                For children specifically, x-rays also allow us to see the developing permanent teeth forming beneath the primary (baby) teeth. This helps us identify potential problems with eruption sequences, watch for impacted teeth, and confirm that enough space exists for incoming permanent teeth.
              </p>
              <ul class="space-y-3 mt-4">
                {[
                  "Detecting decay between teeth before it becomes visible or symptomatic",
                  "Monitoring developing permanent teeth and their expected eruption paths",
                  "Checking bone levels and the health of structures around the roots",
                  "Identifying whether a primary tooth's root has resorbed appropriately",
                  "Assessing the position of teeth that have not yet erupted",
                ].map(item => (
                  <li class="flex items-start gap-3">
                    <svg class="mt-1 shrink-0 text-[var(--color-brand-accent)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="5 12 10 17 19 7"/></svg>
                    <span class="text-[var(--color-text)] leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Image break -->
          <div class="rounded-2xl overflow-hidden max-h-[700px]">
            <img
              src="/images/services/childrens-treatment.jpg"
              alt="Pediatric dental treatment in progress"
              width="800"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full h-auto"
            />
          </div>


          <!-- How often -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              How often are x-rays taken?
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                There is no fixed schedule that applies to every child. The frequency of x-rays is based on individual risk: a child with a history of cavities, closely spaced teeth, or limited visibility between teeth may need more frequent imaging than a child with wide spacing, no decay history, and good oral hygiene.
              </p>
              <p>
                We discuss x-ray decisions with parents before taking them. If you have questions about whether x-rays are needed at a given visit, we welcome that conversation.
              </p>
            </div>
          </div>

          <!-- Digital x-rays -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Digital x-rays
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                We use digital x-ray technology, which uses less radiation than older film-based systems. The images are captured on a sensor rather than film and are available for review within seconds.
              </p>
            </div>
          </div>

          <!-- Radiation in perspective -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-4">
              Radiation exposure, keeping it in perspective
            </h2>
            <div class="space-y-3 text-[var(--color-text)] leading-relaxed">
              <p>
                We understand that radiation is a concern for many parents, and it is a reasonable thing to think about. The dose from a set of dental x-rays is very low, comparable to the background radiation a person receives from the natural environment over the course of a short period of time.
              </p>
              <p>
                We only take x-rays when they are clinically justified. A lead apron and thyroid collar are used to minimize any incidental exposure during the imaging process.
              </p>
            </div>
          </div>

          <!-- Low-risk patients -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              When x-rays may not be needed
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Children with low cavity risk, well-spaced teeth, no history of decay, and good oral hygiene may go longer between x-rays than children with higher risk factors. Each child's situation is considered individually. We do not take x-rays on a routine fixed schedule, only when the information they provide is likely to affect clinical decisions.
              </p>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <!-- Book CTA card -->
          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or request an appointment online, new patients welcome.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="/refer/" class="mt-2 btn btn-outline w-full block text-center">Refer Patient</a>>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <!-- Sibling services card -->
          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Children's Dentistry</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Questions about your child's dental care?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
