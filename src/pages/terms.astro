---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Use | Wildwood Dental Clinic"
  description="Terms of use for the Wildwood Dental Clinic website."
>

  <!-- ============================================================
       SIMPLE PAGE HEADER
       ============================================================ -->
  <section class="bg-[var(--color-surface-cool)] border-b border-[var(--color-border-soft)]">
    <div class="container-wide py-10">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-muted)] mb-4" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-brand-primary)] transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <span class="text-[var(--color-text)]">Terms of Use</span>
      </nav>
      <h1 class="font-display font-semibold text-[length:var(--text-4xl)] text-[var(--color-brand-primary)]">
        Terms of Use
      </h1>
      <p class="mt-2 text-sm text-[var(--color-text-muted)]">Last updated: May 2026</p>
    </div>
  </section>

  <!-- ============================================================
       TERMS CONTENT
       ============================================================ -->
  <section class="bg-white section-y">
    <div class="container-wide">
      <div class="max-w-3xl">

        <div class="prose prose-sm max-w-none space-y-8 text-[var(--color-text)] leading-relaxed">

          <!-- Website use -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">Website use</h2>
            <p>
              This website is operated by Wildwood Dental Clinic and is provided for informational purposes only. The content on this site is intended to offer general information about dental health and the services available at our clinic. It is not intended to serve as professional dental advice, diagnosis, or treatment.
            </p>
            <p class="mt-3">
              By accessing and using this website, you agree to be bound by these terms of use. If you do not agree with any part of these terms, please do not use this site.
            </p>
          </div>

          <!-- Health information disclaimer -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">Health information disclaimer</h2>
            <p>
              Dental and oral health needs vary significantly from person to person. The general information provided on this website may not apply to your specific situation. Nothing on this site should be taken as a substitute for a consultation with a qualified dental professional.
            </p>
            <p class="mt-3">
              If you have a dental concern, tooth pain, or any other oral health question, we encourage you to contact our clinic directly or consult with a dentist. For urgent dental concerns, please call us at <a href="tel:+13063747272" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent)] transition-colors">306.374.7272</a>.
            </p>
          </div>

          <!-- Privacy -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">Privacy</h2>
            <p>
              Your privacy is important to us. Information collected through this website is handled in accordance with our <a href="/privacy" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent)] transition-colors">Privacy Policy</a>. Patient health information collected at the clinic is handled separately in accordance with applicable Saskatchewan privacy legislation and PIPEDA.
            </p>
          </div>

          <!-- Intellectual property -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">Intellectual property</h2>
            <p>
              The content on this website, including text, images, graphics, logos, and other materials, is owned by or licensed to Wildwood Dental Clinic. You may not reproduce, distribute, or use the content for any commercial purpose without our written permission.
            </p>
            <p class="mt-3">
              Personal, non-commercial use of the content on this site is permitted, provided that all copyright and other proprietary notices are retained.
            </p>
          </div>

          <!-- External links -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">External links</h2>
            <p>
              This website may contain links to external websites, for example, government health resources, professional regulatory bodies, or other informational sites. These links are provided for convenience. Wildwood Dental Clinic is not responsible for the content, accuracy, or practices of any external websites. Linking to an external site does not constitute an endorsement of that site or its content.
            </p>
          </div>

          <!-- Accuracy -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">Accuracy of information</h2>
            <p>
              We aim to keep the information on this website accurate and current. However, dental guidelines, government programs, office hours, and other information may change. We recommend contacting the clinic directly to confirm details that are time-sensitive, such as appointment availability, office hours, or insurance program eligibility.
            </p>
          </div>

          <!-- Limitation of liability -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">Limitation of liability</h2>
            <p>
              To the fullest extent permitted by law, Wildwood Dental Clinic is not liable for any loss or damage arising from your use of this website or reliance on information contained herein. This includes, without limitation, any direct, indirect, or consequential damages.
            </p>
          </div>

          <!-- Jurisdiction -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">Governing jurisdiction</h2>
            <p>
              These terms of use are governed by the laws of the Province of Saskatchewan and the laws of Canada applicable therein. Any disputes relating to these terms will be subject to the exclusive jurisdiction of the courts of Saskatchewan.
            </p>
          </div>

          <!-- Contact -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-2xl)] text-[var(--color-brand-primary)] mb-3">Contact us</h2>
            <p>
              If you have questions about these terms of use, please contact us:
            </p>
            <div class="mt-3 p-5 bg-[var(--color-surface-cool)] rounded-xl border border-[var(--color-border-soft)]">
              <p class="font-semibold text-[var(--color-brand-primary)]">Wildwood Dental Clinic</p>
              <p class="mt-1 text-[var(--color-text-muted)] text-sm">105 – 1526 8th Street East<br/>Saskatoon, SK&nbsp; S7H 0T3</p>
              <p class="mt-2 text-sm">
                Phone: <a href="tel:+13063747272" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent)] transition-colors">306.374.7272</a>
              </p>
              <p class="text-sm">
                Email: <a href="mailto:reception@wildwooddentalclinic.com" class="font-semibold text-[var(--color-brand-primary)] hover:text-[var(--color-brand-accent)] transition-colors">reception@wildwooddentalclinic.com</a>
              </p>
            </div>
          </div>

        </div>

        <!-- Related links -->
        <div class="mt-12 pt-8 border-t border-[var(--color-border-soft)]">
          <p class="text-sm text-[var(--color-text-muted)] mb-4">Related pages:</p>
          <div class="flex flex-wrap gap-3">
            <a href="/privacy" class="btn btn-outline">Privacy Policy</a>
            <a href="/contact" class="btn btn-outline">Contact Us</a>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
