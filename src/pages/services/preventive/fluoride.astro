---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const siblingServices = [
  { name: "Fluoride Treatments", href: "/services/preventive/fluoride", current: true },
  { name: "Routine Cleanings & Exams", href: "/services/preventive/cleanings-exams" },
  { name: "Dental Sealants", href: "/services/preventive/sealants" },
  { name: "Night Guards & Mouthguards", href: "/services/preventive/guards" },
  { name: "Patient Comfort Techniques", href: "/services/preventive/comfort" },
];
---

<BaseLayout
  title="Fluoride Treatment Lethbridge | Able Family Dental"
  description="Professional fluoride varnish at Able Family Dental in Lethbridge, strengthens enamel and helps prevent cavities. Suitable for children and adults."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/preventive-fluoride-hero.jpg"
        alt=""
        width="1024"
        height="769"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover object-[55%_center]"
      />
      <div class="absolute inset-y-0 left-0 w-2/5" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-[var(--color-text-on-dark-muted)] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <a href="/services/preventive/" class="text-white/80 hover:text-white transition-colors">Preventive</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Fluoride</span>
      </nav>
      <p class="eyebrow text-white">Preventive Dentistry</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Fluoride Treatment
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        A quick, painless varnish applied during your dental visit to strengthen enamel and support your daily prevention routine.
      </p>
    </div>
  </section>

  <!-- ============================================================
       MAIN CONTENT + SIDEBAR
       ============================================================ -->
  <section class="section-y bg-white">
    <div class="container-wide">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12">

        <!-- LEFT: Main content -->
        <div class="space-y-10">

          <!-- What is fluoride -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              What is professional fluoride treatment?
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Fluoride is a naturally occurring mineral that helps strengthen tooth enamel and makes teeth more resistant to acid attacks from the bacteria in plaque. Professional fluoride treatment at a dental office is applied as a varnish, a concentrated form that delivers more fluoride to the tooth surface than regular toothpaste alone.
              </p>
              <p>
                The process is simple and quick. After your cleaning, the hygienist paints the varnish onto your teeth. It sets almost immediately on contact with saliva, so you can eat and drink normally shortly afterwards. There are no drills, no needles, and no recovery time.
              </p>
            </div>
          </div>

          <!-- Image break -->
          <div class="rounded-2xl overflow-hidden max-h-[700px]">
            <img
              src="/images/services/preventive-fluoride-inline.jpg"
              alt="Dental hygienist applying a fluoride tray during a preventive visit"
              width="1024"
              height="768"
              loading="lazy"
              decoding="async"
              class="w-full h-auto"
            />
          </div>


          <!-- Who benefits -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              Who benefits from fluoride treatments?
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Professional fluoride is appropriate for patients of all ages, children and adults alike. It is routinely offered as part of a cleaning appointment and is particularly helpful for patients who:
              </p>
              <ul class="space-y-2 ml-4">
                {[
                  "Have a history of cavities or are at higher risk of developing them",
                  "Experience dry mouth, which reduces the protective effect of saliva",
                  "Consume frequent sugary or acidic foods and beverages",
                  "Have exposed root surfaces due to gum recession",
                  "Wear orthodontic appliances, which can make areas harder to clean",
                  "Have limited access to fluoridated water",
                ].map(item => (
                  <li class="flex items-start gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0 mt-2" aria-hidden="true"></span>
                    <span class="text-[var(--color-text)]">{item}</span>
                  </li>
                ))}
              </ul>
              <p>
                For patients with lower cavity risk, we may still recommend fluoride at each cleaning, the benefit is well-established and the treatment is straightforward.
              </p>
            </div>
          </div>

          <!-- Complements daily care -->
          <div>
            <h2 class="font-display font-semibold text-[length:var(--text-3xl)] text-[var(--color-brand-primary)] mb-4">
              How does it fit with home care?
            </h2>
            <div class="space-y-4 text-[var(--color-text)] leading-relaxed">
              <p>
                Professional fluoride complements, it does not replace, your daily brushing and flossing. Using a fluoride toothpaste twice a day provides a steady low dose of protection. The in-office varnish provides an additional, more concentrated boost at each recall visit.
              </p>
              <p>
                Together, consistent home care and regular professional treatment form the backbone of a practical, evidence-informed approach to preventing decay.
              </p>
            </div>
          </div>

        </div>

        <!-- RIGHT: Sidebar -->
        <aside class="space-y-6">

          <div class="bg-[var(--color-brand-primary)] rounded-2xl p-6 text-white">
            <h3 class="font-display font-semibold text-lg text-white">Ready to Book?</h3>
            <p class="mt-2 text-sm text-[var(--color-text-on-dark-muted)]">Call us or request an appointment online, new patients welcome.</p>
            <a href="/book/" class="mt-4 btn btn-primary w-full block text-center">Book Appointment</a>
            <a href="/refer/" class="mt-2 btn btn-outline w-full block text-center">Refer Patient</a>
            <a href="tel:+14033277202" class="mt-2 block text-center text-sm text-[var(--color-text-on-dark-muted)] hover:text-white transition-colors">403.327.7202</a>
          </div>

          <div class="bg-[var(--color-surface-cool)] rounded-2xl p-6 border border-[var(--color-border-soft)]">
            <h3 class="font-body text-sm font-semibold uppercase tracking-[0.14em] text-[var(--color-brand-primary)] mb-4">Preventive Services</h3>
            <ul class="space-y-2">
              {siblingServices.map(svc => (
                <li>
                  {svc.current ? (
                    <span class="flex items-center gap-2 text-sm font-semibold text-[var(--color-brand-accent)]">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand-accent)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </span>
                  ) : (
                    <a href={svc.href} class="flex items-center gap-2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-brand-accent)] transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-border-soft)] shrink-0" aria-hidden="true"></span>
                      {svc.name}
                    </a>
                  )}
                </li>
              ))}
            </ul>
          </div>

        </aside>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Ready to get started?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold hover:text-[var(--color-brand-accent-soft)] transition-colors">403.327.7202</a> or request an appointment online.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Book Appointment</a>
        <a href="/refer/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Refer Patient</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
