---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const services = [
  {
    title: "Teeth Whitening",
    href: "/services/cosmetic/whitening",
    description: "Professional whitening to address staining and discolouration.",
    icon: `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`,
  },
  {
    title: "Porcelain Veneers",
    href: "/services/cosmetic/veneers",
    description: "Thin porcelain shells bonded to the front of teeth to change their shape or colour.",
    icon: `<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>`,
  },
  {
    title: "Dental Bonding",
    href: "/services/cosmetic/bonding",
    description: "Tooth-coloured resin applied to repair chips, gaps, or discolouration.",
    icon: `<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>`,
  },
  {
    title: "Smile Makeovers",
    href: "/services/cosmetic/smile-makeovers",
    description: "A comprehensive approach combining two or more cosmetic treatments to address multiple aesthetic concerns in a coordinated plan.",
    icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
  },
  {
    title: "Invisalign & Clear Aligners",
    href: "/services/orthodontics/invisalign",
    description: "Clear aligner therapy to address crowding, spacing, and bite alignment. Treatment is planned and monitored by our team throughout the process.",
    icon: `<path d="M12 2C9 2 7 4 7 7c0 1.5.5 2.5 1 3.5.5 1 1 2 1 3.5 0 2 .5 4 3 4 1 0 1.5-1 2-1.5.5.5 1 1.5 2 1.5 2.5 0 3-2 3-4 0-1.5.5-2.5 1-3.5.5-1 1-2 1-3.5 0-3-2-5-5-5z"/>`,
  },
  {
    title: "Gum Contouring",
    href: "/services/periodontal/gum-contouring",
    description: "Reshaping of the gumline to address uneven gum levels or a gummy smile, performed as part of a broader periodontal or cosmetic treatment plan.",
    icon: `<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>`,
  },
];
---

<BaseLayout
  title="Cosmetic Dentistry Lethbridge | Able Family Dental"
  description="Cosmetic dental services in Lethbridge at Able Family Dental, teeth whitening, porcelain veneers, dental bonding, tooth reshaping, bite correction, and Invisalign."
>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] relative overflow-hidden">
    <!-- Right-side image panel, desktop only -->
    <div class="hidden lg:block absolute right-0 top-0 bottom-0 w-[42%] pointer-events-none" aria-hidden="true">
      <img
        src="/images/services/hero-cosmetic-pexels.jpg"
        alt=""
        width="800"
        height="600"
        loading="eager"
        decoding="async"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-y-0 left-0 w-2/3" style="background: linear-gradient(to right, var(--color-brand-primary), transparent);"></div>
    </div>
    <div class="container-wide relative py-16 lg:py-24 lg:max-w-[64%]">
      <nav class="flex items-center gap-2 text-xs text-white mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white hover:text-white/80 transition-colors">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/services/" class="text-white/80 hover:text-white transition-colors">Services</a>
        <span aria-hidden="true">›</span>
        <span class="text-white">Cosmetic</span>
      </nav>
      <p class="eyebrow text-white">Cosmetic Dentistry</p>
      <h1 class="mt-3 font-display font-semibold text-[length:var(--text-5xl)] leading-tight text-white max-w-2xl">
        Refine the Appearance of Your Smile
      </h1>
      <p class="mt-4 text-lg text-[var(--color-text-on-dark-muted)] leading-relaxed max-w-xl">
        Cosmetic dentistry at Able Family Dental focuses on improving the look of your teeth while maintaining, and often improving, their health and function.
      </p>
    </div>
  </section>

  <!-- ============================================================
       INTRO + SERVICE CARDS
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-cool)]">
    <div class="container-wide">

      <!-- Intro paragraph -->
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="eyebrow">Our approach</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-4xl)] leading-tight text-[var(--color-brand-primary)]">
          Cosmetic services tailored to your goals
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] leading-relaxed">
          Whether you're looking to address discolouration, repair a chipped tooth, or explore orthodontic options, our team can help you understand what's possible. Every cosmetic treatment starts with a thorough assessment to ensure we recommend options that are appropriate for your oral health and realistic for your situation.
        </p>
      </div>

      <!-- 2×3 service cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(svc => (
          <div class="bg-white rounded-2xl p-6 border border-[var(--color-border-soft)] shadow-md flex flex-col">
            <div class="w-12 h-12 rounded-full bg-[var(--color-brand-primary)] flex items-center justify-center mb-4 shrink-0">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={svc.icon} />
            </div>
            <h3 class="font-display font-semibold text-lg text-[var(--color-brand-primary)] mb-2">{svc.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed flex-1">{svc.description}</p>
            <a href={svc.href} class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand-accent)] hover:text-[var(--color-brand-accent-hover)] transition-colors">
              Learn More
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ============================================================
       COMPLIANCE NOTE
       ============================================================ -->
  <section class="section-y bg-[var(--color-surface-alt)]">
    <div class="container-wide">
      <div class="max-w-2xl mx-auto">
        <p class="eyebrow text-[var(--color-brand-accent)]">A note about cosmetic goals</p>
        <h2 class="mt-3 font-display font-semibold text-[length:var(--text-3xl)] leading-tight text-[var(--color-brand-primary)]">
          Realistic expectations, prioritising oral health
        </h2>
        <p class="mt-4 text-base text-[var(--color-text-muted)] leading-relaxed">
          Cosmetic dentistry addresses aesthetic concerns while keeping oral health the priority. At your consultation, we'll discuss realistic expectations and what options may be appropriate for your situation. Not all cosmetic concerns have a single solution, and some treatments may not be suitable depending on your existing dental health. Our team will walk you through the options, what each involves, and what you can reasonably expect.
        </p>
        <div class="mt-8">
          <a href="/book/" class="btn btn-primary">Request a Consultation</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       CTA BAND
       ============================================================ -->
  <section class="bg-[var(--color-brand-primary)] py-16 text-center overflow-hidden relative">
    <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 1440 160" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 60 C 240 20, 480 100, 720 60 C 960 20, 1200 100, 1440 60 L1440 160 L0 160 Z" fill="rgba(255,255,255,0.03)"/>
    </svg>
    <div class="relative container-wide">
      <h2 class="font-display font-semibold text-[length:var(--text-4xl)] text-white leading-tight">Considering a cosmetic treatment?</h2>
      <p class="mt-4 text-[var(--color-text-on-dark-muted)] text-lg max-w-xl mx-auto">Call <a href="tel:+14033277202" class="text-white font-semibold">403.327.7202</a> to book a consultation.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/book/" class="btn btn-primary btn-lg">Request a Consultation</a>
        <a href="/contact/" class="btn btn-lg border border-white/30 text-white hover:bg-white/10 transition-colors">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>
